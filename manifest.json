function gDisc(){
  const sl=ST.answers.addiction_screen||0,pl=ST.answers.addiction_porno||0,al=ST.answers.addiction_alc||0,fl=ST.answers.addiction_food||0;
  const hard=ST.multiAnswers.hardest||[];const red=isRed();
  // Screen time: progressive reduction from day 1 to day 80
  // sl=0 (4h+/day): 3h → 20min over 80 days
  // sl=1 (2-4h):    2h → 20min over 80 days
  // sl=2 (1-2h):    1h → 20min over 80 days
  // sl=3 (<1h):     30min → 20min over 80 days (already disciplined)
  function screenLimit(){
    const startMins=[180,120,60,30][sl];// starting values in minutes
    const endMins=20;// target for everyone at day 80
    const progress=Math.min(1,(ST.day-1)/79);// 0 at day 1, 1 at day 80
    const raw=Math.round(startMins+(endMins-startMins)*progress);
    const mins=red?Math.round(raw*1.5):raw;// reduced mode: more lenient
    // Format as Xh Ymin or Xmin
    if(mins>=60){const h=Math.floor(mins/60);const m=mins%60;return m===0?`${h}h`:`${h}h${m}`;}
    return`${mins} min`;
  }
  const screenLbl=screenLimit();
