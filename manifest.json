  const vh=ST.validationHours||[];
  const bilans=ST.bilans||[];
  const adapt={extraDiscQuest:false,miniMode:false,earlyBonus:false,discFocus:false};
  // 1. If discipline fails most → add micro discipline quest for 3 days
  const worstType=Object.entries(fb).sort((a,b)=>b[1]-a[1])[0];
  if(worstType&&worstType[0]==='disc'&&worstType[1]>=3)adapt.extraDiscQuest=true;
  if(worstType&&worstType[0]==='disc'&&worstType[1]>=5)adapt.discFocus=true;
  // 2. If chronic fatigue (3+ low energy bilans in last 7)
  const recent7=bilans.slice(-7);
  const lowE=recent7.filter(b=>b.energy&&b.energy<=2).length;
  if(lowE>=3)adapt.miniMode=true;
  // 3. If most validations before 15h → early bonus
  if(vh.length>=10){
    const early=vh.filter(h=>h<15).length;
    if(early/vh.length>0.6)adapt.earlyBonus=true;
  }
  return adapt;
}
function genWeek(){
  ST.gymW=0;ST.runW=0;
  const plan=[];const nh=noHard();

  // Gym sessions from onboarding: 0=2, 1=3, 2=4
  var targetGym=[2,3,4][ST.answers.gym_sessions||0];
  var targetRun=[0,1,2][ST.answers.run_freq||0];

  // V3: Fatigue adaptation - reduce if globalState is fatigue or adaptation says miniMode
  var adapt=getAdaptation();
  if(getGlobalState()==='fatigue'||adapt.miniMode){
    targetGym=Math.min(targetGym,3);
    targetRun=Math.min(targetRun,1);
  }

  // Guarantee exactly targetGym gym days, avoid consecutive
  const gymDays=new Set();
  const shuffled=[0,1,2,3,4,5,6].sort(()=>Math.random()-.5);
  for(const d of shuffled){
    if(gymDays.size>=targetGym)break;
    const prev=d>0&&gymDays.has(d-1);const next=d<6&&gymDays.has(d+1);
    if(!prev&&!next)gymDays.add(d);
  }
  // Fallback if not enough non-consecutive slots
  for(const d of [0,1,2,3,4,5,6]){if(gymDays.size>=targetGym)break;gymDays.add(d);}

  // Roll events for all 7 days
  // Strategy: guarantee the week always has at least 2-3 non-null events
  // by seeding fixed events on specific days, then filling the rest randomly
  const events=[];
  // Guaranteed events this week: pick 2-3 from the pool weighted by their rates
  const guaranteed=['doubleXP','hardMode','easyDay','shadow'];
  const weights=[5,7,10,3]; // doubleXP, hardMode, easyDay, shadow
  function pickGuaranteed(){
    const total=weights.reduce((a,b)=>a+b,0);
    let r=Math.random()*total;
    for(let i=0;i<guaranteed.length;i++){r-=weights[i];if(r<=0)return guaranteed[i];}
    return guaranteed[0];
  }
  // Assign guaranteed events to 2 random days out of 7
  const guaranteedDays=new Set();
  while(guaranteedDays.size<2){guaranteedDays.add(Math.floor(Math.random()*7));}
  const guaranteedEvents=[pickGuaranteed(),pickGuaranteed()];
  let gi=0;
  let prevEv=null;
  for(let d=0;d<7;d++){
    let ev;
    if(guaranteedDays.has(d)){
      ev=guaranteedEvents[gi++];
      // Don't repeat same event as previous day
      if(ev===prevEv)ev=pickGuaranteed();
    } else {
      ev=rollEv();
      if(ev!==null&&ev===prevEv)ev=rollEv(); // one retry
    }
    events.push(ev);
    prevEv=ev;
  }
  // V3: No events before day 7
  for(let e=0;e<events.length;e++){if(ST.day+e<7)events[e]=null;}
  // RECONSTRUCTION: force doubleXP every day, override events
  const reconActive=isReconstruction();
  if(reconActive){for(let e=0;e<events.length;e++)events[e]='doubleXP';}
  ST.todayEvent=events[0];

  for(let d=0;d<7;d++){
    const rd=isReconstruction(); // re-check per day (reconstructionDay advances)
    // RECONSTRUCTION: no gym, use body recon pool; no secondaries
    const isGymDay=gymDays.has(d);
    const last2Heavy=ST.lastBodyType&&ST.lastBodyType.slice(-2).every(t=>t==='heavy');
    const body=rd?gBodyNoGym(false):(isGymDay&&!last2Heavy)?gBodyGym():gBodyNoGym(d>0&&gymDays.has(d-1));
    ST.lastBodyType=ST.lastBodyType||[];ST.lastBodyType.push((isGymDay&&!last2Heavy&&!rd)?'heavy':'light');if(ST.lastBodyType.length>7)ST.lastBodyType=ST.lastBodyType.slice(-7);
    const nn=[body,gMind(),gDisc()];nn[0].id="nn0";nn[1].id="nn1";nn[2].id="nn2";
    const water={...gWater()};const secs=[];
    const fat=ST.fatigueScore||3;
    const dEv=events[d];

    // Discipline Day: replace random secondary with a disc-themed secondary (extra resistance quest)
    const isDiscDay=false; // removed in V3

    // RECONSTRUCTION: no secondaries at all
    if(!rd){
      if(!isMin()&&ST.day>=7&&Math.random()<.70)secs.push({...gSE(ST.day+d),id:"se"+d});
      if(!isMin()&&ST.day>=14&&Math.random()<.40)secs.push({...gSM(),id:"sm"+d});
      if(!nh&&ST.day>=21&&Math.random()<.15)secs.push({...gSH(),id:"sh"+d});

      // Hard Mode: add extra quest - only after day 7
      if(dEv==='hardMode'&&(ST.day+d)>=7){
        if(!isMin()){
          let hmQuest;
          if(fat<=1)hmQuest={...gSE(ST.day+d),id:"se_hm_"+d};
          else if(fat===2)hmQuest={...gSM(),id:"sm_hm_"+d};
          else hmQuest={...gSH(),id:"sh_hm_"+d};
          hmQuest.hardMode=true;
          secs.push(hmQuest);
        }
      }
    }

    // Discipline Day: guaranteed extra discipline secondary quest (zone de confort / résistance)
    if(isDiscDay&&!isMin()){
      const discExtras=[
        {id:"disc_d1_"+d,name:"Zéro réseaux sociaux pendant 3h consécutives",desc:"Pour réussir, n'hésite pas à bloquer tes apps avec un mot de passe (demande à un ami de le créer).",type:"se",icon:"&#128683;",cls:"qi-sec",tag:"tag-easy",tagLbl:"Discipline Day",xp:xpV('se'),pts:ptsV('se'),discDay:true},
        {id:"disc_d2_"+d,name:"Journée sans consommation passive d'écran",desc:"Pas de jeux, swipe, YouTube… Pour réussir, n'hésite pas à bloquer tes apps avec un mot de passe (demande à un ami de le créer).",type:"se",icon:"&#128683;",cls:"qi-sec",tag:"tag-easy",tagLbl:"Discipline Day",xp:xpV('se'),pts:ptsV('se'),discDay:true},
        {id:"disc_d3_"+d,name:"30min sans bruit de fond, d'ennui, uniquement avec tes pensées",desc:"Pas de musique, podcast, ni vidéo en fond. Être avec soi-même.",type:"se",icon:"&#128263;",cls:"qi-sec",tag:"tag-easy",tagLbl:"Discipline Day",xp:xpV('se'),pts:ptsV('se'),discDay:true},
      ];
      secs.push(pick(discExtras));
    }

    // V3: Track quest generation for spider chart
    if(!ST.questLog)ST.questLog={};
    var _qnames={body:'Body (Salle/Sport)',mind:'Mind (Étude/Lecture)',disc:'Discipline',water:'Hydratation',se:'Secondaire Facile',sm:'Secondaire Moyen',sh:'Secondaire Dur'};
    nn.forEach(function(q){var k=q.type;if(!ST.questLog[k])ST.questLog[k]={name:_qnames[k]||k,gen:0,ok:0};ST.questLog[k].gen++;});
    if(water){var k='water';if(!ST.questLog[k])ST.questLog[k]={name:'Hydratation',gen:0,ok:0};ST.questLog[k].gen++;}
    secs.forEach(function(q){var k=q.type;if(!ST.questLog[k])ST.questLog[k]={name:_qnames[k]||k,gen:0,ok:0};ST.questLog[k].gen++;});
    plan.push({nn,water,secs,event:dEv});
  }
  return plan;
}

