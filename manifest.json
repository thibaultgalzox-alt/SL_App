  'Y a-t-il une habitude qui était pénible et qui est devenue un plaisir ?',
  'Qu\'est-ce que le toi d\'il y a {d} jours penserait de toi aujourd\'hui ?',
];
function checkReflective(){
  if(ST.day<66)return false;
  if(ST.morningCheckDone===false)return false;
  var lastR=ST.lastReflectiveDay||0;
  return(ST.day-lastR>=14);
}
function showReflective(){
  ST.lastReflectiveDay=ST.day;
  var q=REFLECT_QS[ST.day%REFLECT_QS.length].replace(/\{d\}/g,ST.day);
  var az=document.getElementById('alert-zone');
  if(az){
    az.innerHTML='<div class="abox" style="padding:18px 14px;text-align:center"><div style="font-family:Playfair Display,Georgia,serif;font-size:16px;font-weight:700;color:#2a2118;margin-bottom:10px;line-height:1.5">'+q+'</div>'
      +'<textarea id="reflect-input" placeholder="Prends un moment pour y réfléchir..." style="width:100%;min-height:70px;border-radius:12px;border:2px solid #d4c9b0;padding:12px;font-size:13px;font-family:inherit;resize:vertical;background:#fff;color:#2a2118;margin-top:6px;line-height:1.5"></textarea>'
      +'<div style="font-size:10px;color:#8a7e6a;margin-top:4px;font-style:italic">Pas de bonne ou mauvaise réponse.</div>'
      +'<button class="btn primary" onclick="submitReflective()" style="width:100%;margin-top:10px">Continuer</button></div>';
