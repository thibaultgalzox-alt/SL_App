// SOUND ENGINE - Solo Leveling style (game UI / system sounds)
const SND=(function(){
  let ctx=null;
  function C(){
    if(!ctx)ctx=new(window.AudioContext||window.webkitAudioContext)();
    if(ctx.state==='suspended')ctx.resume();
    return ctx;
  }

  // Base tone: oscillator + gain envelope
  function tone(freq,type,startT,dur,vol,freqEnd){
    const c=C(),o=c.createOscillator(),g=c.createGain();
    o.connect(g);g.connect(c.destination);
    o.type=type;
    o.frequency.setValueAtTime(freq,c.currentTime+startT);
    if(freqEnd)o.frequency.exponentialRampToValueAtTime(freqEnd,c.currentTime+startT+dur);
    g.gain.setValueAtTime(0,c.currentTime+startT);
    g.gain.linearRampToValueAtTime(vol,c.currentTime+startT+0.005);
    g.gain.exponentialRampToValueAtTime(0.001,c.currentTime+startT+dur);
    o.start(c.currentTime+startT);
    o.stop(c.currentTime+startT+dur+0.01);
  }

  // Noise burst (impact/hit feel)
  function noise(startT,dur,vol){
    const c=C();
    const buf=c.createBuffer(1,Math.floor(c.sampleRate*dur),c.sampleRate);
    const data=buf.getChannelData(0);
    for(let i=0;i<data.length;i++)data[i]=(Math.random()*2-1);
    const src=c.createBufferSource();
    const g=c.createGain(),filt=c.createBiquadFilter();
    src.buffer=buf;filt.type='bandpass';filt.frequency.value=200;filt.Q.value=0.8;
    src.connect(filt);filt.connect(g);g.connect(c.destination);
    g.gain.setValueAtTime(vol,c.currentTime+startT);
    g.gain.exponentialRampToValueAtTime(0.001,c.currentTime+startT+dur);
    src.start(c.currentTime+startT);src.stop(c.currentTime+startT+dur+0.01);
  }

  return{
    // Perfect Clear - double chime ascendant, propre, cristallin (type: confirm/reward)
    perfect(){
      tone(880,'sine',0,.08,.22);
      tone(1320,'sine',.07,.1,.18);
      tone(1760,'sine',.15,.14,.20);
      tone(2637,'sine',.25,.18,.16);
    },

    // Fail - system error tone (2 short descending beeps)
    fail(){
      tone(520,'square',0,.06,.14);
      tone(380,'square',.1,.06,.14);
      tone(260,'square',.2,.1,.10);
    },

    // Ouverture app - sweep montant court, clean (type: system boot)
    open(){
      tone(440,'sine',0,.06,.10,660);
      tone(880,'sine',.08,.08,.12,1100);
      tone(1100,'sine',.18,.1,.08);
    },

    // Rank Up - fanfare épique en 2 temps, impactante (type: level up)
    rankUp(){
      noise(0,.04,.12);
      tone(523,'square',0,.05,.18);
      tone(659,'square',.06,.05,.20);
      tone(784,'square',.12,.06,.22);
      tone(1047,'sine',.19,.1,.25);
      tone(1319,'sine',.28,.08,.22);
      tone(1568,'sine',.36,.2,.20);
      tone(2093,'sine',.48,.35,.18);
    },

    // Bilan - notification douce, deux notes (type: soft UI confirm)
    bilan(){
      tone(660,'sine',0,.12,.12);
      tone(880,'sine',.14,.18,.10);
    },

    // Sanction - alarme grave menaçante, trois pulses (type: alert/warning)
    sanction(){
      noise(0,.08,.20);
      tone(110,'square',0,.1,.22);
      tone(82,'sawtooth',.12,.12,.20);
      noise(.18,.08,.15);
      tone(65,'square',.22,.15,.18);
    },

    // Potion - magical activation (shop item use)
    potion(){
      tone(660,'sine',0,.08,.15);
      tone(880,'sine',.06,.08,.18);
      tone(1100,'sine',.12,.08,.20);
      tone(1320,'sine',.18,.06,.15);
      tone(1760,'sine',.24,.15,.12);
    },

    // Reveal quête - tick électronique bref (type: UI card appear)
    reveal(){
      tone(1200,'square',0,.025,.07,900);
      tone(800,'sine',.025,.04,.05);
    },

    // Rare bonus - séquence montante rapide, cristalline (type: rare loot)
    rare(){
      tone(880,'sine',0,.06,.14);
      tone(1318,'sine',.07,.06,.16);
      tone(1760,'sine',.14,.06,.18);
      tone(2637,'sine',.21,.06,.20);
      tone(3520,'sine',.28,.18,.16);
    },
    // Check-in matinal - deux notes douces descendantes, neutre et calme
    checkin(){
      tone(528,'sine',0,.1,.10);
      tone(396,'sine',.12,.18,.08);
    },

  };
})();


function vib(p){if(navigator.vibrate)navigator.vibrate(p);}
function flash(c,d=400){const f=document.getElementById('flash');f.className='flash '+c+' show';setTimeout(()=>f.className='flash',d);}
function setNar(type){const pool=NAR[type]||[];const el=document.getElementById('narrative-text');if(!el||!pool.length)return;el.style.opacity='0';setTimeout(()=>{el.textContent=pick(pool);el.style.opacity='1';},200);}
function toast(msg){const t=document.getElementById('toast');t.textContent=msg;t.className='toast show';setTimeout(()=>t.className='toast',4000);}
function getRank(){for(let i=RANKS.length-1;i>=0;i--)if(ST.xp>=RANKS[i].min)return RANKS[i];return RANKS[0];}
function getWk(){return Math.floor((ST.day-1)/7)+1;}
var _testDateCounter=0;
function todayStr(){if(window._TEST_MODE)return'test-'+_testDateCounter;const d=new Date();return d.getFullYear()+'-'+d.getMonth()+'-'+d.getDate();}
function nowH(){if(window._TEST_MODE)return 14;return new Date().getHours();}
function isOpen(){if(window._TEST_MODE)return true;const h=nowH();return h>=10&&h<22;}
function rnd(a,b){return Math.floor(Math.random()*(b-a+1))+a;}
function pick(arr){return arr[Math.floor(Math.random()*arr.length)];}
function noRec(lst,id){return !lst.slice(-3).includes(id);}
function rdesc(str){const parts=str.split('+').map(s=>s.trim()).filter(Boolean);return parts[Math.floor(Math.random()*parts.length)];}
function monotonyCount(arr,id){return arr.slice(-7).filter(x=>x===id).length;}
function pickAntiMonotony(pool,lastArr){
  // Filter out quests seen >2 times in last 7 days
  const fresh=pool.filter(q=>monotonyCount(lastArr,q.id)<=2);
  if(fresh.length>0)return pick(fresh);
  // All blocked - pick the least repeated
  return pool.slice().sort((a,b)=>monotonyCount(lastArr,a.id)-monotonyCount(lastArr,b.id))[0]||pick(pool);
}
function monotonyCount(lst,id){return lst.slice(-7).filter(x=>x===id).length;}
function pickAntiMonotony(pool,lst){
  // Filter: remove quests that appeared >2 times in last 7 days
  const candidates=pool.filter(q=>monotonyCount(lst,q.id)<=2&&noRec(lst,q.id));
  if(candidates.length>0)return pick(candidates);
  // Fallback: pick least repeated
  return pool.slice().sort((a,b)=>monotonyCount(lst,a.id)-monotonyCount(lst,b.id))[0]||pick(pool);
}
function clamp(mn,v,mx){return Math.min(Math.max(v,mn),mx);}

function renderXPBar(){
  const rk=getRank();
  const pct=rk.next===99999?100:Math.min(100,Math.round((ST.xp-rk.min)/(rk.next-rk.min)*100));
  const fill=document.getElementById('xp-fill');if(fill)fill.style.width=pct+'%';
  const cur=document.getElementById('xp-cur');if(cur)cur.textContent=ST.xp+' XP';
  const nxt=document.getElementById('xp-nxt');if(nxt)nxt.textContent=rk.next===99999?'∞':rk.next+' XP';
}

function getRate7(){if(!ST.sr7.length)return 1;const l=ST.sr7.slice(-7);return l.reduce((a,b)=>a+b,0)/l.length;}
function rollEv(){const r=Math.random();if(r<.03)return'shadow';if(r<.08)return'doubleXP';if(r<.15)return'hardMode';if(r<.25)return'easyDay';return null;}
// Min Day: hardMode and shadow have no effect when isMin()
function getTodayEvent(){
  if(ST.day<=1)return null;
  // Manual override (e.g. shop Double XP) takes priority
  if(ST.todayEvent)return ST.todayEvent;
  if(!ST.weekPlan||!ST.weekPlan.length)return null;
  const idx=Math.min((ST.day-1)%7,ST.weekPlan.length-1);
  const dayPlan=ST.weekPlan[idx];
  const ev=(dayPlan&&dayPlan.event!==undefined)?dayPlan.event:null;
  // Silence hardMode and shadow on min days
  if(isMin()&&(ev==='hardMode'||ev==='shadow'))return null;
  return ev;
}

// ─── V3 GLOBAL STATE ENGINE ───
function getGlobalState(){
  const fs=ST.failStreak||0;const fat=ST.fatigueScore||3;const rate=getRate7();
  if(fs>=3)return'punishment';
  if(fat<=1)return'fatigue';
  if(rate>0.85&&fs===0)return'flow';
  return'normal';
}
function stateModifier(){
  const s=getGlobalState();const ev=getTodayEvent();
  let m=1.0;
  if(s==='fatigue')m=0.7;
  else if(s==='punishment')m=1.1;
  else if(s==='flow')m=1.15;
  if(ev==='easyDay')m*=0.85;
  else if(ev==='shadow')m*=1.3;
  else if(ev==='hardMode')m*=1.1;
  return m;
}
function getMult(){return stateModifier();}
function isMin(){return getGlobalState()==='fatigue';}
function isRed(){return !isReconstruction()&&(ST.failStreak||0)>=5;}
function noHard(){return getGlobalState()==='fatigue'||(ST.failStreak||0)>=4;}
// Reconstruction mode: returns current recon day (1-4) or 0 if inactive
function isReconstruction(){
  // Active if reconstructionDay is 1-4
  if((ST.reconstructionDay||0)>=1&&(ST.reconstructionDay||0)<=4)return ST.reconstructionDay;
  return 0;
}
// Check if reconstruction should trigger (called at advDay)
function _checkReconTrigger(){
  if(ST.day>66)return false;
  if((ST.reconstructionCooldown||0)>0)return false;
  if((ST.reconstructionDay||0)>=1)return false; // already active
  var log=ST.recentNNFails||[];
  if(log.length<3)return false;
  var last3=log.slice(-3);
  return last3.reduce(function(a,b){return a+b;},0)>=7;
}
function sc(a,b){
  const ratio=clamp(0,(getWk()-1)/20,1);
  var v=a+(b-a)*ratio*stateModifier();
  // Reconstruction: progressive reduction - priority over isRed
  const rd=isReconstruction();
  if(rd){
    // J1=20%, J2=40%, J3=60%, J4=80% of scaled range
    const mult=[0.2,0.4,0.6,0.8][rd-1]||0.2;
    v=a+(v-a)*mult;
  }
  return Math.round(clamp(a,v,b));
}
function xpV(tp,questMeta){
  const hard=ST.multiAnswers.hardest||[];const base={body:6,mind:6,disc:5,water:2,se:3,sm:5,sh:8};let v=base[tp]||4;
  if(tp==='body'&&hard.includes("Faire du sport régulièrement"))v=Math.round(v*1.5);
  if(tp==='mind'&&hard.includes("Étudier sans distraction"))v=Math.round(v*1.5);
  if(tp==='mind'&&hard.includes("Lire régulièrement"))v=Math.round(v*1.3);
  if(tp==='disc'&&hard.includes("Résister aux écrans"))v=Math.round(v*1.5);
  if(tp==='disc'&&hard.includes("Résister à la pornographie"))v=Math.round(v*1.5);
  if(tp==='se'||tp==='sm'||tp==='sh'){
    if(hard.includes("Sortir de sa zone de confort"))v=Math.round(v*1.5);
    if(hard.includes("Lire régulièrement"))v=Math.round(v*1.3);
  }
  // Apply state modifier (includes fatigue ×0.7, punishment ×1.1, flow ×1.15)
  v=Math.round(v*stateModifier());
  // Events - applied after state, independent of state
  if(getTodayEvent()==='doubleXP')v=Math.round(v*2);
  // Hard Mode / Discipline Day quests: x4 XP boost
  if(questMeta&&(questMeta.hardMode||questMeta.discDay))v=Math.round(v*4);
  // Note: isMin() (fatigue) already handled by stateModifier() above - not applied twice
  return v;
}
function ptsV(tp){return Math.round(xpV(tp)*.4);}

