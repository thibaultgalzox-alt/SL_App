// ─── IndexedDB storage (fallback to localStorage) ────────────────────────
const DB_NAME='solo_leveling_db_v2',DB_STORE='app_state',DB_KEY='main';
let _db=null;
function openDB(){
  return new Promise((res,rej)=>{
    if(_db)return res(_db);
    const req=indexedDB.open(DB_NAME,1);
    req.onupgradeneeded=e=>e.target.result.createObjectStore(DB_STORE);
    req.onsuccess=e=>{_db=e.target.result;res(_db);};
    req.onerror=()=>rej(req.error);
  });
}
async function saveState(state){
  try{
    const db=await openDB();
    return new Promise((res,rej)=>{
      const tx=db.transaction(DB_STORE,'readwrite');
      tx.objectStore(DB_STORE).put(state,DB_KEY);
      tx.oncomplete=()=>res();tx.onerror=()=>rej(tx.error);
    });
  }catch(e){try{localStorage.setItem('slv10',JSON.stringify(state));}catch(_){}}
}
async function loadState(){
  try{
    const db=await openDB();
    return new Promise((res,rej)=>{
      const req=db.transaction(DB_STORE,'readonly').objectStore(DB_STORE).get(DB_KEY);
      req.onsuccess=()=>res(req.result||null);req.onerror=()=>rej(req.error);
    });
  }catch(e){
    // Fallback to localStorage
    try{const r=localStorage.getItem('slv10');return r?JSON.parse(r):null;}catch(_){return null;}
  }
}
// Sync save wrapper (called everywhere as save())
function save(){saveState(ST);}
