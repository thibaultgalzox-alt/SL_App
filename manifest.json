function getToday(){if(!ST.weekPlan||!ST.weekPlan.length)return null;return ST.weekPlan[Math.min((ST.day-1)%7,ST.weekPlan.length-1)];}
function allNNDone(){const t=getToday();if(!t)return false;return t.nn.every(q=>ST.questStatus[q.id]&&ST.questStatus[q.id]!=='fail');}
function allNNValidated(){const t=getToday();if(!t)return false;return t.nn.every(q=>ST.questStatus[q.id]);}
function allFullDone(){const t=getToday();if(!t)return false;const all=[...t.nn,t.water,...(t.secs||[])].filter(Boolean);return all.every(q=>ST.questStatus[q.id]&&ST.questStatus[q.id]!=='fail');}
function allInteracted(){const t=getToday();if(!t)return false;const all=[...t.nn,t.water,...(t.secs||[])].filter(Boolean);return all.every(q=>ST.questStatus[q.id]);}
function hasAnyFail(){const t=getToday();if(!t)return false;return t.nn.some(q=>ST.questStatus[q.id]==='fail');}
function countRem(){const t=getToday();if(!t)return 0;return[...t.nn,t.water,...(t.secs||[])].filter(q=>q&&(!ST.questStatus[q.id]||ST.questStatus[q.id]==='fail')).length;}

function scheduleNotif(){
  if(!('Notification' in window)||Notification.permission!=='granted'){ST.notifOk=false;return;}
  ST.notifOk=true;
  // Direct notification scheduling via setInterval (runs while app is open)
  // Also send to SW for background notifications
  const t=getToday();
  const nnRemaining=t?t.nn.filter(q=>!ST.questStatus[q.id]||ST.questStatus[q.id]==='fail').length:3;
  const secRemaining=t?[t.water,...(t.secs||[])].filter(q=>q&&!ST.questStatus[q.id]).length:0;
  const hadFailYesterday=ST.hadFailYesterday||false;
  // SW-based (works in background if SW is alive)
  if('serviceWorker' in navigator){
    navigator.serviceWorker.ready.then(r=>{
      if(r.active)r.active.postMessage({type:'SCHEDULE',nnRemaining,secRemaining,hadFailYesterday});
    }).catch(()=>{});
  }
  // Direct fallback: check every 5 min and fire if needed
  if(window._notifTimer)clearInterval(window._notifTimer);
  window._notifTimer=setInterval(function(){
    var h=new Date().getHours(),m=new Date().getMinutes();
    var key='notif_'+h+'_'+new Date().toDateString();
    if(window['_nf_'+key])return;
    if(h===13&&m<5&&nnRemaining>0){
      window['_nf_'+key]=true;
      new Notification('Solo Leveling',{body:'Aucune quête validée. Tu dérives ?',icon:'./icons/icon-192.png'});
    }
    if(h===21&&m>=25&&m<30&&nnRemaining>0){
      window['_nf_'+key]=true;
      new Notification('Solo Leveling - Dernière fenêtre',{body:'Il reste des quêtes. Go !',icon:'./icons/icon-192.png'});
    }
  },300000); // every 5 min
}
async function askNotif(){
  if(!('Notification' in window)){toast('Notifications non supportées sur ce navigateur.');return;}
  if(Notification.permission==='granted'){ST.notifOk=true;save();scheduleNotif();toast('Notifications déjà actives ✓');return;}
  if(Notification.permission==='denied'){toast('Notifications bloquées. Autorise-les dans les paramètres du navigateur.');return;}
  const p=await Notification.requestPermission();
  ST.notifOk=(p==='granted');save();
  if(ST.notifOk){scheduleNotif();toast('Notifications activées !');}
  else{toast('Notifications refusées.');}
}

function buildQ(q,uid){
  if(!q)return'';const id=uid||q.id;const done=ST.questStatus[id];const locked=!isOpen();
  const isNN=id==='nn0'||id==='nn1'||id==='nn2';
  const isPorno=q.id==='d4'||q.name?.includes('pornographie');
  let act='';
  const liveXP=xpV(q.type||'se');
  const livePts=ptsV(q.type||'se');
  if(done==='dayoff')act=`<span class="qdone-lbl" style="color:#74b9ff">&#127796; Validée - Journée off</span>`;
  else if(done==='perfect')act=`<span class="qdone-lbl">&#10003; ${isNN?'Accomplie':'Accomplie'} - +${liveXP} XP, +${livePts} pts</span>`;
  else if(done==='clear')act=`<span class="qclear-lbl">&#10003; ${isNN?'En partie':'En partie'} - +${Math.round(liveXP*.7)} XP</span>`;
  else if(done==='fail')act=isNN?(ST.day<=14?`<span style="font-size:10px;color:#8a7e6a;font-style:italic">Fail. Fais mieux demain.</span>`:(ST.sanctionConfirmedAt?`<span style="font-size:10px;color:#B8612A;font-weight:600">Sanction effectuée.</span>`:`<span class="qfail-lbl">&#10007; Fail - correction demain 10h</span>`)):`<span style="font-size:10px;color:#8a7e6a;font-style:italic">Skippée</span>`;
  else if(locked){
    // Don't show "Disponible à 10h" for water/secs after a sanction day
    if(!isNN&&ST.sanctionConfirmedAt)act=`<span style="font-size:10px;color:#8a7e6a;font-style:italic">—</span>`;
    else act=`<span style="font-size:10px;color:#8a7e6a;font-style:italic">Disponible à partir de 10h</span>`;
  }
  else if(isNN){
    if(isPorno){
      act=`<button class="qbtn perfect" onclick="trig('${id}','perfect')">&#10003; Tenu</button><button class="qbtn fail" onclick="trig('${id}','fail')">Fail</button>`;
    } else {
      var _partLeft=2-(ST.weeklyPartialCount||0);
      if(_partLeft>0){
        act=`<button class="qbtn perfect" onclick="trig('${id}','perfect')">&#10003; Accomplie</button><button class="qbtn clear" onclick="trig('${id}','clear')">En partie <span style="font-size:9px;opacity:.6">(${_partLeft})</span></button><button class="qbtn fail" onclick="trig('${id}','fail')">Fail</button>`;
      } else {
        act=`<button class="qbtn perfect" onclick="trig('${id}','perfect')">&#10003; Accomplie</button><button class="qbtn fail" onclick="trig('${id}','fail')">Fail</button>`;
      }
    }
  } else act=`<button class="qbtn perfect" onclick="trig('${id}','perfect')">&#10003; Accomplie</button><button class="qbtn fail" style="background:#fff;border-color:#d4c9b0;color:#8a7e6a" onclick="trig('${id}','fail')">Skip</button>`;
  const displayXP=xpV(q.type||'se');
  const xc=q.type==='body'?'xp-g':q.type==='mind'||q.type==='water'?'xp-b':'xp-p';
  const hmStyle=q.hardMode?'border:2px solid #f39c12;box-shadow:0 0 8px rgba(243,156,18,.35);':q.discDay?'border:2px solid #d4a054;box-shadow:0 0 8px rgba(162,155,254,.3);':'';
  const hmLabel=q.hardMode
    ?`<span style="font-size:9px;font-weight:700;color:#f39c12;background:#2d1800;padding:2px 8px;border-radius:10px;margin:4px 0 0 38px;display:inline-block;letter-spacing:.04em">&#128293; HARD MODE BONUS</span>`
    :q.discDay
    ?`<span style="font-size:9px;font-weight:700;color:#d4a054;background:#1a1040;padding:2px 8px;border-radius:10px;margin:4px 0 0 38px;display:inline-block;letter-spacing:.04em">&#9876; DISCIPLINE DAY BONUS</span>`
    :'';
  return`<div class="qcard${done?' done':''}" id="qcard-${id}" style="${hmStyle}"><div class="qh"><div class="qicon ${q.cls}">${q.icon}</div><div class="qname">${q.name}</div><div class="qxp ${xc}">+${displayXP} XP</div></div><div class="qdesc">${q.desc}</div>${hmLabel}<span class="qtag ${q.tag}">${q.tagLbl}</span><div class="qactions">${act}</div></div>`;
}

function animQ(){setTimeout(()=>{document.querySelectorAll('.qcard').forEach((c,i)=>{setTimeout(()=>{c.classList.add('visible');SND.reveal();},i*120);});},100);}

var _trigBusy=false;
function trig(id,lv){
  if(_trigBusy)return;
  // If this quest already has this exact status, it's a ghost click - ignore
  if(ST.questStatus[id]===lv)return;
  // If quest already has ANY status and we're trying to set same type, ignore
  // (except fail can replace nothing)
  var _existing=ST.questStatus[id];
  if(_existing&&_existing!=='fail'&&lv!=='fail')return;
  _trigBusy=true;
  var card=document.getElementById('qcard-'+id);
  if(card){card.style.pointerEvents='none';card.style.opacity='.55';}
  setTimeout(function(){_trigBusy=false;},700);

  const isNN=id==='nn0'||id==='nn1'||id==='nn2';
  if(lv==='fail'){
    if(isNN){
      ST.questStatus[id]='fail';
      if(ST.day>14){
        ST.integrity=Math.max(0,ST.integrity-5);
        ST.points=Math.max(0,ST.points-15);
        ST.disciplineDebt=Math.min(200,(ST.disciplineDebt||0)+15);
      }
      const t2=getToday();if(t2){const q2=t2.nn.find(x=>x.id===id);if(q2){if(!ST.failByType)ST.failByType={body:0,mind:0,disc:0};ST.failByType[q2.type]=(ST.failByType[q2.type]||0)+1;
        if(q2.type==='disc')ST.weeklyBoss.discFail=(ST.weeklyBoss.discFail||0)+1;
      }}
      SND.fail();flash('red',500);vib([200,100,200]);
      save();renderMain();scheduleNotif();
      if(ST.day<=14){
        var earlyFails=(ST.failByType?Object.values(ST.failByType).reduce(function(a,b){return a+b;},0):0);
        if(earlyFails>=10){
          var whyLine=ST.myWhy?'\n\nTon pourquoi\u00a0: «\u00a0'+ST.myWhy+'\u00a0»':'';
          setTimeout(function(){toast('10 fails en moins de 14 jours. Une habitude prend 66 jours - tu en es au début. Mais là, il faut vraiment te bouger.'+whyLine,6000);},400);
        } else {toast('Fail. Fais mieux demain.');}
      } else {toast('Fail noté - sanction demain 10h');}
    } else {
      ST.questStatus[id]='fail';
      flash('grey',300);
      save();renderMain();toast('Skippée.');
    }
    return;
  }
  ST.questStatus[id]=lv;
  // Track "En partie" usage for NN (2/week limit)
  if(lv==='clear'&&isNN)ST.weeklyPartialCount=(ST.weeklyPartialCount||0)+1;
  const t=getToday();if(!t)return;
  if(!ST.questLog)ST.questLog={};
  const _allQ2=[...t.nn,t.water,...(t.secs||[])].filter(Boolean);
  const _qq=_allQ2.find(x=>x.id===id);
  if(_qq){
    const _qKey=_qq.type||_qq.id.replace(/[0-9]+$/,'');
    var _qnames2={body:'Body (Salle/Sport)',mind:'Mind (Étude/Lecture)',disc:'Discipline',water:'Hydratation',se:'Secondaire Facile',sm:'Secondaire Moyen',sh:'Secondaire Dur'};
    if(!ST.questLog[_qKey])ST.questLog[_qKey]={name:_qnames2[_qKey]||_qq.name.split(':')[0].trim().substring(0,20),gen:0,ok:0};
    if(lv==='perfect'||lv==='clear'||lv==='dayoff')ST.questLog[_qKey].ok++;
  }
  if(!ST.validationHours)ST.validationHours=[];
  if(lv==='perfect'||lv==='clear')ST.validationHours.push(nowH());
  if(ST.validationHours.length>200)ST.validationHours=ST.validationHours.slice(-200);
  const allQ=[...t.nn,t.water,...(t.secs||[])].filter(Boolean);const q=allQ.find(x=>x.id===id);
  if(q){
    const baseXP=xpV(q.type||'se');
    const baseP=ptsV(q.type||'se');
    const v=lv==='perfect'?baseXP:Math.round(baseXP*.7);
    const p=lv==='perfect'?baseP:Math.round(baseP*.7);
    ST.xp+=v;ST.points+=p;
    if(q.type==='body'&&lv==='perfect'){ST.totalBody++;ST.weeklyBoss.body=(ST.weeklyBoss.body||0)+1;if(!ST.successByType)ST.successByType={body:0,mind:0,disc:0};ST.successByType.body=(ST.successByType.body||0)+1;}
    else if(q.type==='body'){ST.totalBody++;if(!ST.successByType)ST.successByType={body:0,mind:0,disc:0};ST.successByType.body=(ST.successByType.body||0)+1;}
    if(q.type==='mind'&&isNN&&lv==='perfect'){ST.totalMind++;ST.weeklyBoss.mind=(ST.weeklyBoss.mind||0)+1;if(!ST.successByType)ST.successByType={body:0,mind:0,disc:0};ST.successByType.mind=(ST.successByType.mind||0)+1;}
    else if(q.type==='mind'){ST.totalMind++;if(!ST.successByType)ST.successByType={body:0,mind:0,disc:0};ST.successByType.mind=(ST.successByType.mind||0)+1;}
    if(q.type==='disc'){ST.totalDisc++;if(!ST.successByType)ST.successByType={body:0,mind:0,disc:0};ST.successByType.disc=(ST.successByType.disc||0)+1;}
    if(lv==='perfect'){SND.perfect();vib([100]);flash('green',400);}
    else{flash(isNN?'orange':'green',350);}
    if(lv==='perfect'&&Math.random()<.1&&allNNDone()){const b=Math.round(v*.5);ST.xp+=b;ST.points+=Math.round(p*.5);setTimeout(()=>{SND.rare();flash('gold',600);toast('Bonus rare ! +'+b+' XP');},500);}
    toast('+'+v+' XP +'+p+' pts - '+(lv==='perfect'?'Accomplie !':'En partie'));
    if(checkRankUp())return;
    if(checkNewTitles())return;
  }
  save();scheduleNotif();
  const rb=getRank().label;
  if(getRank().label!==rb){SND.rankUp();flash('purple',800);showRankUp(getRank());}
  renderMain();
}

function renderMainDone(t,locked){
  // Mark as simplified so renderMain knows not to re-call this
  document.getElementById('ql-nn').dataset.simplified='1';
  document.getElementById('ql-nn').innerHTML='';

  // Clear heavy UI elements
  document.getElementById('alert-zone').innerHTML='';
  document.getElementById('nb-zone').innerHTML='';
  // V3: state badge + compact UI
  // state-badge updated via _updateStatBlocks()
  // V3: removed'';
  document.getElementById('boss-zone').innerHTML='';
  document.getElementById('narrative-text').textContent='';
  
  const wbar=document.querySelector('.wbar');if(wbar)wbar.style.display='none';
  const now=new Date(),next=new Date();
  next.setDate(next.getDate()+1);next.setHours(0,0,0,0);
  const diff=next-now;const h=Math.floor(diff/3600000),mn=Math.floor((diff%3600000)/60000);
  const cdTxt=`Nouvelles quêtes dans ${h}h${String(mn).padStart(2,'0')} - À demain.`;
  const fullDone=allFullDone()&&!hasAnyFail();
  document.getElementById('alert-zone').innerHTML=
    (fullDone?`<div class="abox as" style="text-align:center;font-size:13px;font-weight:600;margin-bottom:5px">&#10003; Toutes les quêtes ont été validées. Bravo et à demain !</div>`:``)
    +`<div class="abox ai" style="text-align:center;font-size:12px;font-weight:600">&#9876; ${cdTxt}</div>`;

  // Keep secondary quests visible (still completable)
  const secs=t.secs||[];
  document.getElementById('ql-nn').innerHTML='';
  document.getElementById('ql-water').innerHTML=buildQ(t.water,'water0');
  document.getElementById('ql-sec').innerHTML=secs.length?secs.map(q=>buildQ(q,q.id)).join(''):`<div style="font-size:11px;color:#8a7e6a;padding:4px">Aucune quête secondaire.</div>`;
  document.querySelectorAll('.qcard').forEach(c=>c.classList.add('visible'));

  // Show bilan button if not done
  document.getElementById('bilan-btn').style.display=ST.reviewDone?'none':'';
  document.getElementById('bilan-btn').textContent=ST.reviewDone?'Bilan validé ✓':'Faire le bilan du soir';

  // Update header
  const rk=getRank();
  document.getElementById('rank-pill').textContent=rk.label;document.getElementById('title-text').textContent=ST.equippedTitle||rk.title;
  _updateStatBlocks();
  renderXPBar();
  const nnD=t.nn.filter(q=>ST.questStatus[q.id]==='perfect'||ST.questStatus[q.id]==='clear'||ST.questStatus[q.id]==='dayoff').length;
  document.getElementById('nn-count').textContent=nnD+'/'+t.nn.length;
  // [internal display removed]
  // [internal display removed]
  document.getElementById('dl-label').textContent='Deadline toutes quêtes';
  // V3: Rank projection
  const pz=document.getElementById('projection-zone');if(pz)pz.innerHTML='';
  const nbz=document.getElementById('nb-zone');if(!ST.notifOk&&'Notification' in window&&Notification.permission!=='denied')nbz.innerHTML=`<div class="nb">&#128276; Active les rappels<button class="btn primary" style="padding:4px 10px;font-size:11px;white-space:nowrap;margin-left:auto" onclick="askNotif()">Activer</button></div>`;else nbz.innerHTML='';
  document.getElementById('slbl').style.display='none';
}

function _cd(){const now=new Date(),next=new Date();next.setDate(next.getDate()+1);next.setHours(0,0,0,0);const diff=next-now;return`${Math.floor(diff/3600000)}h${String(Math.floor((diff%3600000)/60000)).padStart(2,'0')}`;}
function _updateSimplifiedCd(){
  const az=document.getElementById('alert-zone');if(!az)return;
  az.innerHTML=`<div class="abox as" style="text-align:center;font-size:13px;font-weight:600">&#10003; Toutes les quêtes ont été validées. Bravo et à demain !</div><div class="abox ai" style="text-align:center;font-size:12px;font-weight:600">&#9876; Nouvelles quêtes dans ${_cd()} - À demain.</div>`;
}
function _updateStatBlocks(){
  document.getElementById('s-day').textContent=ST.day;
  document.getElementById('s-week').textContent='S'+getWk();
  document.getElementById('s-streak').textContent=ST.streak;
  const intVal=ST.day>=14?ST.integrity:'—';
  document.getElementById('s-int').textContent=intVal;
  // Integrity block color
  const scInt=document.getElementById('sc-int');
  if(scInt&&ST.day>=14){
    const iv=ST.integrity||100;
    scInt.classList.remove('int-warn','int-crit','int-zero');
    if(iv<=0)scInt.classList.add('int-zero');
    else if(iv<30)scInt.classList.add('int-crit');
    else if(iv<60)scInt.classList.add('int-warn');
  }
  // State badge: current rank → next rank in ~X days
  var _sb=document.getElementById('state-badge');
  if(_sb){
    const _rk=getRank();
    const _rkIdx=RANKS.findIndex(r=>r.label===_rk.label);
    const _nextRk=_rkIdx<RANKS.length-1?RANKS[_rkIdx+1]:null;
    const _needed=_rk.next-ST.xp;
    var _avgXP=10;const _dl=ST.dayLog||[];
    if(_dl.length>=3){const _rec=_dl.slice(-Math.min(14,_dl.length));let _xt=0;for(let _j=1;_j<_rec.length;_j++)_xt+=Math.max(0,(_rec[_j].xp||0)-(_rec[_j-1].xp||0));const _du=Math.max(1,_rec.length-1);const _cp=Math.round(_xt/_du);if(_cp>0&&_cp<200)_avgXP=_cp;}
    else if(ST.sr7&&ST.sr7.length>=3){const _s7=ST.sr7.slice(-14);const _rt=_s7.filter(x=>x===1).length/_s7.length;if(_rt>0)_avgXP=Math.round(_rt*18);}
    const _dn=_avgXP>0?Math.ceil(_needed/_avgXP):999;
    if(_nextRk&&_needed>0&&_dn>0&&_dn<3000)_sb.innerHTML=_rk.label+' → <strong>'+_nextRk.label+'</strong> dans ~<strong>'+_dn+'j</strong>';
    else if(!_nextRk||_rk.label==='Rang Nation')_sb.textContent='Rang Nation - Sommet atteint';
    else _sb.textContent=_rk.label;
  }
}
function _updateHeader(t){
  const rk=getRank();document.getElementById('rank-pill').textContent=rk.label;document.getElementById('title-text').textContent=ST.equippedTitle||rk.title;
  _updateStatBlocks();
  renderXPBar();
  if(t){const nnD=t.nn.filter(q=>ST.questStatus[q.id]==='perfect'||ST.questStatus[q.id]==='clear'||ST.questStatus[q.id]==='dayoff').length;document.getElementById('nn-count').textContent=nnD+'/'+t.nn.length;}
}

function morningCheck(mood,btn){
  if(ST.morningCheckDone)return;
  ST.morningCheckDone=true;
  ST.todayMood=mood;
  if(!ST.moodLog)ST.moodLog=[];
  ST.moodLog.push({day:ST.day,mood:mood});
  if(ST.moodLog.length>200)ST.moodLog=ST.moodLog.slice(-200);
  if(mood==='bad'&&ST.fatigueScore>1)ST.fatigueScore=Math.max(1,ST.fatigueScore-1);
  if(mood==='good'&&ST.fatigueScore<4)ST.fatigueScore=Math.min(4,ST.fatigueScore+1);
  // Grey flash on the clicked button only - no full-screen flash
  if(btn){var _b=btn;_b.style.background='#b8b8b8';_b.style.transform='scale(.95)';setTimeout(function(){_b.style.background='';_b.style.transform='';},280);}
  SND.checkin();
  var el=document.getElementById('morning-checkin-zone');if(el)el.innerHTML='';
  save();renderMain();
  var msgs={good:'Bonne journée à toi.',ok:'Donne ce que tu peux - c\'est déjà beaucoup.',bad:'Courage. Fais juste un pas aujourd\'hui.'};
  toast(msgs[mood]||'C\'est noté.');
}

// ═══ REFLECTIVE QUESTIONS (J66+, every 14 days) ═══
var REFLECT_QS=[
  'Tu fais ça depuis {d} jours. Est-ce que tu as remarqué des changements ?',
  'Quelles habitudes te semblent maintenant naturelles ?',
  'Si tu arrêtais l\'application demain, quelles habitudes garderais-tu ?',
  'Est-ce que tu fais ces quêtes pour les points, ou pour toi ?',
