    }
    if(t.ok(ST))_checkedTitles[t.id]=true;
  }
  return false;
}


// ─── V3 ADAPTIVE ENGINE - recalibrates from stats ───
function adaptFromStats(){
  if(!ST.adaptBonus)ST.adaptBonus={};
  const fb=ST.failByType||{body:0,mind:0,disc:0};
  const sb=ST.successByType||{body:0,mind:0,disc:0};
  const bilans=ST.bilans||[];
  const vh=ST.validationHours||[];
  // 1. Weakest axis → micro-quest boost for 3 days
  const axes=[{t:'body',f:fb.body||0},{t:'mind',f:fb.mind||0},{t:'disc',f:fb.disc||0}];
  axes.sort((a,b)=>b.f-a.f);
  if(axes[0].f>=3)ST.adaptBonus.weakAxis=axes[0].t;else ST.adaptBonus.weakAxis=null;
  // 2. Chronic fatigue → easier mode more often
  const last5=bilans.slice(-5);
  const lowEnergy=last5.filter(b=>b.energy&&b.energy<=2).length;
  ST.adaptBonus.chronicFatigue=lowEnergy>=3;
  if(ST.adaptBonus.chronicFatigue&&ST.fatigueScore>1)ST.fatigueScore=Math.max(1,ST.fatigueScore-1);
  // 3. Early bird bonus - if >60% validations before 15h
  if(vh.length>=10){
    const earlyPct=vh.filter(h=>h<15).length/vh.length;
    ST.adaptBonus.earlyBird=earlyPct>0.6;
  }
  // 4. Relapse patterns → extra discipline focus
  const relapses=bilans.filter(b=>b.resisted===false);
  ST.adaptBonus.relapseHeavy=relapses.length>=3&&relapses.length/Math.max(1,bilans.length)>0.15;
  save();
}

