  save();renderMain();
}

function allNNValidated(){const t=getToday();if(!t)return false;return t.nn.every(q=>ST.questStatus[q.id]);}

function renderMain(){
  const t=getToday();if(!t)return;const locked=!isOpen();
  
  // ═══ MICRO CHECK-IN MATINAL - shown as card, quests still accessible ═══
  // Inject into a dedicated zone, don't block quest rendering
  var _czCheck=document.getElementById('morning-checkin-zone');
  if(_czCheck){
    if(!ST.morningCheckDone&&!locked&&!ST.dayDone){
      if(!_czCheck.innerHTML){
        ST._morningCheckShownAt=Date.now();
        _czCheck.innerHTML='<div id="morning-checkin" style="background:var(--card);border-radius:var(--r);padding:16px;box-shadow:var(--shadow-md);border-left:4px solid var(--accent);height:100%;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;gap:10px">'
          +'<div style="font-size:11px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:var(--accent)">Comment tu te sens aujourd\'hui ?</div>'
          +'<div style="display:flex;gap:6px">'
          +'<button class="btn" style="flex:1;font-size:11px;padding:9px 3px;font-weight:600;touch-action:manipulation;background:var(--green-bg);border:1.5px solid var(--green);color:var(--green);box-shadow:none" onclick="morningCheck(\'good\',this)">😊 Bien</button>'
          +'<button class="btn" style="flex:1;font-size:11px;padding:9px 3px;font-weight:600;touch-action:manipulation;background:var(--gold-bg);border:1.5px solid var(--gold);color:var(--gold);box-shadow:none" onclick="morningCheck(\'ok\',this)">😐 Moyen</button>'
          +'<button class="btn" style="flex:1;font-size:11px;padding:9px 3px;font-weight:600;touch-action:manipulation;background:var(--red-bg);border:1.5px solid var(--red);color:var(--red);box-shadow:none" onclick="morningCheck(\'bad\',this)">😔 Pas bien</button>'
          +'</div></div>';
      } else {
        // Auto-dismiss after 30 min of no response
        if(ST._morningCheckShownAt&&(Date.now()-ST._morningCheckShownAt)>1800000){
          ST.morningCheckDone=true;_czCheck.innerHTML='';save();
        }
      }
    } else {
      _czCheck.innerHTML='';
    }
  }

  // ═══ REFLECTIVE QUESTION (J66+, every 14 days) ═══
  if(checkReflective()&&!ST.dayDone){
    showReflective();
    return;
  }

  const wbar=document.querySelector('.wbar');if(wbar)wbar.style.display='';

  // Simplified view ONLY when ALL quests SUCCESSFULLY done (no fails)
  if(allFullDone()&&!ST.dayDone){
    if(!document.getElementById('ql-nn').dataset.simplified){
      renderMainDone(t,locked);
    } else {
      _updateSimplifiedCd();_updateHeader(t);
    }
    return;
  }
  // If all interacted but has fails → show bilan prompt, not simplified view
  if(allInteracted()&&hasAnyFail()&&!ST.dayDone&&!ST.reviewDone){
    delete document.getElementById('ql-nn').dataset.simplified;
    // Force bilan button visible and highlighted
  }
  // Clear simplified flag if not all done yet
  delete document.getElementById('ql-nn').dataset.simplified;
  // Build a stable fingerprint of today's quest IDs + statuses - only rebuild DOM if something changed
  const fingerprint=JSON.stringify([...t.nn.map(q=>q.id+':'+(ST.questStatus[q.id]||'')),
    'w:'+(ST.questStatus['water0']||''),
    ...(t.secs||[]).map(q=>q.id+':'+(ST.questStatus[q.id]||''))]);
  const prevFp=document.getElementById('ql-nn').dataset.fp||'';
  const needsRebuild=fingerprint!==prevFp;
  if(needsRebuild){
    const isFirst=!prevFp;
    document.getElementById('ql-nn').dataset.fp=fingerprint;
    document.getElementById('ql-nn').innerHTML=t.nn.map(q=>buildQ(q,q.id)).join('');
    document.getElementById('ql-water').innerHTML=buildQ(t.water,'water0');
    const secs=t.secs||[];document.getElementById('ql-sec').innerHTML=secs.length?secs.map(q=>buildQ(q,q.id)).join(''):`<div style="font-size:11px;color:#8a7e6a;padding:4px">${isMin()?'Mode Minimum - secondaires suspendues.':'Aucune quête secondaire.'}</div>`;
    if(isFirst)animQ();else document.querySelectorAll('.qcard').forEach(c=>c.classList.add('visible'));
  }
  document.getElementById('bilan-btn').style.display=locked?'none':'';
  if(!locked&&!ST.reviewDone){
    const t2=getToday();
    if(t2){
      const allQ=[...t2.nn,t2.water,...(t2.secs||[])].filter(Boolean);
      const missing=allQ.filter(q=>!ST.questStatus[q.id]).length;
      const fails=t2.nn.filter(q=>ST.questStatus[q.id]==='fail').length;
      if(fails>0){
        document.getElementById('bilan-btn').textContent='⚠ Bilan soir - '+fails+' quête'+(fails>1?'s':'')+' en échec';
        document.getElementById('bilan-btn').style.background='var(--red-bg)';
        document.getElementById('bilan-btn').style.color='var(--red)';
        document.getElementById('bilan-btn').style.fontWeight='700';
      } else if(missing>0){
        document.getElementById('bilan-btn').textContent='Bilan soir ('+missing+' quête'+(missing>1?'s':'')+' restante'+(missing>1?'s':'')+')';
        document.getElementById('bilan-btn').style.background='';document.getElementById('bilan-btn').style.color='';document.getElementById('bilan-btn').style.fontWeight='';
      } else {
        document.getElementById('bilan-btn').textContent='Bilan soir - tout validé ✓';
        document.getElementById('bilan-btn').style.background='var(--green-bg)';document.getElementById('bilan-btn').style.color='var(--green)';document.getElementById('bilan-btn').style.fontWeight='600';
      }
    }
  }
  // V3: state badge + compact UI
  // state-badge updated via _updateStatBlocks()
  // V3: removedisMin()?`<div class="min-banner" style="font-size:12px;font-weight:600;color:#d4a054;background:#fff8e1;border:1px solid #d4a054;border-radius:8px;padding:10px 14px;margin:.4rem 0;text-align:center">&#128564; Mode survie activé. Aujourd'hui, l'objectif est de ne pas rompre la chaîne.</div>`:'';

  const msgs=[];
  if(locked)msgs.push({c:'ai',m:'&#128274; Quêtes actives de 10h à 22h.'});
  else{
    // Events - only show if the event actually has an effect
    const fat=ST.fatigueScore||3;
    const todayEv=getTodayEvent();
    // Only show event banner if it has a real effect today
    const hasHMQuest=!!(t.secs||[]).find(q=>q.hardMode);
    const hasDiscQuest=!!(t.secs||[]).find(q=>q.discDay);
    const evDesc={
      doubleXP:'&#9889; Double XP - toutes tes quêtes rapportent 2× plus d\'XP aujourd\'hui.',
      hardMode: hasHMQuest?( fat<=1?'&#128293; Hard Mode - quête facile bonus ajoutée.': fat===2?'&#128293; Hard Mode - quête moyenne bonus ajoutée.':'&#128293; Hard Mode - quête difficile supplémentaire ajoutée.'):null,
      easyDay: isMin()?null:'&#127774; Easy Day - durées et volumes réduits de 20% aujourd\'hui.',
      
      shadow: isMin()?null:'&#128171; Shadow Event - toutes les quêtes rapportent +30% d\'XP aujourd\'hui et les volumes sont plus élevés. L\'événement le plus rare du programme.',
    };
    if(todayEv&&evDesc[todayEv])msgs.push({c:'ae',m:evDesc[todayEv]});
    // Adaptive difficulty - silent in UI (kept in code for adjustments)
    // if(fs>=3) ... easyDay ... → invisible to user, system adjusts silently
    if(ST.sanctionPending&&ST.day>=15)msgs.push({c:'ad',m:'&#9888; Sanction non accomplie - pénalité doublée au prochain fail.'});
    const f=t.nn.filter(q=>ST.questStatus[q.id]==='fail');if(f.length&&ST.day>=15)msgs.push({c:'ad',m:`${f.length} quête`+(f.length>1?'s':'')+` en Fail - correction imposée demain avant 10h.`});
    // (integrity status shown via bloc 4 color)
    // integrity status shown via bloc 4 color only
    // NN done banner - only shown when 3 NN validated but not all quests done yet
    // ═══ PROGRESSION MESSAGES - what sections are fully treated ═══
    (function(){
      var _t=getToday();if(!_t)return;
      var _qs=ST.questStatus;
      var _nnTreated=_t.nn.every(function(q){return _qs[q.id];});
      var _waterTreated=_t.water&&!!_qs[_t.water.id];
      var _secs=_t.secs||[];var _hasSecs=_secs.length>0;
      var _secsTreated=_hasSecs&&_secs.every(function(q){return _qs[q.id];});
      var _allTreated=_nnTreated&&_waterTreated&&(!_hasSecs||_secsTreated);
      if(_allTreated){
        var _hasFails=_t.nn.some(function(q){return _qs[q.id]==='fail';});
        if(_hasFails&&ST.day>=15){
          msgs.push({c:'as',m:'Toutes les quêtes de la journée ont été traitées. Fais ta sanction, repose-toi et à demain.'});
        } else {
          msgs.push({c:'as',m:'Toutes les quêtes de la journée ont été traitées, bravo\u00a0! Repose-toi, et à demain.'});
        }
        return;
      }
      var _done=[],_remain=[];
      if(_nnTreated)_done.push('nn');else _remain.push('nn');
      if(_waterTreated)_done.push('w');else _remain.push('w');
      if(_hasSecs){if(_secsTreated)_done.push('s');else _remain.push('s');}
      if(_done.length===0)return;
      // Fixed labels - no article needed in "done" position, proper article in "remain" position
      function _namesDone(codes){
        var p=[];
        if(codes.indexOf('nn')>=0)p.push('quêtes principales');
        if(codes.indexOf('w')>=0)p.push('quête eau');
        if(codes.indexOf('s')>=0)p.push('quêtes secondaires');
        if(!p.length)return'';
        if(p.length===1)return p[0];
        var l=p.pop();return p.join(', ')+' et '+l;
      }
      function _namesRemain(codes){
        // Returns "les quêtes principales", "la quête eau", "les quêtes secondaires"
        var p=[];
        if(codes.indexOf('nn')>=0)p.push('les quêtes principales');
        if(codes.indexOf('w')>=0)p.push('la quête eau');
        if(codes.indexOf('s')>=0)p.push('les quêtes secondaires');
        if(!p.length)return'';
        if(p.length===1)return p[0];
        var l=p.pop();return p.join(', ')+' et '+l;
      }
      var msg='';
      if(_done.length===1&&_remain.length>0){
        var _dName=_namesDone(_done);
        var _rName=_namesRemain(_remain);
        msg='Statut '+(_done[0]==='w'?'de la ':des_prefix(_done[0]))+_dName+' enregistré. Continue avec '+_rName+'\u00a0!';
      } else if(_done.length===2&&_remain.length>0){
        var _dName2=_namesDone(_done);
        var _last=_remain[0];
        var _rName2=_namesRemain(_remain);
        var _prefix='Statut des '+_dName2+' enregistré. ';
        if(_last==='w')msg=_prefix+'Termine cette journée avec la quête eau\u00a0!';
        else if(_last==='s')msg=_prefix+'Continue avec les quêtes secondaires\u00a0!';
        else msg=_prefix+'Continue avec les quêtes principales\u00a0!';
      }
      function des_prefix(code){return code==='w'?'de la ':code==='nn'?'des ':'des ';}
      if(msg)msgs.push({c:'as',m:'\u2713 '+msg});
    })();
    // ═══ RECONSTRUCTION MODE ═══
    if(isReconstruction()){
      const rd=isReconstruction();
      var whyMsg=ST.myWhy?'<br/><em style="opacity:.75;font-style:italic">«\u00a0'+ST.myWhy+'\u00a0»</em>':'';
      const reductions=['80%','60%','40%','20%'];
      msgs.push({c:'ai',m:`⚡ Double XP · Mode Reconstruction J${rd}/4 - Quêtes allégées de ${reductions[rd-1]||'20%'}.${whyMsg}`});
    }
  }
  document.getElementById('alert-zone').innerHTML=msgs.map(x=>`<div class="abox ${x.c}">${x.m}</div>`).join('');

  // Clear unused progression-card div
  var _pcEl=document.getElementById('progression-card');if(_pcEl)_pcEl.innerHTML='';

  const wb=ST.weeklyBoss||{body:0,mind:0,discFail:0};
  // Boss requirements change by week
  var bossWeek=ST.week||1;
  var needBody=3,needMind=(bossWeek>=2?4:0),needDiscCheck=(bossWeek>=3);
  var bDisp2=Math.min(wb.body||0,needBody);
  var mDisp2=needMind>0?Math.min(wb.mind||0,needMind):0;
  var bPct=Math.min(100,Math.round(bDisp2/needBody*100));
  var mPct=needMind>0?Math.min(100,Math.round(mDisp2/needMind*100)):100;
  var dOk=needDiscCheck?(wb.discFail||0)<=2:true;
  var bWon=bPct>=100&&mPct>=100&&dOk;
  const bossClaimable=bWon&&!ST._bossShownThisWeek;
  var bossHTML='<div class="boss-card"><div class="boss-title">&#128293; Boss hebdomadaire'+(bWon?' - &#127942; Vaincu !':'')+'</div>';
  bossHTML+='<div class="boss-row"><span>Body '+bDisp2+'/'+needBody+'</span><span>'+bPct+'%</span></div><div class="boss-bar"><div class="boss-fill body" style="width:'+bPct+'%"></div></div>';
  if(needMind>0)bossHTML+='<div class="boss-row"><span>Mind '+mDisp2+'/'+needMind+'</span><span>'+mPct+'%</span></div><div class="boss-bar"><div class="boss-fill mind" style="width:'+mPct+'%"></div></div>';
  if(needDiscCheck)bossHTML+='<div class="boss-row"><span>Discipline (max 2 fails) : '+(wb.discFail||0)+'</span><span style="color:'+(dOk?'#00b894':'#e74c3c')+'">'+(dOk?'&#10003;':'&#10007;')+'</span></div>';
  if(bossClaimable)bossHTML+='<button class="btn gold full" style="margin-top:8px;animation:pulse-welcome 2s infinite" onclick="claimBossFromMain()">&#127942; Réclamer la victoire !</button>';
  bossHTML+='</div>';
  document.getElementById('boss-zone').innerHTML=bossHTML;

  // V3: debt shown in state badge

  const rk=getRank();document.getElementById('rank-pill').textContent=rk.label;document.getElementById('title-text').textContent=ST.equippedTitle||rk.title;
  _updateStatBlocks();
  renderXPBar();
  const nnD=t.nn.filter(q=>ST.questStatus[q.id]&&ST.questStatus[q.id]!=='fail').length;document.getElementById('nn-count').textContent=nnD+'/'+t.nn.length;
  // [internal display removed]
  // [internal display removed]
  const h=nowH();if(isOpen())document.getElementById('dl-label').textContent='8h - 22h · encore '+(`${22-h}h`);else document.getElementById('dl-label').textContent='8h - 22h';
  // V3: Rank projection
  const nbz=document.getElementById('nb-zone');if(!ST.notifOk&&'Notification' in window&&Notification.permission!=='denied')nbz.innerHTML=`<div class="nb">&#128276; Active les rappels<button class="btn primary" style="padding:4px 10px;font-size:11px;white-space:nowrap;margin-left:auto" onclick="askNotif()">Activer</button></div>`;else nbz.innerHTML='';
  const pz=document.getElementById('projection-zone');if(pz)pz.innerHTML='';
}

function claimBossFromMain(){
  ST._bossShownThisWeek=true;save();
  ST._bossFromMain=true; // flag: return to main after victory, not showDone
  showBossVictory();
}
function showDone(){
  ST.dayDone=true;save();SND.bilan();vib([100]);
  const t=getToday();let tot=0;if(t){[...t.nn,t.water,...(t.secs||[])].filter(Boolean).forEach(q=>{const d=ST.questStatus[q.id];const lxp=xpV(q.type||'se');if(d==='perfect')tot+=lxp;else if(d==='clear')tot+=Math.round(lxp*.7);});}
  document.getElementById('done-xp').textContent='+'+tot+' XP';
  const wb=ST.weeklyBoss||{};
  var _bw=ST.week||1;
  var _needM=_bw>=2?4:0;var _needDisc=_bw>=3;
  var bWon=(wb.body||0)>=3&&(_bw<2||(wb.mind||0)>=_needM)&&(!_needDisc||(wb.discFail||0)<=2);const brz=document.getElementById('boss-reward-zone');
  if(bWon&&!ST._bossShownThisWeek){
    ST._bossShownThisWeek=true;save();
    showBossVictory();return;
  }
  brz.innerHTML='';
  updateCD();show('s-done');
}
function updateCD(){const now=new Date(),next=new Date();next.setDate(next.getDate()+(now.getHours()>=10?1:0));next.setHours(10,0,0,0);const diff=next-now;const h=Math.floor(diff/3600000),m=Math.floor((diff%3600000)/60000);const el=document.getElementById('done-cd');if(el)el.textContent=`Dans ${h}h${String(m).padStart(2,'0')}`;}

function _getQuestDetails(){
  var t=getToday();if(!t)return[];
  var all=[].concat(t.nn,[t.water],(t.secs||[])).filter(Boolean);
  return all.map(function(q){
    var s=ST.questStatus[q.id]||'skip';
    return{name:(q.name||'').substring(0,35),status:s,type:q.type||'se'};
  });
}
function openReview(){
  if(ST.reviewDone){toast('Bilan déjà validé aujourd\'hui.');return;}
  if(ST.sanctionPending){
    SND.sanction();flash('red',400);vib([200,100,200]);
    _updateAbsenceDays();
    _renderSanctionScreen();
    swSanctionLock(true);
    show('s-sanction');return;
  }

  // Check all quests have been updated by user
  const t=getToday();
  if(t){
    const allQ=[...t.nn,t.water,...(t.secs||[])].filter(Boolean);
    const missing=allQ.filter(q=>!ST.questStatus[q.id]);
    if(missing.length>0){
      // Shake the button + fail sound + red flash
      const btn=document.getElementById('bilan-btn');
      btn.classList.remove('btn-shake');
      void btn.offsetWidth; // force reflow
      btn.classList.add('btn-shake');
      setTimeout(()=>btn.classList.remove('btn-shake'),600);
      SND.fail();flash('red',400);vib([200,100,200]);
      toast('Avant le bilan, traite toutes les quêtes !');
      return;
    }
  }

  ST.resistedToday=null;
  // Show morning mood if set
  var _mz=document.getElementById('rv-morning-mood');
  if(_mz){
    var _mLabels={good:'☀ Humeur matin : Bien',ok:'🌤 Humeur matin : Je peux aller mieux',bad:'🌧 Humeur matin : Pas bien'};
    if(ST.todayMood&&_mLabels[ST.todayMood]){_mz.textContent=_mLabels[ST.todayMood];_mz.style.display='block';}
    else _mz.style.display='none';
  }
  ['st-energy','st-disc'].forEach(id=>{
    document.getElementById(id).innerHTML=[1,2,3,4,5].map(n=>`<div class="star" id="${id}-${n}" onclick="setStar('${id}',${n})">&#9733;</div>`).join('');
  });
  document.getElementById('block-txt').value='';
  document.getElementById('relapse-txt').value='';
  document.getElementById('relapse-z').style.display='none';
  document.getElementById('r-yes').style.background='';
  document.getElementById('r-no').style.background='';
  const tz=document.getElementById('truth-zone');
  if(ST.day%7===0&&!ST.weekTruthDone){
    tz.innerHTML=`<div class="truth-card"><div style="font-size:12px;font-weight:600;color:#3a2e22;margin-bottom:8px">Mode Vérité - le programme était-il calibré cette semaine ?</div><div><span class="truth-opt" onclick="setTruth('tooEasy')">Trop facile</span><span class="truth-opt" onclick="setTruth('ok')">Calibré</span><span class="truth-opt" onclick="setTruth('tooHard')">Trop dur</span></div></div>`;
  } else tz.innerHTML='';
  show('s-review');
}
function setStar(id,n){for(let i=1;i<=5;i++){const s=document.getElementById(id+'-'+i);if(s)s.classList.toggle('sel',i<=n);}}
function getStars(id){for(let i=5;i>=1;i--){const s=document.getElementById(id+'-'+i);if(s&&s.classList.contains('sel'))return i;}return 0;}
function setResist(v){ST.resistedToday=v;document.getElementById('r-yes').style.background=v?'#e8f5e9':'';document.getElementById('r-no').style.background=!v?'#fce8e8':'';document.getElementById('relapse-z').style.display=v?'none':'block';}
function setTruth(val){ST.weekTruthDone=true;document.querySelectorAll('.truth-opt').forEach(o=>o.classList.remove('sel'));event.target.classList.add('sel');toast('Réponse enregistrée.');save();}

function submitReview(){
  const t=getToday();if(!t)return;
  ST.reviewDone=true;
  const energy=getStars('st-energy');const disc=getStars('st-disc');
  const block=document.getElementById('block-txt').value;
  const relapse=ST.resistedToday===false?document.getElementById('relapse-txt').value:'';

  // Auto-fail any NN not yet validated (not touched before bilan)
  t.nn.forEach(q=>{
    if(!ST.questStatus[q.id]){
      ST.questStatus[q.id]='fail';
      ST.integrity=Math.max(0,ST.integrity-5);
      ST.points=Math.max(0,ST.points-15);
      ST.disciplineDebt=Math.min(200,(ST.disciplineDebt||0)+15);
      if(!ST.failByType)ST.failByType={body:0,mind:0,disc:0};
      ST.failByType[q.type]=(ST.failByType[q.type]||0)+1;
      if(q.type==='disc')ST.weeklyBoss.discFail=(ST.weeklyBoss.discFail||0)+1;
    }
  });

  const failed=t.nn.filter(q=>ST.questStatus[q.id]==='fail');
  const ok=failed.length===0;
  ST.sr7.push(ok?1:0);
  if(!ST.bilans)ST.bilans=[];const d=new Date();
  var _bqs=[];var _allPerf=true;if(t){[...t.nn,t.water,...(t.secs||[])].filter(Boolean).forEach(function(q){var _qs=ST.questStatus[q.id]||'skip';_bqs.push({n:q.name.substring(0,35),s:_qs});if(_qs!=='perfect'&&_qs!=='dayoff')_allPerf=false;});}
  ST.bilans.push({day:ST.day,date:`${d.getDate()}/${d.getMonth()+1}/${d.getFullYear()}`,energy,disc,resisted:ST.resistedToday,relapse,block,success:ok,perfect:ok&&_allPerf,quests:_bqs,morningMood:ST.todayMood||null});

  // ─── V2: Track day data for stats dashboard ───
  if(!ST.dayLog)ST.dayLog=[];
  const allQ2=[...t.nn,t.water,...(t.secs||[])].filter(Boolean);
  const perfCount=allQ2.filter(q=>ST.questStatus[q.id]==='perfect').length;
  const clearCount=allQ2.filter(q=>ST.questStatus[q.id]==='clear').length;
  const failCount2=allQ2.filter(q=>ST.questStatus[q.id]==='fail'||!ST.questStatus[q.id]).length;
  const bodyOk=t.nn.filter(q=>q.type==='body'&&(ST.questStatus[q.id]==='perfect'||ST.questStatus[q.id]==='clear'||ST.questStatus[q.id]==='dayoff')).length>0;
  const mindOk=t.nn.filter(q=>q.type==='mind'&&(ST.questStatus[q.id]==='perfect'||ST.questStatus[q.id]==='clear'||ST.questStatus[q.id]==='dayoff')).length>0;
  const discOk=t.nn.filter(q=>q.type==='disc'&&(ST.questStatus[q.id]==='perfect'||ST.questStatus[q.id]==='clear'||ST.questStatus[q.id]==='dayoff')).length>0;
  const dow=d.getDay();
  ST.dayLog.push({day:ST.day,date:`${d.getDate()}/${d.getMonth()+1}/${d.getFullYear()}`,dow,success:ok,perfect:perfCount>=allQ2.length&&perfCount>0,partial:ok&&perfCount<allQ2.length,energy,body:bodyOk,mind:mindOk,disc:discOk,xp:ST.xp,streak:ST.streak,morningMood:ST.todayMood||null});
  if(ST.dayLog.length>400)ST.dayLog=ST.dayLog.slice(-400);
  // ─── End V2 tracking ───
  if(energy>0){
    if(energy<=2)ST.fatigueScore=Math.max(1,ST.fatigueScore-1);
    else if(energy>=4)ST.fatigueScore=Math.min(4,ST.fatigueScore+1);
    // 3 stars = neutral, no change
  } else {
    // No bilan stars - +1 on success, -1 on fail
    if(ok)ST.fatigueScore=Math.min(4,(ST.fatigueScore||3)+1);
    else ST.fatigueScore=Math.max(1,(ST.fatigueScore||3)-1);
  }

  const rb=getRank().label;
  if(ok){
    ST.streak++;ST.bestStreak=Math.max(ST.bestStreak,ST.streak);ST.failStreak=0;
    // Exit min/red mode after 2 consecutive successes
    if(ST.streak>=2&&(ST.fatigueScore||3)<=1)ST.fatigueScore=2;
    // Reset rankDowngrade flag once integrity recovers above 60
    if(ST.integrity>=60)ST.rankDowngrade=false;
    // Integrity recovery: +7 if perfect day, +3 if just NN done
    const intRecov=allFullDone()?7:3;
    ST.integrity=Math.min(100,ST.integrity+intRecov);
    // Debt reduction: -15 if all quests done (perfect day), -8 if only NN done
    const debtReduc=allFullDone()?25:15;
    ST.disciplineDebt=Math.max(0,(ST.disciplineDebt||0)-debtReduc);
    if(getRank().label!==rb){SND.rankUp();flash('purple',800);toast('Rang supérieur - '+getRank().label+' !');}
    if(ST.resistedToday===false)ST.integrity=Math.max(0,ST.integrity-5);
    showDone();save();
  } else {
    ST.failStreak=(ST.failStreak||0)+1;const fs=Math.min(ST.failStreak,7);ST.failStreak=fs;
    if(fs>=3){const prev=ST.streak;ST.streak=0;if(prev>0)toast(`Série réinitialisée après ${prev} jours`);}
    else{ST.streak=Math.max(0,ST.streak-1);}
    if(ST.integrity<30&&!ST.rankDowngrade&&(ST.day-(ST.lastRankDowngradeDay||0))>=30){
      ST.rankDowngrade=true;ST.lastRankDowngradeDay=ST.day;
      const ri=RANKS.findIndex(r=>r.label===getRank().label);
      if(ri>0){ST.xp=Math.max(0,RANKS[ri-1].min);toast('Intégrité critique - rang rétrogradé !');}
    }
    ST.lockRewards=(ST.failStreak||0)>=3;
    if(ST.resistedToday===false)ST.integrity=Math.max(0,ST.integrity-5);
    // Sanction logic: any fail triggers sanction screen (after day 15)
    if(failed.length>=1){
      if(ST.day<15){
        // Before day 15: just debt, no screen
        ST.disciplineDebt=Math.min(200,(ST.disciplineDebt||0)+5*failed.length);
        toast(failed.length+' quête'+(failed.length>1?'s':'')+' ratée'+(failed.length>1?'s':'')+' - le système s\'en souviendra.');
        showDone();save();
      } else if(ST.sanctionPending){
        // Sanction already pending - extra debt
        ST.disciplineDebt=Math.min(200,(ST.disciplineDebt||0)+20);
        toast('Sanction déjà active - dette augmentée.');
        showDone();save();
      } else {
        buildSanction(failed);save();show('s-sanction');
      }
    } else {
      showDone();save();
    }
  }
}

function buildSanction(failed){
  const n=failed.length;
  // V3: Gradual sanction introduction
  // Day 1-14: NO sanctions, NO debt, normalisation only
  if(ST.day<=14){
    var normMsgs=[
      'Jour '+ST.day+' - tu apprends. Les faux pas font partie du processus.',
      'C\'est normal de rater au début. L\'important c\'est d\'être là demain.',
      'Le système ne te juge pas. Chaque jour est une nouvelle chance.',
      'Pas de pression. Tu construis quelque chose, ça prend du temps.',
    ];
    toast(pick(normMsgs));
    return; // no sanction screen, no debt, nothing
  }
  // Day 15-29: light sanctions (reduced multiplier)
  var sanctionScale=ST.day<30?0.5:1.0;
  SND.sanction();flash('red',800);vib([300,100,300,100,300]);

  let task='';let mult=1.5*sanctionScale;
  if(n>=3){
    mult=4.0*sanctionScale;
    const body=rnd(30,50);
    task=`${Math.round(body*mult)} pompes AVANT 10h demain.`;
  } else if(n>=2){
    mult=2.0*sanctionScale;
    const opts=[
      `${Math.round(rnd(25,45)*mult)} pompes avant 10h demain`,
      `${Math.round(rnd(20,40)*mult)} squats avant 10h demain`,
      `${Math.round(rnd(60,120)*mult)}s de planche avant 10h demain`,
    ];
    task=pick(opts);
  } else {
    const type=failed[0].type||'body';
    const pool=SP[type]||SP.body;
    let tmpl=pick(pool);
    const nv=type==='body'?Math.round(rnd(20,50)*mult):type==='mind'?Math.round(rnd(30,60)*mult):Math.round(rnd(15,30)*mult);
    task=tmpl.replace('{n}',nv).replace(/ *\(x\{m\}\)/g,'');
  }

  const ctxMsgs={
    1:ST.day<30?'1 quête non accomplie. Le système commence à réagir.':'1 quête obligatoire non accomplie.',
    2:ST.day<30?'2 quêtes non accomplies. Attention.':'2 quêtes non accomplies - sanction doublée.',
    3:'3 quêtes non accomplies - sanction maximale.'
  };
  // Show "Mon pourquoi" if user wrote one
  var whyZone=document.getElementById('s-why');
  if(whyZone){whyZone.style.display=ST.myWhy?'block':'none';if(ST.myWhy)whyZone.textContent='« '+ST.myWhy+' »';}
  ST.sanctionText=task;
  ST.sanctionCtx=ctxMsgs[n]||`${n} quêtes non accomplies.`;
  ST.sanctionMult=mult.toFixed(1);
  ST.sanctionPending=true;
  ST.totalSanctions=(ST.totalSanctions||0)+1;
  ST.disciplineDebt=Math.min(200,(ST.disciplineDebt||0)+Math.round(8*mult));
  // Init absence tracking - starts at 1 at the moment sanction fires
  if(!ST.sanctionStartedAt){ST.sanctionStartedAt=Date.now();ST.absenceDays=1;}
  // Engage SW lock
  swSanctionLock(true);
  _renderSanctionScreen();
}

// ── SW sanction lock ──────────────────────────────────────────────
function swSanctionLock(locked){
  if(!navigator.serviceWorker||!navigator.serviceWorker.controller)return;
  navigator.serviceWorker.controller.postMessage({type:locked?'SANCTION_LOCK':'SANCTION_CLEARED'});
}

// ── Sanction screen helpers ───────────────────────────────────────
function _updateAbsenceDays(){
  if(!ST.sanctionPending||!ST.sanctionStartedAt)return;
  // absenceDays = how many full 24h periods have elapsed since sanction fired
  const elapsed=Date.now()-ST.sanctionStartedAt;
  const fullDays=Math.floor(elapsed/(24*3600*1000));
  ST.absenceDays=1+fullDays; // starts at 1 immediately, +1 per full 24h
  save();
}

function _renderSanctionScreen(){
  const el=id=>document.getElementById(id);
  if(el('s-ctx'))el('s-ctx').textContent=ST.sanctionCtx||'';
  if(el('s-task'))el('s-task').textContent=ST.sanctionText||'';
  if(el('s-day-label'))el('s-day-label').textContent='J'+ST.day;
  // Return offer
  const absence=ST.absenceDays||0;
  const ro=el('s-return-offer');
  if(ro){
    if(absence>=2){
      const cost=Math.round((ST.points||0)*0.25*(1+(absence/100)));
      el('s-return-text').textContent=`Tu es absent depuis ${absence} jour${absence>1?'s':''}.`;
      const btnPay=el('btn-return-pay');
      if(btnPay)btnPay.textContent=`Oui - Payer ${cost} pts pour effacer les jours manqués et reprendre où tu en étais (les jours d'absence ne comptent pas)`;
      ro.style.display='';
    } else {
      ro.style.display='none';
    }
  }
}

function acceptSanction(){
  ST.xp=Math.max(0,ST.xp-15);
  ST.points=Math.max(0,ST.points-8);
  ST.sanctionPending=false;
  ST.sanctionConfirmedAt=Date.now();
  ST.sanctionsCompleted=(ST.sanctionsCompleted||0)+1;
  swSanctionLock(false);
  if(!ST.bilans)ST.bilans=[];
  const d=new Date();
  ST.bilans.push({day:ST.day,date:`${d.getDate()}/${d.getMonth()+1}/${d.getFullYear()}`,hour:d.getHours(),isSanction:true,sanctionTask:ST.sanctionText,sanctionMult:ST.sanctionMult});
  // Show return offer screen if absence >= 2 days
  const absence=ST.absenceDays||0;
  if(absence>=2){
    showReturnOffer();
  } else {
    ST.absenceDays=0;ST.sanctionStartedAt=null;ST.returnOfferShown=false;
    save();showDone();
  }
}

function showReturnOffer(){
  const absence=ST.absenceDays||0;
  const cost=Math.round((ST.points||0)*0.25*(1+(absence/100)));
  // Repurpose s-done screen with return offer content
  const brz=document.getElementById('boss-reward-zone');
  if(brz)brz.innerHTML='';
  document.getElementById('done-xp').textContent='';
  // Override done screen content temporarily
  const doneWrap=document.querySelector('#s-done .done-wrap');
  if(doneWrap){
    doneWrap.innerHTML=`
      <div style="font-size:48px;margin-bottom:1rem">&#128293;</div>
      <div style="font-size:17px;font-weight:700;color:#c0392b;margin-bottom:6px">Tu reviens après ${absence} jour${absence>1?'s':''} d'absence.</div>
      <div style="font-size:13px;color:#7a6e5a;margin-bottom:1.4rem;line-height:1.7">Le système a enregistré ton absence.<br/>Tu peux effacer ces jours en payant <strong>${cost} points boutique</strong>,<br/>ou les comptabiliser comme des jours d'échec.</div>
      <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:1rem">
        <button onclick="returnPay()" style="background:#2e7d32;border:none;border-radius:14px;color:#fff;font-size:14px;font-weight:700;padding:16px;cursor:pointer;line-height:1.5">
          ✓ Payer ${cost} pts - Effacer les ${absence} jour${absence>1?'s':''}.<br/><span style="font-size:11px;font-weight:500;opacity:.85">Les jours manqués ne comptent pas : stats, boss, série - tout reprend comme avant.</span>
        </button>
        <button onclick="returnSkip()" style="background:rgba(0,0,0,.06);border:1px solid #ddd;border-radius:14px;color:#5a4e3a;font-size:13px;font-weight:600;padding:16px;cursor:pointer;line-height:1.5">
          ✗ Non - Comptabiliser ${absence} jour${absence>1?'s':''} comme des échecs.<br/><span style="font-size:11px;font-weight:500;opacity:.75">Les quêtes de ces jours sont générées et marquées ratées. La série, les stats et le boss en tiennent compte.</span>
        </button>
      </div>`;
  }
  ST.returnOfferShown=true;save();
  show('s-done');
}

function returnPay(){
  const absence=ST.absenceDays||0;
  const cost=Math.round((ST.points||0)*0.25*(1+(absence/100)));
  ST.points=Math.max(0,(ST.points||0)-cost);
  // Absence days don't count - just advance ST.day silently, no stats, no boss, no fails
  ST.day+=absence;
  // Regenerate week plan if needed
  if(getWk()>ST.week){ST.week=getWk();ST.weekPlan=genWeek();ST.weeklyBoss={body:0,mind:0,discFail:0};ST.weekTruthDone=false;ST.lockRewards=false;ST._bossShownThisWeek=false;ST.weeklyPartialCount=0;}
  else{ST.weekPlan=genWeek();}
  ST.questStatus={};ST.dayDone=false;ST.reviewDone=false;ST.morningCheckDone=false;ST.todayMood=null;
  ST.absenceDays=0;ST.sanctionStartedAt=null;ST.returnOfferShown=false;
  // Restore s-done to normal
  _restoreDoneScreen();
  save();nav('s-main');SND.open();renderMain();
}

function returnSkip(){
  const absence=ST.absenceDays||0;
  // Simulate absence days as failed days
  for(let i=0;i<absence;i++){
    // Generate a week plan entry and fail all NN
    const fakeDay={nn:[{id:'nn0',type:'body'},{id:'nn1',type:'mind'},{id:'nn2',type:'disc'}],water:null,secs:[]};
    fakeDay.nn.forEach(q=>{
      if(!ST.failByType)ST.failByType={body:0,mind:0,disc:0};
      ST.failByType[q.type]=(ST.failByType[q.type]||0)+1;
      if(q.type==='disc')ST.weeklyBoss.discFail=(ST.weeklyBoss.discFail||0)+1;
      ST.integrity=Math.max(0,ST.integrity-5);
      ST.disciplineDebt=Math.min(200,(ST.disciplineDebt||0)+15);
    });
    ST.sr7.push(0);if(ST.sr7.length>7)ST.sr7=ST.sr7.slice(-7);
    const fd=new Date();fd.setDate(fd.getDate()-(absence-i));
    ST.dayLog.push({day:ST.day+i,date:`${fd.getDate()}/${fd.getMonth()+1}/${fd.getFullYear()}`,dow:(ST.day+i)%7,success:false,perfect:false,partial:false,energy:1,body:false,mind:false,disc:false,xp:ST.xp,streak:0,absent:true});
    if(ST.dayLog.length>400)ST.dayLog=ST.dayLog.slice(-400);
    ST.failStreak=(ST.failStreak||0)+1;
    ST.streak=0;
    ST.day++;
    if(getWk()>ST.week){ST.week=getWk();ST.weekPlan=genWeek();ST.weeklyBoss={body:0,mind:0,discFail:0};ST.weekTruthDone=false;ST.lockRewards=false;ST._bossShownThisWeek=false;ST.weeklyPartialCount=0;}
  }
  if(!ST.weekPlan||!ST.weekPlan.length)ST.weekPlan=genWeek();
  ST.questStatus={};ST.dayDone=false;ST.reviewDone=false;ST.morningCheckDone=false;ST.todayMood=null;
  ST.absenceDays=0;ST.sanctionStartedAt=null;ST.returnOfferShown=false;
  _restoreDoneScreen();
  save();nav('s-main');SND.open();renderMain();
}

function _restoreDoneScreen(){
  const doneWrap=document.querySelector('#s-done .done-wrap');
  if(doneWrap){
    doneWrap.innerHTML=`
      <div style="font-size:48px;margin-bottom:1rem">&#9876;</div>
      <div style="font-size:17px;font-weight:600;color:#2e7d32;margin-bottom:6px">Toutes les quêtes validées.</div>
      <div style="font-size:13px;color:#7a6e5a;margin-bottom:1.2rem;line-height:1.6">Le système enregistre ta progression.<br/>Repose-toi - tu l'as mérité.</div>
      <div class="done-box"><strong>Nouvelles quêtes disponibles demain à 10h.</strong><br/><span id="done-cd" style="font-size:12px;margin-top:4px;display:block"></span></div>
      <div style="font-size:12px;color:#8a7e6a;margin-top:.5rem" id="done-xp"></div>
      <div id="boss-reward-zone" style="margin-top:.5rem"></div>`;
  }
}

function advDay(){
  // Block advance if sanction pending and it's past 10h
  if(ST.sanctionPending&&nowH()>=10){
    return;
  }
  const t=getToday();
  if(t){
    // Auto-fail un-interacted NN quests, auto-skip water/secondaries
    var autoFailed=[];
    t.nn.forEach(function(q){
      if(!ST.questStatus[q.id]){
        ST.questStatus[q.id]='fail';
        autoFailed.push(q);
        if(!ST.failByType)ST.failByType={body:0,mind:0,disc:0};
        ST.failByType[q.type]=(ST.failByType[q.type]||0)+1;
        if(ST.day>14){
          ST.integrity=Math.max(0,ST.integrity-5);
          ST.disciplineDebt=Math.min(200,(ST.disciplineDebt||0)+15);
        }
        if(q.type==='disc')ST.weeklyBoss.discFail=(ST.weeklyBoss.discFail||0)+1;
      }
    });
    // Auto-skip water and secondaries
    if(t.water&&!ST.questStatus[t.water.id])ST.questStatus[t.water.id]='skip';
    (t.secs||[]).forEach(function(q){if(!ST.questStatus[q.id])ST.questStatus[q.id]='skip';});

    // If auto-fails happened and no review done, trigger sanction
    if(autoFailed.length>0&&!ST.reviewDone&&!ST.sanctionPending&&ST.day>=15){
      buildSanction(autoFailed);
      save();show('s-sanction');
      return; // Don't advance - sanction blocks
    }

    const hadFail=t.nn.some(q=>ST.questStatus[q.id]==='fail');
    ST.hadFailYesterday=hadFail;
    // Track NN fails per day for reconstruction mode
    var dayNNFails=t.nn.filter(q=>ST.questStatus[q.id]==='fail').length;
    if(!ST.recentNNFails)ST.recentNNFails=[];
    ST.recentNNFails.push(dayNNFails);
    if(ST.recentNNFails.length>7)ST.recentNNFails=ST.recentNNFails.slice(-7);
    if(!hadFail){
      if((ST.disciplineDebt||0)>0)ST.disciplineDebt=Math.max(0,(ST.disciplineDebt||0)-15);
      if((ST.fatigueScore||3)<3)ST.fatigueScore=Math.min(3,(ST.fatigueScore||3)+1);
      ST.integrity=Math.min(100,ST.integrity+2);
    } else {
      ST.failStreak=(ST.failStreak||0)+1;
      if(ST.failStreak>=3)ST.streak=0;
      else ST.streak=Math.max(0,ST.streak-1);
    }
  }
  ST.day++;
  adaptFromStats();
  // ── Reconstruction counter management ────────────────────────────
  if((ST.reconstructionDay||0)>=1&&(ST.reconstructionDay||0)<=4){
    ST.reconstructionDay++;
    if(ST.reconstructionDay>4){
      // Finished 4 days - reset, apply 3-day cooldown
      ST.reconstructionDay=0;
      ST.reconstructionCooldown=3;
    }
  } else {
    // Decrement cooldown
    if((ST.reconstructionCooldown||0)>0)ST.reconstructionCooldown--;
    // Check if trigger conditions met for next day
    if(_checkReconTrigger()){
      ST.reconstructionDay=1;
      ST.reconstructionCooldown=0;
    }
  }
  // Hard cap on debt - can never exceed 200
  ST.disciplineDebt=Math.min(200,ST.disciplineDebt||0);
  if(getWk()>ST.week){
    // Auto-collect ALL unclaimed boss rewards before reset
    var _wb=ST.weeklyBoss||{body:0,mind:0,discFail:0};
    var _bwk=ST.week||1;var _bNeedM=_bwk>=2?4:0;var _bNeedDisc=_bwk>=3;
    if((_wb.body||0)>=3&&(_bwk<2||(_wb.mind||0)>=_bNeedM)&&(!_bNeedDisc||(_wb.discFail||0)<=2)&&!ST._bossShownThisWeek){
      // Unclaimed boss from this week - auto-collect
      ST.unclaimedBoss=(ST.unclaimedBoss||0)+1;
      ST.xp+=40;ST.points+=20;ST.bossWins=(ST.bossWins||0)+1;
      var _bd=ST.disciplineDebt||0;if(_bd>=20)ST.disciplineDebt-=20;else if(_bd>0)ST.disciplineDebt=0;
      if(!ST.bossQuoteIdx)ST.bossQuoteIdx=0;ST.bossQuoteIdx=(ST.bossQuoteIdx+1)%BOSS_QUOTES.length;
      var _btr={1:'Tueur de Boss',4:'Chasseur Chevronné',8:"Élite de l'Ombre",12:'Légende'};
      if(_btr[ST.bossWins]){if(!ST.unlockedTitles)ST.unlockedTitles=[];if(!ST.unlockedTitles.includes(_btr[ST.bossWins]))ST.unlockedTitles.push(_btr[ST.bossWins]);}
    }
    ST.week=getWk();ST.weekPlan=genWeek();ST.weeklyBoss={body:0,mind:0,discFail:0};ST.weekTruthDone=false;ST.lockRewards=false;ST._bossShownThisWeek=false;ST.weeklyPartialCount=0;
  }
  ST.questStatus={};ST.dayDone=false;ST.reviewDone=false;ST.morningCheckDone=false;ST.todayMood=null;
  const qlnn=document.getElementById('ql-nn');if(qlnn)delete qlnn.dataset.simplified;
}

function renderIdentity(){
  const allUnlocked=[
    ...ID_T.filter(t=>t.ok(ST)).map(t=>t.name),
    ...(ST.unlockedTitles||[]),
  ];
  // Deduplicate
  const uniqueUnlocked=[...new Set(allUnlocked)];
  // Sort: equipped first, then automatic (by ID_T order), then boss, then shop
  const autoNames=ID_T.map(t=>t.name);
  const bossOrder=['Tueur de Boss','Chasseur Chevronné',"Élite de l'Ombre",'Légende'];
  uniqueUnlocked.sort((a,b)=>{
    const aAuto=autoNames.indexOf(a),bAuto=autoNames.indexOf(b);
    const aBoss=bossOrder.indexOf(a),bBoss=bossOrder.indexOf(b);
    // Auto titles first (in ID_T order)
    if(aAuto>=0&&bAuto>=0)return aAuto-bAuto;
    if(aAuto>=0)return -1;if(bAuto>=0)return 1;
    // Boss titles next
    if(aBoss>=0&&bBoss>=0)return aBoss-bBoss;
    if(aBoss>=0)return -1;if(bBoss>=0)return 1;
    return a.localeCompare(b);
  });
  const locked=ID_T.filter(t=>!t.ok(ST));
  const equipped=ST.equippedTitle||null;

  const unlockedHtml=uniqueUnlocked.length
    ?uniqueUnlocked.map(name=>{
      const isEq=equipped===name;
      const safeAttr=name.replace(/"/g,'&quot;');
      return`<div data-title="${safeAttr}" onclick="equipTitle(this.dataset.title)" style="cursor:pointer;touch-action:manipulation;display:flex;flex-direction:column;align-items:center;gap:6px;padding:14px 8px;border-radius:var(--r);background:${isEq?'var(--accent)':'var(--card)'};box-shadow:${isEq?'0 3px 14px rgba(184,97,42,.25)':'var(--shadow)'};transition:all .15s;border:1px solid ${isEq?'transparent':'rgba(0,0,0,.04)'};text-align:center">
        <span style="font-size:20px;pointer-events:none">${isEq?'⭐':'🏷️'}</span>
        <span style="font-size:12px;font-weight:700;color:${isEq?'#fff':'var(--ink)'};line-height:1.3;pointer-events:none">${name}</span>
        <span style="font-size:9px;font-weight:700;padding:3px 10px;border-radius:6px;background:${isEq?'rgba(255,255,255,.2)':'var(--bg2)'};color:${isEq?'rgba(255,255,255,.9)':'var(--ink3)'};pointer-events:none">${isEq?'Équipé ✓':'Équiper'}</span>
      </div>`;
    }).join('')
    :'<span style="font-size:11px;color:var(--ink3);grid-column:1/-1">Aucun titre encore - continue ta progression et bats des boss.</span>';

  document.getElementById('id-unlocked').innerHTML=unlockedHtml;
  document.getElementById('id-locked').innerHTML=locked.map(t=>`<div style="display:flex;justify-content:space-between;align-items:center;font-size:11px;padding:6px 0;border-bottom:1px solid #d4c9b0"><span class="badge locked">${t.name}</span><span style="color:#8a7e6a;font-size:10px;max-width:55%;text-align:right">${t.cond}</span></div>`).join('');
  document.getElementById('id-stats').innerHTML=
    `<div>Titre affiché : <strong style="color:#d4a054">${equipped?'"'+equipped+'"':'Aucun'}</strong></div>
     <div>Série : ${ST.streak} jours | Meilleure : ${ST.bestStreak}</div>
     <div>Body : ${ST.totalBody} | Mind : ${ST.totalMind} | Disc : ${ST.totalDisc}</div>
     <div>Boss vaincus : ${ST.bossWins||0}</div>`;
}

function equipTitle(name){
  const wasEquipped=ST.equippedTitle===name;
  ST.equippedTitle=wasEquipped?null:name;
  if(!wasEquipped)SND.perfect(); else SND.reveal();
  vib([60]);
  save();renderIdentity();
  const tt=document.getElementById('title-text');
  if(tt&&ST.equippedTitle)tt.textContent=ST.equippedTitle;
  else if(tt)tt.textContent=getRank().title;
  toast(ST.equippedTitle?`Titre équipé : "${ST.equippedTitle}"`:' Titre retiré');
}
function renderRewards(){
  document.getElementById('rw-pts').textContent=ST.points+' pts';
  const locked=ST.disciplineDebt>150;
  ST.lockRewards=locked;
  const owned=ST.unlockedTitles||[];
  const mk=(r,i,src)=>{const can=!locked&&ST.points>=r.cost;const isUtil=r.type==='util';const isReal=r.type==='real';const isSym=r.type==='sym';return`<div class="rc${locked?' locked-reward':''}"><div class="rt">${isUtil?'Utilitaire':isSym?'Symbolique':isReal?'🎁 Récompense réelle':'Perso'}</div><div class="rn">${r.name}</div><div class="rp">${r.cost} pts</div><button class="rb" ${can?'':'disabled'} onclick="buyRew(${i},'${src}')">${locked?'Verrouillé':isUtil?'Utiliser':isReal?'Utiliser':isSym?'Échanger':'Échanger'}</button></div>`;};
  document.getElementById('shop-lock-banner').innerHTML=(locked&&ST.day>=67)?`<div class="abox ad" style="margin-bottom:8px">&#128308; Boutique verrouillée : rembourse ta dette de discipline (${ST.disciplineDebt} pts).</div>`:''  ;
  document.getElementById('rw-util').innerHTML=UTIL_R.map((r,i)=>mk(r,i,'util')).join('');
  // Symbolic: filter out already-owned titles
  const availSym=SYM_R.map((r,i)=>({r,i})).filter(({r})=>{const title=r.name.replace('Titre : ','');return !owned.includes(title);});
  document.getElementById('rw-sym').innerHTML=availSym.length?availSym.map(({r,i})=>mk(r,i,'sym')).join(''):'<p style="font-size:11px;color:var(--ink3);grid-column:1/-1">Tous les titres symboliques débloqués ✓</p>';
  document.getElementById('rw-real').innerHTML=REAL_R.map((r,i)=>mk(r,i,'real')).join('');
  const c=ST.customR||[];
  const mkCustom=(r,i)=>{const can=!locked&&ST.points>=r.cost;return`<div class="rc${locked?' locked-reward':''}"><div class="rt">Perso</div><div class="rn">${r.name}</div><div class="rp">${r.cost} pts</div><div style="display:flex;gap:4px"><button class="rb" style="flex:1" ${can?'':'disabled'} onclick="buyRew(${i},'custom')">${locked?'Verrouillé':'Échanger'}</button><button style="background:none;border:1px solid var(--red);color:var(--red);border-radius:8px;padding:4px 8px;font-size:10px;cursor:pointer" onclick="delCustomRew(${i})">🗑</button></div></div>`;};
  document.getElementById('rw-custom').innerHTML=c.length?c.map((r,i)=>mkCustom(r,i)).join(''):'<p style="font-size:11px;color:var(--ink3);grid-column:1/-1">Aucune récompense perso.</p>';
}
function buyRew(i,src){
  if(ST.disciplineDebt>150||ST.lockRewards){toast('Boutique verrouillée.');return;}
  const r=src==='util'?UTIL_R[i]:src==='sym'?SYM_R[i]:src==='real'?REAL_R[i]:(ST.customR||[])[i];
  if(!r||ST.points<r.cost)return;
  if(!confirm('Utiliser "'+r.name+'" pour '+r.cost+' pts ?'))return;
  ST.points-=r.cost;
  SND.potion();vib([100,50,100]);flash('gold',600);
  // Activate item effects
  if(r.name==='Double XP - 1 jour'){ST.todayEvent='doubleXP';toast('🧪 Double XP activé !');save();renderRewards();renderMain();return;}
  if(r.name==='Protection streak (1×)'){if(!ST.streakShields)ST.streakShields=0;ST.streakShields++;toast('🛡️ Protection streak ! ('+ST.streakShields+' en stock)');save();renderRewards();return;}
  if(r.name==='Annuler sanction (1×)'){
    if(ST.sanctionPending){ST.sanctionPending=false;ST.sanctionText='';toast('⚡ Sanction annulée !');save();renderRewards();if(document.getElementById('s-sanction').classList.contains('active'))showDone();return;}
    else{if(!ST.sanctionCancels)ST.sanctionCancels=0;ST.sanctionCancels++;toast('⚡ Annulation en réserve ('+ST.sanctionCancels+')');save();renderRewards();return;}
  }
  if(r.name==='Journée off sans pénalité'){
    // Validate all quests for today as "day off"
    var t=getToday();
    if(t){
      var allQ=[].concat(t.nn,[t.water],t.secs||[]).filter(Boolean);
      allQ.forEach(function(q){ST.questStatus[q.id]='dayoff';});
      // Quick bilan
      ST.sr7.push(1);
      if(!ST.bilans)ST.bilans=[];var d=new Date();
      ST.bilans.push({day:ST.day,date:d.getDate()+'/'+(d.getMonth()+1)+'/'+d.getFullYear(),energy:3,disc:3,resisted:true,relapse:'',block:'Journée off (objet boutique)',success:true,hour:d.getHours()});
      if(!ST.dayLog)ST.dayLog=[];
      ST.dayLog.push({day:ST.day,date:d.getDate()+'/'+(d.getMonth()+1)+'/'+d.getFullYear(),dow:ST.day%7,success:true,perfect:true,partial:false,energy:3,body:true,mind:true,disc:true,xp:ST.xp,streak:ST.streak});
      if(ST.dayLog.length>400)ST.dayLog=ST.dayLog.slice(-400);
      ST.streak++;ST.bestStreak=Math.max(ST.bestStreak,ST.streak);ST.failStreak=0;
      ST.integrity=Math.min(100,ST.integrity+3);
      ST.disciplineDebt=Math.max(0,(ST.disciplineDebt||0)-15);
      ST.reviewDone=true;
      save();
      toast('🏖️ Journée off ! Toutes les quêtes validées.');
      renderMain();
    } else {
      toast('Aucune quête disponible.');ST.points+=r.cost; // refund
    }
    save();renderRewards();return;
  }
  if(r.type==='real'){
    if(!confirm('Let\'s go ! Tu peux t\'autoriser un extra '+r.name+' :)'))return ST.points+=r.cost;
    SND.rare();toast('🎉 '+r.name+' - tu l\'as mérité !');save();renderRewards();return;
  }
  if(r.type==='sym'&&r.name.startsWith('Titre : ')){
    const title=r.name.replace('Titre : ','');
    if(!ST.unlockedTitles)ST.unlockedTitles=[];
    if(!ST.unlockedTitles.includes(title))ST.unlockedTitles.push(title);
    toast('🏷️ Titre débloqué : "'+title+'" - va dans Identité !');
    save();renderRewards();return;
  } else if(r.type==='custom'){
    // Unlock as identity title + remove from shop
    SND.rare();
    if(!ST.unlockedTitles)ST.unlockedTitles=[];
    if(!ST.unlockedTitles.includes(r.name))ST.unlockedTitles.push(r.name);
    toast('🎁 Titre débloqué : "'+r.name+'" - équipe-le dans Identité !');
    if(ST.customR)ST.customR.splice(i,1);
  }
  save();renderRewards();
}
function addRew(){
  const name=document.getElementById('rw-name').value.trim();
  const cost=parseInt(document.getElementById('rw-cost').value);
  if(!name){toast('Donne un nom à ta récompense.');return;}
  if(!cost||cost<1400){toast('Minimum : 1 400 pts.');return;}
  if(cost>40000){toast('Maximum : 40 000 pts.');return;}
  if(!ST.customR)ST.customR=[];
  if(ST.customR.length>=10){toast('Maximum 10 récompenses perso.');return;}
  // Check for duplicate names
  var nameLower=name.toLowerCase();
  var existingNames=[].concat(
    SYM_R.map(function(r){return r.name.replace('Titre : ','').toLowerCase();}),
    REAL_R.map(function(r){return r.name.toLowerCase();}),
    ID_T.map(function(t){return t.name.toLowerCase();}),
    ['tueur de boss','chasseur chevronné',"élite de l'ombre",'légende'],
    (ST.unlockedTitles||[]).map(function(t){return t.toLowerCase();}),
    ST.customR.map(function(r){return r.name.toLowerCase();})
  );
  if(existingNames.includes(nameLower)){toast('Ce nom existe déjà !');return;}
  ST.customR.push({name,cost,type:'custom'});save();
  document.getElementById('rw-name').value='';document.getElementById('rw-cost').value='';
  renderRewards();toast('Récompense "'+name+'" ajoutée ('+cost+' pts)');
}
function delCustomRew(i){if(!ST.customR||!ST.customR[i])return;if(!confirm('Supprimer "'+ST.customR[i].name+'" ?'))return;ST.customR.splice(i,1);save();renderRewards();toast('Récompense supprimée.');}

