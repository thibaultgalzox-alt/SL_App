<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<meta name="theme-color" content="#F4F0EB"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-title" content="Solo Leveling"/>
<link rel="manifest" href="./manifest.json"/>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin><link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap" rel="stylesheet">
<title>Solo Leveling</title>
<style>
:root{
  --bg:#F4F0EB;--bg2:#EBE6DE;--card:#FFFFFF;
  --ink:#1A120B;--ink2:#5C4D3C;--ink3:#9A8B78;--ink4:#C4B8A8;
  --accent:#B8612A;--accent2:#D4903A;--accent-soft:rgba(184,97,42,.08);
  --green:#2B7A3B;--green-bg:#EBF5ED;
  --blue:#2663B0;--blue-bg:#E8F0FA;
  --red:#B82D2D;--red-bg:#FCEAEA;
  --gold:#C49030;--gold-bg:#FDF6EA;
  --shadow-sm:0 1px 3px rgba(26,18,11,.05);
  --shadow:0 2px 8px rgba(26,18,11,.06),0 0 1px rgba(26,18,11,.08);
  --shadow-md:0 4px 16px rgba(26,18,11,.07),0 1px 3px rgba(26,18,11,.05);
  --shadow-lg:0 12px 40px rgba(26,18,11,.1),0 2px 8px rgba(26,18,11,.06);
  --r:16px;--r-sm:12px;--r-lg:20px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{background:var(--bg);color:var(--ink);height:100%;background-image:radial-gradient(ellipse at top,rgba(184,97,42,.03) 0%,transparent 60%)}
body{font-family:'DM Sans',-apple-system,BlinkMacSystemFont,sans-serif;font-size:14px;max-width:430px;margin:0 auto;-webkit-font-smoothing:antialiased}
.app{padding:.75rem 1rem 5rem}
.screen{display:none;visibility:hidden}.screen.active{display:block;visibility:visible;min-height:100dvh;overflow-y:auto}

/* ─── HEADER ─── */
.hdr{text-align:center;padding:.75rem 0 .3rem}
.pill{display:inline-flex;font-size:10px;font-weight:700;padding:4px 16px;border-radius:20px;margin-bottom:6px;background:var(--accent);color:#fff;letter-spacing:.06em;box-shadow:0 2px 10px rgba(184,97,42,.3)}
.hdr h1{font-family:'Playfair Display',Georgia,serif;font-size:22px;font-weight:800;color:var(--ink);letter-spacing:-.02em}
.hdr p{font-size:12px;color:var(--ink3);margin-top:2px}
.xp-wrap{margin:10px 0 4px}
.xp-track{background:var(--bg2);border-radius:6px;height:8px;overflow:hidden;box-shadow:inset 0 1px 3px rgba(0,0,0,.08)}
.xp-fill{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:6px;transition:width .6s;box-shadow:0 0 8px rgba(184,97,42,.3)}
.xp-row{display:flex;justify-content:space-between;font-size:10px;color:var(--ink3);margin-bottom:3px;font-weight:500}

/* ─── STAT GRID ─── */
.sg{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin:.5rem 0}
.sc{background:var(--card);border-radius:var(--r-sm);padding:10px 4px;text-align:center;box-shadow:var(--shadow);border:1px solid rgba(0,0,0,.03)}
.sc.int-warn{background:var(--gold-bg);border-color:rgba(196,144,48,.25)}
.sc.int-crit{background:var(--red-bg);border-color:rgba(184,45,45,.25);animation:int-blink 1.8s ease-in-out infinite}
.sc.int-zero{background:#B82D2D;border-color:#8B0000;animation:int-blink-fast 0.6s ease-in-out infinite}
.sc.int-zero .v,.sc.int-zero .l{color:#fff}
@keyframes int-blink{0%,100%{background:var(--red-bg)}50%{background:#f9c9c9}}
@keyframes int-blink-fast{0%,100%{background:#B82D2D}50%{background:#e74c3c}}
.sc .v{font-size:17px;font-weight:700;color:var(--ink)}
.sc .l{font-size:8px;color:var(--ink3);margin-top:2px;text-transform:uppercase;letter-spacing:.05em;font-weight:600}

/* ─── SECTION LABELS ─── */
.slbl{font-size:11px;font-weight:800;color:var(--ink2);letter-spacing:.08em;text-transform:uppercase;margin:1.2rem 0 .5rem;display:flex;align-items:center;gap:8px}
.slbl::after{content:'';flex:1;height:1px;background:var(--bg2)}

/* ─── QUEST CARDS ─── */
.qlist{display:flex;flex-direction:column;gap:10px}
.qcard{background:var(--card);border-radius:var(--r);padding:14px 16px;overflow:hidden;transition:all .35s cubic-bezier(.4,0,.2,1);opacity:0;transform:translateY(10px);box-shadow:var(--shadow);border:1px solid rgba(0,0,0,.04)}
.qcard.visible{opacity:1;transform:translateY(0)}
.qcard.done{opacity:.3;transform:scale(.98)}
.qh{display:flex;align-items:center;gap:10px}
.qicon{width:40px;height:40px;border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;box-shadow:inset 0 -2px 4px rgba(0,0,0,.06)}
.qi-body{background:var(--green-bg)}.qi-mind{background:var(--blue-bg)}.qi-disc{background:var(--red-bg)}.qi-sec{background:var(--gold-bg)}
.qname{font-size:13px;font-weight:600;flex:1;line-height:1.4;color:var(--ink)}
.qxp{font-size:10px;font-weight:700;white-space:nowrap}
.xp-g{color:var(--green)}.xp-b{color:var(--blue)}.xp-o{color:var(--accent)}.xp-p{color:var(--accent)}
.qdesc{font-size:11px;color:var(--ink3);margin:6px 0 0 48px;line-height:1.5}
.qtag{display:inline-block;font-size:8px;font-weight:700;padding:3px 8px;border-radius:6px;margin:6px 0 0 48px;letter-spacing:.03em}
.tag-body{background:var(--green-bg);color:var(--green)}.tag-mind{background:var(--blue-bg);color:var(--blue)}
.tag-disc{background:var(--red-bg);color:var(--red)}.tag-water{background:var(--blue-bg);color:var(--blue)}
.tag-easy{background:var(--green-bg);color:var(--green)}.tag-med{background:var(--gold-bg);color:var(--accent)}.tag-hard{background:var(--red-bg);color:var(--red)}
.qactions{margin:10px 0 0 48px;display:flex;gap:6px;flex-wrap:wrap;align-items:center}
.qbtn{display:inline-flex;align-items:center;justify-content:center;border:none;background:var(--bg2);border-radius:var(--r-sm);padding:8px 16px;font-size:12px;color:var(--ink2);cursor:pointer;min-height:36px;font-weight:600;transition:all .15s;box-shadow:var(--shadow-sm);touch-action:manipulation;-webkit-tap-highlight-color:transparent}
.qbtn:active{transform:scale(.95);box-shadow:none}
.qbtn.perfect{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;box-shadow:0 3px 14px rgba(184,97,42,.3),inset 0 1px 0 rgba(255,255,255,.15)}
.qbtn.clear{background:var(--gold-bg);color:var(--gold)}
.qbtn.fail{background:var(--red-bg);color:var(--red)}
.qdone-lbl{font-size:10px;color:var(--green);font-weight:700}
.qclear-lbl{font-size:10px;color:var(--gold);font-weight:600}
.qfail-lbl{font-size:10px;color:var(--red);font-weight:600}

/* ─── ALERTS ─── */
.abox{border-radius:var(--r-sm);padding:10px 14px;font-size:11px;margin:.4rem 0;line-height:1.5;font-weight:500}
.aw{background:var(--gold-bg);color:#8B6914}
.ad{background:var(--red-bg);color:var(--red)}
.as{background:var(--green-bg);color:var(--green)}
.ai{background:var(--bg2);color:var(--ink2)}
.ae{background:var(--green-bg);color:var(--green)}

/* ─── BOSS ─── */
.boss-card{background:var(--card);border-radius:var(--r);padding:16px;margin:.5rem 0;box-shadow:var(--shadow-md);border-left:4px solid var(--accent);position:relative;overflow:hidden}
.boss-card::before{content:'';position:absolute;top:0;right:0;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(184,97,42,.03));pointer-events:none}
.boss-title{font-size:11px;font-weight:700;color:var(--accent);margin-bottom:8px;text-transform:uppercase;letter-spacing:.08em}
.boss-row{display:flex;justify-content:space-between;font-size:11px;color:var(--ink2);font-weight:500}
.boss-bar{height:6px;background:var(--bg2);border-radius:4px;overflow:hidden;margin:3px 0 6px}
.boss-fill{height:100%;border-radius:4px;transition:width .5s}
.boss-fill.body{background:linear-gradient(90deg,#4caf50,#66bb6a)}.boss-fill.mind{background:linear-gradient(90deg,#42a5f5,#64b5f6)}.boss-fill.disc{background:linear-gradient(90deg,var(--accent),var(--accent2))}

/* ─── DEBT ─── */
.debt-bar{background:var(--red-bg);border-radius:var(--r-sm);padding:12px 14px;margin:.4rem 0}
.debt-track{height:5px;background:#F0D5D5;border-radius:3px;overflow:hidden;margin-top:6px}
.debt-fill{height:100%;background:linear-gradient(90deg,var(--red),#E04040);border-radius:3px;transition:width .5s}

/* ─── BUTTONS ─── */
.dbar{background:var(--red-bg);border-radius:var(--r-sm);padding:10px 14px;margin:.5rem 0;font-size:12px;color:var(--red);font-weight:600;display:flex;justify-content:space-between;align-items:center}
.btn{border:none;background:var(--card);border-radius:var(--r-sm);padding:10px 18px;font-size:13px;color:var(--ink);cursor:pointer;transition:all .15s;font-weight:500;box-shadow:var(--shadow-sm);touch-action:manipulation;-webkit-tap-highlight-color:transparent}
.btn:active{transform:scale(.97);opacity:.85}
.btn.primary{background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;font-weight:600;box-shadow:0 3px 14px rgba(184,97,42,.25),inset 0 1px 0 rgba(255,255,255,.15)}
.btn.gold{background:var(--gold);color:#fff;font-weight:600;box-shadow:0 3px 14px rgba(196,144,48,.25)}
.btn.red{background:var(--red-bg);color:var(--red);font-weight:600}
.btn.full{width:100%}

/* ─── BOTTOM NAV ─── */
.bnav{display:flex;justify-content:space-around;padding:6px 8px env(safe-area-inset-bottom,8px);position:fixed;bottom:0;left:0;right:0;max-width:430px;margin:0 auto;background:rgba(244,240,235,.82);backdrop-filter:blur(24px) saturate(1.4);-webkit-backdrop-filter:blur(24px) saturate(1.4);z-index:50;box-shadow:0 -2px 12px rgba(0,0,0,.05)}
.ni{display:flex;flex-direction:column;align-items:center;gap:1px;cursor:pointer;padding:6px 14px;border-radius:12px;border:none;background:transparent;transition:all .2s}
.ni.active{background:linear-gradient(135deg,var(--accent),var(--accent2));box-shadow:0 3px 12px rgba(184,97,42,.3),inset 0 1px 0 rgba(255,255,255,.15)}
.ni-i{font-size:18px;transition:filter .2s}
.ni-l{font-size:9px;color:var(--ink3);font-weight:500}
.ni.active .ni-i{filter:brightness(0) invert(1)}
.ni.active .ni-l{color:#fff;font-weight:700}

/* ─── MISC ─── */
.wbar{background:var(--card);border-radius:var(--r-sm);padding:10px 14px;margin:.4rem 0;display:flex;justify-content:space-between;align-items:center;box-shadow:var(--shadow-sm)}
.wbl{font-size:12px;font-weight:600;color:var(--accent)}
.wbs{font-size:10px;color:var(--ink3);margin-top:1px}
.wbm{font-size:16px;font-weight:700;color:var(--accent)}
.toast{background:var(--card);border-radius:24px;padding:10px 22px;font-size:12px;font-weight:600;color:var(--ink);display:none;text-align:center;position:fixed;bottom:80px;left:50%;transform:translateX(-50%);white-space:nowrap;z-index:999;box-shadow:var(--shadow-lg)}
.toast.show{display:block;animation:fio 4.5s forwards}
@keyframes fio{0%{opacity:0;transform:translateX(-50%) translateY(8px)}8%{opacity:1;transform:translateX(-50%) translateY(0)}70%{opacity:1}100%{opacity:0}}
.flash{position:fixed;inset:0;z-index:9999;pointer-events:none;opacity:0;transition:opacity .2s}
.flash.red{background:rgba(184,45,45,.25)}.flash.gold{background:rgba(196,144,48,.2)}.flash.purple{background:rgba(184,97,42,.2)}.flash.orange{background:rgba(212,144,58,.2)}.flash.green{background:rgba(43,122,59,.2)}.flash.grey{background:rgba(100,90,80,.15)}.flash.show{opacity:1}
.narrative{font-size:12px;color:var(--ink3);font-style:italic;text-align:center;margin:.4rem 0;min-height:18px;transition:opacity .3s}
.done-wrap{text-align:center;padding:2.5rem 1.2rem}
.done-box{background:var(--green-bg);border-radius:var(--r);padding:16px;font-size:13px;color:var(--green);margin:1rem 0;box-shadow:0 4px 16px rgba(43,122,59,.1)}
.boss-reward{background:var(--gold-bg);border-radius:var(--r-sm);padding:10px 13px;margin:.5rem 0;font-size:12px;color:var(--gold)}
.min-banner{border-radius:var(--r-sm);padding:12px 16px;margin:.5rem 0;font-size:12px;text-align:center;font-weight:600}
.nb{background:var(--green-bg);border-radius:var(--r-sm);padding:10px 14px;margin:.4rem 0;font-size:11px;color:var(--green);display:flex;justify-content:space-between;align-items:center;gap:8px}

/* ─── ONBOARDING ─── */
.ob-bar{height:4px;background:var(--bg2);border-radius:4px;margin-bottom:8px;overflow:hidden}
.ob-fill{height:100%;background:var(--accent);border-radius:4px;transition:width .3s}
.ob-lbl{font-size:10px;color:var(--ink3);margin-bottom:14px;font-weight:500}
.ob-title{font-family:'Playfair Display',Georgia,serif;font-size:17px;font-weight:700;margin-bottom:4px;color:var(--ink)}
.ob-sub{font-size:12px;color:var(--ink3);margin-bottom:14px;line-height:1.5}
.ob-opts{display:flex;flex-direction:column;gap:8px;margin-bottom:1rem}
.ob-opt{background:var(--card);border:2px solid var(--bg2);border-radius:var(--r-sm);padding:13px 16px;font-size:12px;color:var(--ink);cursor:pointer;text-align:left;line-height:1.4;transition:all .15s;box-shadow:var(--shadow-sm)}
.ob-opt:active{transform:scale(.98)}
.ob-opt.sel{border-color:var(--accent);background:var(--accent);color:#fff;font-weight:600;box-shadow:0 3px 14px rgba(184,97,42,.3)}
.ob-chk{background:var(--card);border:2px solid var(--bg2);border-radius:var(--r-sm);padding:13px 16px;font-size:12px;color:var(--ink);cursor:pointer;display:flex;align-items:center;gap:10px;transition:all .15s;box-shadow:var(--shadow-sm)}
.ob-chk:active{transform:scale(.98)}
.ob-chk.sel{border-color:var(--accent);background:var(--accent);color:#fff;font-weight:600;box-shadow:0 3px 14px rgba(184,97,42,.3)}
.cb{width:18px;height:18px;flex-shrink:0;border-radius:5px;border:2px solid var(--ink4);display:flex;align-items:center;justify-content:center;font-size:11px;color:transparent;background:var(--card);transition:all .12s}
.ob-chk.sel .cb{background:#fff;border-color:#fff;color:var(--accent)}
.ob-nav{display:flex;gap:7px;margin-top:.5rem}

/* ─── REVIEW ─── */
.rv-card{background:var(--card);border-radius:var(--r);padding:16px;margin:.6rem 0;box-shadow:var(--shadow)}
.rv-q{font-size:12px;font-weight:600;margin-bottom:8px;color:var(--ink)}
.stars{display:flex;gap:6px;margin-bottom:12px}
.star{width:30px;height:30px;border-radius:8px;border:none;background:var(--bg2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:15px;color:var(--ink4);transition:all .12s;box-shadow:var(--shadow-sm)}
.star.sel{background:var(--gold-bg);color:var(--gold);box-shadow:0 2px 8px rgba(196,144,48,.2)}
.rv-inp{width:100%;font-size:12px;padding:10px 12px;border-radius:var(--r-sm);border:none;background:var(--bg2);resize:none;margin-bottom:10px;color:var(--ink);font-family:inherit}
.modal-bg{min-height:220px;background:rgba(26,18,11,.8);border-radius:var(--r);display:flex;align-items:center;justify-content:center;padding:1rem;margin:.6rem 0}
.modal{background:var(--card);border-radius:var(--r);padding:1.2rem;width:100%;box-shadow:var(--shadow-lg)}
.sbox{background:var(--red-bg);border-radius:var(--r-sm);padding:10px 12px;margin-bottom:10px;font-size:12px;font-weight:600;color:var(--red)}

/* ─── SHOP ─── */
.rg{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin:.4rem 0}
.rc{background:var(--card);border-radius:var(--r);padding:14px;box-shadow:var(--shadow);border:1px solid rgba(0,0,0,.03)}
.rc.locked-reward{opacity:.4;filter:grayscale(.5)}
.rt{font-size:8px;font-weight:700;margin-bottom:4px;color:var(--ink4);text-transform:uppercase;letter-spacing:.06em}
.rn{font-size:11px;margin-bottom:8px;line-height:1.4;color:var(--ink);font-weight:500}
.rp{font-size:13px;font-weight:700;color:var(--accent);margin-bottom:8px}
.rb{width:100%;border:none;background:linear-gradient(135deg,var(--accent),var(--accent2));color:#fff;border-radius:8px;padding:8px;font-size:10px;cursor:pointer;font-weight:700;box-shadow:0 2px 8px rgba(184,97,42,.2),inset 0 1px 0 rgba(255,255,255,.12);transition:all .12s}
.rb:active{transform:scale(.96)}
.rb:disabled{opacity:.25;cursor:not-allowed;background:var(--bg2);color:var(--ink3);box-shadow:none}
.rs{font-size:10px;font-weight:700;color:var(--ink3);text-transform:uppercase;letter-spacing:.08em;margin:1rem 0 .4rem}
.badge{font-size:10px;font-weight:700;padding:4px 10px;border-radius:20px;background:var(--accent);color:#fff;display:inline-block}
.badge.locked{background:var(--bg2);color:var(--ink3)}
.sig-canvas{width:100%;height:120px;border:2px solid var(--bg2);border-radius:var(--r-sm);background:var(--card);touch-action:none;cursor:crosshair}
.sig-label{font-size:11px;color:var(--ink3);line-height:1.5;margin-bottom:8px;text-align:center;font-style:italic}
#bilan-btn{max-width:100%;white-space:normal!important;line-height:1.3;font-size:12px;word-break:break-word}
.truth-card{background:var(--card);border-radius:var(--r);padding:14px;margin:.6rem 0;box-shadow:var(--shadow)}
.truth-opt{background:var(--bg2);border:none;border-radius:8px;padding:7px 13px;font-size:12px;color:var(--ink2);cursor:pointer;display:inline-block;margin:3px;transition:all .12s}
.truth-opt.sel{background:var(--accent);color:#fff}

/* ─── V2 STATS ─── */
.st-tabs{display:flex;gap:0;margin:0 -1rem;padding:0 1rem;position:sticky;top:0;z-index:5;background:rgba(246,242,237,.92);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px)}
.st-tab{flex:1;padding:13px 6px;background:transparent;border:none;border-bottom:3px solid transparent;color:var(--ink4);font-size:11px;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s}
.st-tab.active{color:var(--accent);border-bottom-color:var(--accent)}
.st-pane{display:none}.st-pane.active{display:block}
.st-section-lbl{font-size:10px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--ink2);margin:1.1rem 0 .5rem}
.st-card{background:var(--card);border-radius:var(--r);padding:14px;margin-bottom:10px;box-shadow:var(--shadow);border:1px solid rgba(0,0,0,.03)}
.st-card-accent{background:linear-gradient(135deg,var(--gold-bg),#F8F0E2);border-radius:var(--r);padding:14px;margin-bottom:10px;box-shadow:var(--shadow)}
.st-row{display:flex;gap:8px;margin-bottom:8px}
.st-metric{flex:1;background:var(--card);border-radius:var(--r-sm);padding:10px;text-align:center;box-shadow:var(--shadow-sm)}
.st-metric .mv{font-size:17px;font-weight:700;color:var(--ink)}
.st-metric .ml{font-size:8px;color:var(--ink4);margin-top:2px;text-transform:uppercase;letter-spacing:.06em;font-weight:600}
.st-flow-box{flex:1;background:var(--card);border-radius:var(--r-sm);padding:10px 12px;box-shadow:var(--shadow-sm)}
.st-flow-lbl{font-size:10px;font-weight:600;margin-bottom:3px}
.st-flow-track{height:5px;background:var(--bg2);border-radius:3px;overflow:hidden;position:relative;margin-bottom:3px}
.st-flow-marker{position:absolute;height:100%;border-radius:3px}
.st-flow-zone{font-size:8px;font-weight:600}
.st-insight{font-size:12px;color:var(--ink);line-height:1.6;margin-bottom:7px;padding:8px 12px;border-radius:var(--r-sm);background:var(--card);box-shadow:var(--shadow-sm)}
.st-heatmap-wrap{overflow-x:auto;padding:4px 0;-webkit-overflow-scrolling:touch}
.st-legend{display:flex;gap:8px;margin-top:5px}
.st-legend-item{display:flex;align-items:center;gap:3px;font-size:8px;color:var(--ink3)}
.st-legend-dot{width:8px;height:8px;border-radius:2px}
.st-sparkline-labels{display:flex;justify-content:space-between;font-size:7px;color:var(--ink3);margin-top:2px}
.st-capsule{display:grid;grid-template-columns:1fr auto 1fr;gap:6px;align-items:center;margin:.6rem 0}
.st-capsule-val{text-align:center;font-size:15px;font-weight:700}
.st-capsule-arrow{font-size:10px;color:var(--accent2)}
.st-mood-bar-wrap{height:50px;background:var(--bg2);border-radius:6px;overflow:hidden;display:flex;align-items:flex-end}
.st-mood-bar{width:100%;border-radius:6px 6px 0 0;transition:height .8s ease}
.st-phase-row{background:var(--card);border-radius:var(--r-sm);padding:10px 12px;margin-bottom:6px;position:relative;overflow:hidden;box-shadow:var(--shadow-sm)}
.st-phase-row::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px}
.st-phase-track{height:4px;background:var(--bg2);border-radius:2px;overflow:hidden;margin-top:5px}
.st-phase-fill{height:100%;border-radius:2px;transition:width .8s ease}
.st-bilan-mini{background:var(--card);border-radius:var(--r-sm);padding:10px 12px;margin-bottom:6px;box-shadow:var(--shadow-sm)}
.star-small{font-size:12px;color:var(--gold)}
.star-small.off{color:var(--bg2)}
.bilan-card{background:var(--card);border-radius:var(--r-sm);padding:10px 12px;margin-bottom:7px;box-shadow:var(--shadow-sm)}
.bilan-date{font-size:10px;font-weight:600;color:var(--ink3);margin-bottom:4px}
.bilan-row{display:flex;justify-content:space-between;font-size:11px;color:var(--ink2);margin-bottom:2px}
.bilan-note{font-size:11px;color:var(--ink3);margin-top:4px;font-style:italic;line-height:1.4}
.stat-big{display:grid;grid-template-columns:repeat(2,1fr);gap:7px;margin-bottom:.5rem}

</style>
</head>
<body>
<div class="app">
<div class="flash" id="flash"></div>

<div class="screen active" id="s-ob">
  <div class="hdr"><div class="pill">Initialisation du système</div><h1>Solo Leveling</h1><p>Réponds honnêtement - le programme s'adapte à ton niveau réel.</p></div>
  <div class="ob-bar"><div class="ob-fill" id="ob-fill" style="width:0%"></div></div>
  <div class="ob-lbl" id="ob-lbl">Question 1 / 15</div>
  <div id="ob-body"></div>
</div>

<div class="screen" id="s-welcome" style="position:fixed;inset:0;z-index:90;background:#1A2740">
  <div style="min-height:100vh;min-height:100dvh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem 1.5rem;text-align:center;background:#1A2740">
    <div style="font-size:52px;margin-bottom:1.5rem;animation:pulse-welcome 3s ease-in-out infinite">🌙</div>
    <div style="font-size:10px;font-weight:700;letter-spacing:.2em;color:#6B9FD4;text-transform:uppercase;margin-bottom:.8rem">Solo Leveling</div>
    <h1 style="font-family:'Playfair Display',Georgia,serif;font-size:24px;font-weight:800;color:#E8EDF3;line-height:1.3;margin-bottom:1.5rem">Repose-toi.</h1>
    <p style="font-size:13px;color:#8BA4BF;line-height:1.8;max-width:280px;margin-bottom:2rem">Tes quêtes seront disponibles<br/>demain à <strong style="color:#9EC5E8">10h00</strong>.</p>
    <div style="font-size:10px;color:#6B8FAD;margin-bottom:8px;letter-spacing:.08em;text-transform:uppercase;font-weight:600">Ouverture dans</div>
    <div id="welcome-cd" style="font-size:40px;font-weight:700;color:#E8EDF3;font-variant-numeric:tabular-nums;margin-bottom:2rem;letter-spacing:.02em">--h--</div>
  </div>
  <style>
  @keyframes pulse-welcome{0%,100%{opacity:.5;transform:scale(1)}50%{opacity:1;transform:scale(1.06)}}
  </style>
</div>

<div class="screen" id="s-main">
  <div class="hdr">
    <div class="pill" id="rank-pill">Rang E</div>
    <h1 id="title-text">Chasseur débutant</h1>
    <div class="xp-wrap">
      <div class="xp-row"><span id="xp-cur">0 XP</span><span id="xp-nxt">540 XP</span></div>
      <div class="xp-track"><div class="xp-fill" id="xp-fill" style="width:0%"></div></div>
    </div>
  </div>
  <div class="sg">
    <div class="sc"><div class="v" id="s-day">1</div><div class="l">Jour</div></div>
    <div class="sc"><div class="v" id="s-week">1</div><div class="l">Semaine</div></div>
    <div class="sc"><div class="v" id="s-streak">0</div><div class="l">Série</div></div>
    <div class="sc" id="sc-int"><div class="v" id="s-int">—</div><div class="l">Intégrité</div></div>
  </div>
  <div id="alert-zone"></div>
  <div id="nb-zone"></div>
  <div style="display:flex;gap:6px;margin:.3rem 0;align-items:stretch">
    <div class="dbar" style="flex:1;margin:0;font-size:12px;font-weight:600;padding:6px 10px;display:flex;align-items:center;justify-content:center;gap:6px"><span style="font-size:16px">⏱</span><span id="dl-label">8h - 22h</span></div>
    <div id="state-badge" style="flex:1;border-radius:8px;padding:6px 10px;font-size:10px;font-weight:600;display:flex;align-items:center;justify-content:center;text-align:center;background:var(--card);border:1px solid rgba(0,0,0,.06);color:var(--ink2)"></div>
  </div>
  <div style="position:relative" id="boss-checkin-wrap">
    <div id="boss-zone"></div>
    <div id="morning-checkin-zone" style="position:absolute;inset:0;z-index:2"></div>
  </div>
  <div class="narrative" id="narrative-text" style="font-size:12px;margin:.2rem 0"></div>
  <div id="projection-zone" style="font-size:10px;color:#8a7e6a;text-align:center;margin:.2rem 0"></div>
  <div id="progression-card"></div>
  <div class="slbl">Non-négociables <span id="nn-count" style="margin-left:4px;font-weight:400;text-transform:none;letter-spacing:0">0/3</span></div>
  <div class="qlist" id="ql-nn"></div>
  <div class="slbl">Hydratation</div>
  <div class="qlist" id="ql-water"></div>
  <div class="slbl">Quêtes secondaires</div>
  <div class="qlist" id="ql-sec"></div>
  <div style="display:flex;gap:7px;margin-top:.8rem">
    <button class="btn" onclick="openReview()" style="flex:1" id="bilan-btn">Bilan soir</button>
    <button class="btn gold" onclick="nav('s-rewards')" style="flex:1">Boutique</button>
  </div>
  <div class="bnav">
    <button class="ni active" onclick="nav('s-main',this)"><span class="ni-i">📋</span><span class="ni-l">Quêtes</span></button>
    <button class="ni" onclick="nav('s-identity',this)"><span class="ni-i">&#11088;</span><span class="ni-l">Identité</span></button>
    <button class="ni" onclick="nav('s-rewards',this)"><span class="ni-i">&#127942;</span><span class="ni-l">Boutique</span></button>
    <button class="ni" onclick="nav('s-stats',this)"><span class="ni-i">&#128200;</span><span class="ni-l">Stats</span></button>
  </div>
</div>

<div class="screen" id="s-done">
  <div class="hdr"><div class="pill" style="background:#e8f5e9;color:#2e7d32">Journée accomplie</div><h1>Mission terminée</h1></div>
  <div class="done-wrap">
    <div style="font-size:48px;margin-bottom:1rem">&#9876;</div>
    <div style="font-size:17px;font-weight:600;color:#2e7d32;margin-bottom:6px">Toutes les quêtes validées.</div>
    <div style="font-size:13px;color:#7a6e5a;margin-bottom:1.2rem;line-height:1.6">Le système enregistre ta progression.<br/>Repose-toi - tu l'as mérité.</div>
    <div class="done-box"><strong>Nouvelles quêtes disponibles demain à 10h.</strong><br/><span id="done-cd" style="font-size:12px;margin-top:4px;display:block"></span></div>
    <div style="font-size:12px;color:#8a7e6a;margin-top:.5rem" id="done-xp"></div>
    <div id="boss-reward-zone" style="margin-top:.5rem"></div>
  </div>
  <div class="bnav">
    <button class="ni" onclick="nav('s-main',this)"><span class="ni-i">📋</span><span class="ni-l">Quêtes</span></button>
    <button class="ni" onclick="nav('s-identity',this)"><span class="ni-i">&#11088;</span><span class="ni-l">Identité</span></button>
    <button class="ni" onclick="nav('s-rewards',this)"><span class="ni-i">&#127942;</span><span class="ni-l">Boutique</span></button>
    <button class="ni" onclick="nav('s-stats',this)"><span class="ni-i">&#128200;</span><span class="ni-l">Stats</span></button>
  </div>
</div>


<div class="screen" id="s-boss-victory">
  <div style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem 1.5rem;text-align:center;background:linear-gradient(180deg,#f5f0e8 0%,#e8ddd0 100%)">
    <div style="margin-bottom:1rem;position:relative">
      <svg viewBox="0 0 120 120" width="120" height="120" style="filter:drop-shadow(0 0 20px rgba(253,203,110,.4))">
        <defs>
          <linearGradient id="trophy-g" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#c0713a"/><stop offset="100%" stop-color="#e17055"/></linearGradient>
          <linearGradient id="trophy-shine" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#fff" stop-opacity=".4"/><stop offset="100%" stop-color="#fff" stop-opacity="0"/></linearGradient>
        </defs>
        <g transform="translate(60,60)">
          <animateTransform attributeName="transform" type="translate" values="60,60;60,55;60,60" dur="2s" repeatCount="indefinite" additive="replace"/>
          <!-- Cup -->
          <path d="M-25,-15 L-20,20 Q0,35 20,20 L25,-15 Z" fill="url(#trophy-g)" stroke="#e17055" stroke-width="1.5"/>
          <path d="M-25,-15 L-20,5 Q0,12 20,5 L25,-15 Z" fill="url(#trophy-shine)"/>
          <!-- Handles -->
          <path d="M-25,-10 Q-40,-5 -35,10 Q-30,20 -20,18" fill="none" stroke="#c0713a" stroke-width="3" stroke-linecap="round"/>
          <path d="M25,-10 Q40,-5 35,10 Q30,20 20,18" fill="none" stroke="#c0713a" stroke-width="3" stroke-linecap="round"/>
          <!-- Base -->
          <rect x="-8" y="20" width="16" height="8" rx="2" fill="#e17055"/>
          <rect x="-15" y="28" width="30" height="5" rx="2" fill="#c0713a"/>
          <!-- Star -->
          <polygon points="0,-8 2,-2 8,-2 3,2 5,8 0,4 -5,8 -3,2 -8,-2 -2,-2" fill="#fff" opacity=".7">
            <animate attributeName="opacity" values=".4;.9;.4" dur="1.5s" repeatCount="indefinite"/>
          </polygon>
        </g>
        <!-- Sparkles -->
        <circle cx="20" cy="25" r="2" fill="#c0713a"><animate attributeName="opacity" values="0;1;0" dur="1.2s" begin="0s" repeatCount="indefinite"/></circle>
        <circle cx="100" cy="30" r="1.5" fill="#fff"><animate attributeName="opacity" values="0;1;0" dur="1.2s" begin=".4s" repeatCount="indefinite"/></circle>
        <circle cx="15" cy="70" r="1.5" fill="#c0713a"><animate attributeName="opacity" values="0;1;0" dur="1.2s" begin=".8s" repeatCount="indefinite"/></circle>
        <circle cx="105" cy="75" r="2" fill="#e17055"><animate attributeName="opacity" values="0;1;0" dur="1.2s" begin=".2s" repeatCount="indefinite"/></circle>
      </svg>
    </div>
    <div style="font-size:11px;font-weight:700;letter-spacing:.2em;color:#d4a054;text-transform:uppercase;margin-bottom:.6rem">Boss hebdomadaire</div>
    <h1 style="font-size:24px;font-weight:800;color:#3a2e22;margin-bottom:1.2rem">Vaincu !</h1>
    <div id="boss-v-rewards" style="background:#fff;border:1px solid #c0713a;border-radius:12px;padding:14px;margin-bottom:1rem;width:100%;max-width:300px"></div>
    <div id="boss-v-quote" style="background:#f5efe6;border:1px solid #c0713a44;border-radius:12px;padding:16px;margin-bottom:1.5rem;font-size:13px;color:#d4a054;font-style:italic;line-height:1.6;max-width:300px"></div>
    <button class="btn primary full" style="max-width:260px" onclick="closeBossVictory()">Continuer</button>
  </div>
</div>


<div class="screen" id="s-rankup">
  <div style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem 1.5rem;text-align:center;background:linear-gradient(180deg,#f5f0e8 0%,#e8ddd0 100%)">
    <svg viewBox="0 0 100 100" width="100" height="100" style="margin-bottom:1rem;filter:drop-shadow(0 0 24px rgba(108,92,231,.5))">
      <polygon points="50,5 61,35 95,35 68,55 78,90 50,70 22,90 32,55 5,35 39,35" fill="#c0713a" stroke="#d4a054" stroke-width="1.5">
        <animate attributeName="opacity" values=".6;1;.6" dur="2s" repeatCount="indefinite"/>
        <animateTransform attributeName="transform" type="rotate" from="0 50 50" to="360 50 50" dur="20s" repeatCount="indefinite"/>
      </polygon>
    </svg>
    <div style="font-size:11px;font-weight:700;letter-spacing:.2em;color:#d4a054;text-transform:uppercase;margin-bottom:.5rem">Promotion</div>
    <h1 id="rankup-label" style="font-size:28px;font-weight:800;color:#3a2e22;margin-bottom:.3rem"></h1>
    <div id="rankup-title" style="font-size:14px;color:#d4a054;margin-bottom:1.5rem;font-style:italic"></div>
    <button class="btn primary" onclick="closeRankUp()" style="min-width:200px">Continuer</button>
  </div>
</div>

<div class="screen" id="s-title-earned">
  <div style="min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem 1.5rem;text-align:center;background:linear-gradient(180deg,#f5f0e8 0%,#fff7ed 100%)">
    <div style="font-size:72px;margin-bottom:1rem;animation:boss-pulse 1.5s ease-in-out infinite">⭐</div>
    <div style="font-size:11px;font-weight:700;letter-spacing:.2em;color:#d4a054;text-transform:uppercase;margin-bottom:.6rem">Titre débloqué</div>
    <h1 id="title-earned-name" style="font-size:24px;font-weight:800;color:#d4a054;margin-bottom:.5rem">"Survivor"</h1>
    <div id="title-earned-cond" style="font-size:12px;color:#7a6e5a;margin-bottom:1.5rem">14 jours de série</div>
    <button class="btn gold full" style="max-width:260px" onclick="show(ST.dayDone?'s-done':'s-main');renderMain();">Continuer</button>
  </div>
</div>

<div class="screen" id="s-review">
  <div class="hdr"><div class="pill">Bilan fin de journée</div><h1>Débrief</h1></div>
  <div class="rv-card">
    <div id="rv-morning-mood" style="display:none;margin-bottom:10px;padding:8px 12px;background:var(--bg2);border-radius:var(--r-sm);font-size:12px;color:var(--ink2)"></div>
    <div class="rv-q">Niveau d'énergie aujourd'hui</div>
    <div class="stars" id="st-energy"></div>
    <div class="rv-q">Niveau de discipline ressenti</div>
    <div class="stars" id="st-disc"></div>
    <div class="rv-q">Résistance aux tentations ?</div>
    <div style="display:flex;gap:7px;margin-bottom:10px">
      <button class="btn" id="r-yes" onclick="setResist(true)" style="flex:1">Oui</button>
      <button class="btn" id="r-no" onclick="setResist(false)" style="flex:1">Non - rechute</button>
    </div>
    <div id="relapse-z" style="display:none">
      <div class="rv-q">Contexte rechute</div>
      <textarea class="rv-inp" id="relapse-txt" rows="2" placeholder="Heure, émotion, situation..."></textarea>
    </div>
    <div class="rv-q">Qu'est-ce qui a bloqué ? (optionnel)</div>
    <textarea class="rv-inp" id="block-txt" rows="2" placeholder="Pour améliorer demain..."></textarea>
    <button class="btn primary full" onclick="submitReview()">Valider le bilan</button>
  </div>
  <div id="truth-zone"></div>
  <button class="btn full" style="margin-top:.5rem" onclick="nav('s-main')">Retour sans valider</button>
</div>

<div class="screen" id="s-sanction" style="position:fixed;inset:0;z-index:100;overflow-y:auto;background:#000;padding:0">
  <style>
  @keyframes shake{0%,100%{transform:translateX(0)}10%,30%,50%,70%,90%{transform:translateX(-6px)}20%,40%,60%,80%{transform:translateX(6px)}}
  @keyframes sanction-bg{0%,100%{background-color:#CC0000}12%{background-color:#FF0000}25%{background-color:#990000}40%{background-color:#DD0000}55%{background-color:#880000}70%{background-color:#EE0000}85%{background-color:#AA0000}}
  @keyframes pulse-border{0%,100%{border-color:rgba(255,255,255,.15);box-shadow:0 0 30px rgba(255,0,0,.3)}50%{border-color:rgba(255,255,255,.4);box-shadow:0 0 60px rgba(255,0,0,.5),0 0 120px rgba(255,0,0,.2)}}
  @keyframes icon-glow{0%,100%{filter:drop-shadow(0 0 15px rgba(255,200,0,.5)) drop-shadow(0 0 40px rgba(255,0,0,.3))}50%{filter:drop-shadow(0 0 30px rgba(255,200,0,.9)) drop-shadow(0 0 80px rgba(255,0,0,.6))}}
  @keyframes flicker{0%,93%,95%,97%,100%{opacity:1}93.5%{opacity:.3}94.5%{opacity:.9}96%{opacity:.5}}
  .sanction-wrap{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;min-height:100dvh;padding:2.5rem 1.5rem 3rem;animation:sanction-bg 3s ease-in-out infinite;position:relative}
  .sanction-wrap::after{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,.06) 3px,rgba(0,0,0,.06) 6px);pointer-events:none;animation:flicker 10s linear infinite}
  .sanction-icon{font-size:80px;margin-bottom:1rem;animation:shake .8s ease-in-out infinite,icon-glow 2s ease-in-out infinite;position:relative;z-index:1}
  .sanction-title{font-family:'Playfair Display',Georgia,serif;font-size:30px;font-weight:900;color:#fff;text-align:center;text-transform:uppercase;letter-spacing:.2em;margin-bottom:.4rem;text-shadow:0 0 20px rgba(255,255,255,.5),0 0 60px rgba(255,0,0,.6),0 2px 4px rgba(0,0,0,.5);position:relative;z-index:1}
  .sanction-sub{font-size:11px;color:rgba(255,255,255,.75);text-align:center;margin-bottom:2rem;letter-spacing:.12em;font-weight:700;text-transform:uppercase;position:relative;z-index:1;text-shadow:0 1px 3px rgba(0,0,0,.4)}
  .sanction-ctx{font-size:13px;color:rgba(255,255,255,.9);text-align:center;margin-bottom:1.2rem;line-height:1.6;position:relative;z-index:1;font-weight:500;text-shadow:0 1px 2px rgba(0,0,0,.3)}
  .sanction-box{background:rgba(0,0,0,.3);border:2px solid rgba(255,255,255,.2);border-radius:16px;padding:22px;margin-bottom:1.5rem;width:100%;animation:pulse-border 2.5s ease-in-out infinite;position:relative;z-index:1;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px)}
  .sanction-task{font-size:18px;font-weight:800;color:#fff;line-height:1.6;text-align:center;text-shadow:0 1px 3px rgba(0,0,0,.3)}
  .sanction-mult{font-size:12px;color:rgba(255,220,220,.7);text-align:center;margin-top:8px;font-weight:600}
  .sanction-consequences{background:rgba(0,0,0,.25);border:1px solid rgba(255,255,255,.12);border-radius:14px;padding:14px 18px;margin-bottom:2rem;font-size:11px;color:rgba(255,220,220,.85);line-height:2;position:relative;z-index:1;backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)}
  .btn-sanction{width:100%;background:rgba(0,0,0,.35);border:2px solid rgba(255,255,255,.25);border-radius:14px;color:rgba(255,255,255,.9);font-size:13px;font-weight:600;padding:16px;cursor:pointer;transition:all .2s;line-height:1.5;position:relative;z-index:1;backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px)}
  .btn-sanction:active{background:rgba(255,255,255,.1);transform:scale(.97)}
  .btn-sanction-confirm{width:100%;background:#fff;border:none;border-radius:14px;color:#CC0000;font-size:14px;font-weight:800;padding:16px;cursor:pointer;margin-top:10px;position:relative;z-index:1;letter-spacing:.04em;box-shadow:0 4px 20px rgba(255,255,255,.3);text-transform:uppercase;line-height:1.5}
  .btn-sanction-confirm:active{opacity:.8;transform:scale(.97)}
  .btn-shake{animation:shake .5s ease-in-out}
  </style>
  <div class="sanction-wrap">
    <div class="sanction-icon">&#9888;</div>
    <div class="sanction-title">SANCTION &mdash; <span id="s-day-label"></span></div>
    <div class="sanction-sub">QUÊTE OBLIGATOIRE NON ACCOMPLIE</div>
    <div class="sanction-ctx" id="s-ctx"></div>
    <div class="sanction-box">
      <div class="sanction-task" id="s-task"></div>
    </div>
    <div id="s-why" style="display:none;font-style:italic;color:rgba(255,255,255,.7);text-align:center;font-size:13px;margin-bottom:1rem;padding:0 1rem;line-height:1.6"></div>
    <div class="sanction-consequences">
      &#10007; Cette sanction doit être effectuée avant 10h demain<br/>
      &#10007; Série réduite - intégrité affectée<br/>
      &#10007; Le système a enregistré cette défaillance
    </div>
    <!-- Return offer zone (shown after 24h+ absence) -->
    <div id="s-return-offer" style="display:none;background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.2);border-radius:14px;padding:18px;margin-bottom:1.2rem;width:100%;text-align:center">
      <div style="font-size:12px;color:rgba(255,220,150,.9);font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-bottom:8px">&#128293; Retour possible</div>
      <div style="font-size:13px;color:rgba(255,255,255,.85);line-height:1.6;margin-bottom:12px" id="s-return-text"></div>
      <div style="display:flex;gap:10px;margin-top:4px">
        <button onclick="returnPay()" style="flex:1;background:rgba(255,200,80,.15);border:1px solid rgba(255,200,80,.4);border-radius:10px;color:rgba(255,220,120,.95);font-size:12px;font-weight:700;padding:12px 8px;cursor:pointer;line-height:1.4" id="btn-return-pay"></button>
        <button onclick="returnSkip()" style="flex:1;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:10px;color:rgba(255,255,255,.7);font-size:12px;font-weight:600;padding:12px 8px;cursor:pointer;line-height:1.4">Non - comptabiliser les jours manqués comme des échecs</button>
      </div>
    </div>
