function showContract(){
  document.getElementById('ob-body').innerHTML='<div class="ob-title">Contrat d\'engagement</div>'
    +'<div class="ob-sub">Votre programme va commencer. Mais avant, signez !</div>'
    +'<div class="sig-label">"Au cours des 30 prochains jours, je m\'engage à réaliser les quêtes demandées, pour devenir une meilleure version de moi-même, même si je n\'en ai pas la motivation."</div>'
    +'<canvas id="sig-canvas" class="sig-canvas" width="600" height="240"></canvas>'
    +'<div style="display:flex;gap:8px;margin-top:8px"><button class="btn" onclick="clearSig()" style="flex:1">Effacer</button><button class="btn primary" id="btn-sign" onclick="finishOB()" style="flex:1" disabled>Signer et commencer</button></div>';
  document.getElementById('ob-fill').style.width='100%';
  document.getElementById('ob-lbl').textContent='Signature requise';
  // Setup canvas
  setTimeout(function(){
    var c=document.getElementById('sig-canvas');if(!c)return;
    var ctx=c.getContext('2d');var drawing=false;window._sigHasDrawn=false;
    var rect=c.getBoundingClientRect();
    var scale=c.width/rect.width;
    ctx.strokeStyle='#c0713a';ctx.lineWidth=2.5;ctx.lineCap='round';ctx.lineJoin='round';
    function pos(e){var t=e.touches?e.touches[0]:e;return{x:(t.clientX-rect.left)*scale,y:(t.clientY-rect.top)*scale};}
    function start(e){e.preventDefault();drawing=true;var p=pos(e);ctx.beginPath();ctx.moveTo(p.x,p.y);}
    function move(e){if(!drawing)return;e.preventDefault();var p=pos(e);ctx.lineTo(p.x,p.y);ctx.stroke();if(!window._sigHasDrawn){window._sigHasDrawn=true;document.getElementById('btn-sign').disabled=false;}}
    function end(){drawing=false;}
    c.addEventListener('mousedown',start);c.addEventListener('mousemove',move);c.addEventListener('mouseup',end);c.addEventListener('mouseleave',end);
    c.addEventListener('touchstart',start,{passive:false});c.addEventListener('touchmove',move,{passive:false});c.addEventListener('touchend',end);
    window._sigCtx=ctx;window._sigCanvas=c;
  },100);
}
function clearSig(){
  if(window._sigCtx&&window._sigCanvas){window._sigCtx.clearRect(0,0,window._sigCanvas.width,window._sigCanvas.height);window._sigHasDrawn=false;document.getElementById('btn-sign').disabled=true;}
}
function finishOB(){
  ST.onboarded=true;const fat=ST.answers.fatigue||2;ST.fatigueScore=[1,2,3,4][fat]||3;
  if(fat<=1){ST.answers.sport_freq=Math.max(0,(ST.answers.sport_freq||0)-1);ST.answers.study_level=Math.max(0,(ST.answers.study_level||0)-1);}
  ST.gymW=0;ST.runW=0;ST.week=1;ST.weekPlan=genWeek();ST.questStatus={};ST.lastDate=todayStr();ST.dayDone=false;ST.failByType={body:0,mind:0,disc:0};ST.successByType={body:0,mind:0,disc:0};
  save();askNotif();
  const h=nowH();
  if(h>=10&&h<15){
    // Good time window - start immediately
    ST.waitingForTomorrow=false;save();
    nav('s-main');SND.open();flash('purple',600);toast('Système initialisé. La chasse commence.');
  } else {
    // After 15h or before 10h - wait for tomorrow
    ST.waitingForTomorrow=true;save();
    showWelcome();
  }
}

(async function init(){
  // Global error catcher for debug
  window.onerror = function(msg,src,line,col,err){
    const d=document.createElement('div');
    d.style.cssText='position:fixed;top:0;left:0;right:0;background:#c0392b;color:#fff;padding:10px;font-size:11px;z-index:99999;word-break:break-all';
    d.textContent='JS ERROR: '+msg+' (L'+line+')';
    document.body.appendChild(d);
  };
  // Load persisted state (IndexedDB → localStorage fallback)
  try{
    const saved=await loadState();
    if(saved)ST=Object.assign({},DEF,saved);
    // Also try localStorage migration if IndexedDB was empty
    if(!saved){
      try{const r=localStorage.getItem('slv10');if(r){ST=Object.assign({},DEF,JSON.parse(r));saveState(ST);}}catch(_){}
    }
  }catch(e){
    try{const r=localStorage.getItem('slv10');if(r)ST=Object.assign({},DEF,JSON.parse(r));}catch(_){}
  }
  if(!ST.onboarded){show('s-ob');buildOB();return;}
  // Init rank/title tracking to current state (avoid false triggers on load)
  _prevRank=getRank().label;
  for(var _ti=0;_ti<ID_T.length;_ti++){if(ID_T[_ti].ok(ST))_checkedTitles[ID_T[_ti].id]=true;}
  // First launch waiting mode
  if(ST.waitingForTomorrow){
    const h=nowH();const today=todayStr();
    // Unlock only on a new day AND after 10h
    if(h>=10&&ST.lastDate!==today){
      ST.waitingForTomorrow=false;
      ST.lastDate=today; // mark today, no advDay - day 1 starts fresh
      save();
      nav('s-main');SND.open();scheduleNotif();
    } else {
      showWelcome();
    }
    return;
  }
  const today=todayStr();
  if(ST.lastDate&&ST.lastDate!==today&&nowH()>=10){advDay();ST.lastDate=today;save();}else if(!ST.lastDate){ST.lastDate=today;save();}
  if(!ST.weekPlan||!ST.weekPlan.length){ST.weekPlan=genWeek();save();}
  // Sanction blocks everything - restore from saved text
  if(ST.sanctionPending&&!ST.dayDone){
    _updateAbsenceDays();
    _renderSanctionScreen();
    swSanctionLock(true);
    SND.sanction();
    show('s-sanction');return;
  }
  if(ST.dayDone){showDone();}else{nav('s-main');SND.open();scheduleNotif();}
})();

setInterval(()=>{
  const today=todayStr();
  const h=nowH();
  // If waiting for tomorrow and it's now 10h on a new day - launch directly
  if(ST.onboarded&&ST.waitingForTomorrow&&h>=10&&ST.lastDate!==today){
    ST.waitingForTomorrow=false;ST.lastDate=today;save();
    nav('s-main');SND.open();scheduleNotif();return;
  }
  // Update welcome countdown if on welcome screen
  if(document.getElementById('s-welcome').classList.contains('active'))updateWelcomeCd();
  // Day rollover only after 10h (quests open at 10h)
  if(ST.onboarded&&!ST.waitingForTomorrow&&ST.lastDate&&ST.lastDate!==today&&h>=10){advDay();ST.lastDate=today;save();}
  // Auto-fail unvalidated NN at 22h
  if(ST.onboarded&&!ST.dayDone&&!ST.reviewDone&&h>=22){
    const t=getToday();
    if(t){
      let changed=false;
      t.nn.forEach(q=>{
        if(!ST.questStatus[q.id]){
          ST.questStatus[q.id]='fail';
          ST.integrity=Math.max(0,ST.integrity-5);
          ST.disciplineDebt=Math.min(200,(ST.disciplineDebt||0)+15);
          if(!ST.failByType)ST.failByType={body:0,mind:0,disc:0};
          ST.failByType[q.type]=(ST.failByType[q.type]||0)+1;
          if(q.type==='disc')ST.weeklyBoss.discFail=(ST.weeklyBoss.discFail||0)+1;
          changed=true;
        }
      });
      if(changed){
        save();
        // If nothing was validated at all (zero quests touched) → show sanction immediately
        const allStatuses=Object.keys(ST.questStatus).length;
        const failed=t.nn.filter(q=>ST.questStatus[q.id]==='fail');
        if(failed.length>=2&&!ST.sanctionPending){
          // Trigger sanction screen directly - user abandoned the day
          ST.failStreak=Math.min(7,(ST.failStreak||0)+1);
          const fs=ST.failStreak;
          if(fs>=3)ST.streak=0;else ST.streak=Math.max(0,ST.streak-1);
          ST.sr7.push(0);
          SND.sanction();vib([300,100,300,100,300]);flash('red',800);
          buildSanction(failed);
          save();
          // Only redirect to sanction if user is on main screen
          if(document.getElementById('s-main').classList.contains('active')||
             document.getElementById('s-review').classList.contains('active')){
            show('s-sanction');
          }
        }
      }
    }
  }
  if(document.getElementById('s-main').classList.contains('active'))renderMain();
  if(document.getElementById('s-done').classList.contains('active'))updateCD();
},60000);

// ═══════════════════════════════════════════════════════════
// ─── MODE TEST - 5 taps rapides coin haut-droit ───────────
// ═══════════════════════════════════════════════════════════
window._TEST_MODE=false;
var _ttaps=0,_ttimer=null;

// Zone invisible 60×60px en haut à droite - fonctionne sur TOUS les écrans
(function(){
  var zone=document.createElement('div');
  zone.style.cssText='position:fixed;top:0;right:0;width:60px;height:60px;z-index:99999;';
  zone.addEventListener('click',function(e){
    e.preventDefault();e.stopPropagation();
    _ttaps++;clearTimeout(_ttimer);
    _ttimer=setTimeout(function(){_ttaps=0;},900);
    if(_ttaps>=5){_ttaps=0;toggleTestMode();}
  });
  zone.addEventListener('touchend',function(e){
    e.preventDefault();e.stopPropagation();
    _ttaps++;clearTimeout(_ttimer);
    _ttimer=setTimeout(function(){_ttaps=0;},900);
    if(_ttaps>=5){_ttaps=0;toggleTestMode();}
  });
  document.body.appendChild(zone);
})();

function toggleTestMode(){
  window._TEST_MODE=!window._TEST_MODE;
  document.getElementById('test-panel').style.display=window._TEST_MODE?'flex':'none';
  if(window._TEST_MODE){
    _testDateCounter=ST._testDateCounterSaved||ST.day||1;
    // Unlock from ANY blocking state
    if(ST.waitingForTomorrow){ST.waitingForTomorrow=false;}
    if(ST.sanctionPending){ST.sanctionPending=false;}
    if(ST.dayDone||ST.reviewDone){
      _testDateCounter++;ST.lastDate='test-'+(_testDateCounter-1);
      advDay();ST.lastDate=todayStr();
      if(!ST.weekPlan||!ST.weekPlan.length){ST.weekPlan=genWeek();}
      ST.questStatus={};ST.dayDone=false;ST.reviewDone=false;ST.morningCheckDone=false;ST.todayMood=null;
    }
    if(!ST.onboarded){
      // Skip onboarding for test
      ST.onboarded=true;
      ST.answers={sport_freq:2,run_freq:1,gym_sessions:1,goal:1,study_level:2,addiction_screen:1,addiction_porno:2,addiction_alc:2,addiction_food:2,wake:1,fatigue:2,read_level:1,obj_weight:2,comfort_level:1};
      ST.multiAnswers={hardest:['Faire du sport régulièrement','Résister aux écrans']};
      ST.fatigueScore=3;ST.weekPlan=genWeek();ST.lastDate=todayStr();
    }
    if(!ST.weekPlan||!ST.weekPlan.length){ST.weekPlan=genWeek();}
    save();
    nav('s-main');renderMain();
    _updateTestInfo();
    toast('⚙ Mode Test activé');
  } else {
    ST._testDateCounterSaved=_testDateCounter;save();toast('Mode Test désactivé');
  }
}

function _updateTestInfo(){
  var rk=getRank();
  var el=document.getElementById('test-info');
  if(el)el.textContent='J'+ST.day+' | '+rk.label+' | '+ST.xp+' XP | Série '+ST.streak+' | Int. '+ST.integrity;
}

// +1 jour : avance au lendemain, affiche les quêtes pour validation manuelle
function testSkipDay(){
  var t=getToday();
  if(t&&!ST.dayDone){
    t.nn.forEach(function(q){
      if(!ST.questStatus[q.id]){
        ST.questStatus[q.id]='fail';
        ST.integrity=Math.max(0,ST.integrity-5);
        ST.disciplineDebt=Math.min(200,(ST.disciplineDebt||0)+15);
        if(!ST.failByType)ST.failByType={body:0,mind:0,disc:0};
        ST.failByType[q.type]=(ST.failByType[q.type]||0)+1;
      }
    });
    var failed=t.nn.filter(function(q){return ST.questStatus[q.id]==='fail';});
    var ok=failed.length===0;
    ST.sr7.push(ok?1:0);
    if(!ST.bilans)ST.bilans=[];var d=new Date();
    var _tbqs=[];[].concat(t.nn,[t.water],t.secs||[]).filter(Boolean).forEach(function(q){_tbqs.push({n:(q.name||'').substring(0,30),s:ST.questStatus[q.id]||'skip'});});
    ST.bilans.push({day:ST.day,date:d.getDate()+'/'+(d.getMonth()+1)+'/'+d.getFullYear(),energy:3,disc:3,resisted:true,relapse:'',block:'',success:ok,hour:14,quests:_tbqs});
    if(!ST.dayLog)ST.dayLog=[];
    ST.dayLog.push({day:ST.day,date:d.getDate()+'/'+(d.getMonth()+1)+'/'+d.getFullYear(),dow:ST.day%7,success:ok,perfect:false,partial:ok,energy:3,body:t.nn.some(function(q){return q.type==='body'&&ST.questStatus[q.id]&&ST.questStatus[q.id]!=='fail';}),mind:t.nn.some(function(q){return q.type==='mind'&&ST.questStatus[q.id]&&ST.questStatus[q.id]!=='fail';}),disc:t.nn.some(function(q){return q.type==='disc'&&ST.questStatus[q.id]&&ST.questStatus[q.id]!=='fail';}),xp:ST.xp,streak:ST.streak});
    if(ST.dayLog.length>400)ST.dayLog=ST.dayLog.slice(-400);
    if(ok){ST.streak++;ST.bestStreak=Math.max(ST.bestStreak,ST.streak);ST.failStreak=0;ST.integrity=Math.min(100,ST.integrity+3);ST.disciplineDebt=Math.max(0,(ST.disciplineDebt||0)-15);}
    else{ST.failStreak=(ST.failStreak||0)+1;if(ST.failStreak>=3)ST.streak=0;else ST.streak=Math.max(0,ST.streak-1);}
  }
  ST.sanctionPending=false;ST.dayDone=true;ST.reviewDone=true;save();
  _testDateCounter++;ST.lastDate='test-'+(_testDateCounter-1);
  advDay();ST.lastDate=todayStr();
  if(!ST.weekPlan||!ST.weekPlan.length){ST.weekPlan=genWeek();}
  ST.questStatus={};ST.dayDone=false;ST.reviewDone=false;ST.morningCheckDone=false;ST.todayMood=null;save();
  nav('s-main');renderMain();
  _updateTestInfo();
  toast('+1 jour → J'+ST.day);
}

// +7j / +30j : auto-validation aléatoire (65%-95%)
function testAutoN(n){
  for(var i=0;i<n;i++)_testAutoOneDay();
  if(!ST.weekPlan||!ST.weekPlan.length){ST.weekPlan=genWeek();}
  ST.questStatus={};ST.dayDone=false;ST.reviewDone=false;ST.morningCheckDone=false;ST.todayMood=null;save();
  nav('s-main');renderMain();_updateTestInfo();
  toast(n+' jours simulés → J'+ST.day);
}
function _testAutoOneDay(){
  if(!ST.weekPlan||!ST.weekPlan.length){ST.weekPlan=genWeek();save();}
  ST.sanctionPending=false;ST.dayDone=false;ST.reviewDone=false;
  var t=getToday();if(!t){ST.weekPlan=genWeek();save();t=getToday();if(!t)return;}
  var rate=0.65+Math.random()*0.30;
  var allQ=[].concat(t.nn,[t.water],t.secs||[]).filter(Boolean);
  allQ.forEach(function(q){
    var isNN=q.id==='nn0'||q.id==='nn1'||q.id==='nn2';
    if(Math.random()<rate){
      var lv=Math.random()<0.45?'perfect':'clear';ST.questStatus[q.id]=lv;
      if(!ST.questLog)ST.questLog={};var _qk=q.type||q.id.replace(/[0-9]+$/,'');var _qnames={body:'Body (Salle/Sport)',mind:'Mind (Étude/Lecture)',disc:'Discipline',water:'Hydratation',se:'Secondaire Facile',sm:'Secondaire Moyen',sh:'Secondaire Dur'};if(!ST.questLog[_qk])ST.questLog[_qk]={name:_qnames[_qk]||(q.name||'').split(':')[0].trim().substring(0,20),gen:0,ok:0};ST.questLog[_qk].gen++;ST.questLog[_qk].ok++;
      var bxp=xpV(q.type||'se'),bp=ptsV(q.type||'se');
      var v=lv==='perfect'?bxp:Math.round(bxp*.7),p=lv==='perfect'?bp:Math.round(bp*.7);
      ST.xp+=v;ST.points+=p;
      if(q.type==='body'){ST.totalBody++;ST.weeklyBoss.body=(ST.weeklyBoss.body||0)+1;if(!ST.successByType)ST.successByType={body:0,mind:0,disc:0};ST.successByType.body=(ST.successByType.body||0)+1;}
      if(q.type==='mind'){ST.totalMind++;ST.weeklyBoss.mind=(ST.weeklyBoss.mind||0)+1;if(!ST.successByType)ST.successByType={body:0,mind:0,disc:0};ST.successByType.mind=(ST.successByType.mind||0)+1;}
      if(q.type==='disc'){ST.totalDisc++;if(!ST.successByType)ST.successByType={body:0,mind:0,disc:0};ST.successByType.disc=(ST.successByType.disc||0)+1;}
      if(!ST.validationHours)ST.validationHours=[];ST.validationHours.push(10+Math.floor(Math.random()*10));
      if(ST.validationHours.length>200)ST.validationHours=ST.validationHours.slice(-200);
    } else {
      ST.questStatus[q.id]='fail';
      if(!ST.questLog)ST.questLog={};var _qkf=q.type||q.id.replace(/[0-9]+$/,'');var _qnamesf={body:'Body (Salle/Sport)',mind:'Mind (Étude/Lecture)',disc:'Discipline',water:'Hydratation',se:'Secondaire Facile',sm:'Secondaire Moyen',sh:'Secondaire Dur'};if(!ST.questLog[_qkf])ST.questLog[_qkf]={name:_qnamesf[_qkf]||(q.name||'').split(':')[0].trim().substring(0,20),gen:0,ok:0};ST.questLog[_qkf].gen++;
      if(isNN){ST.integrity=Math.max(0,ST.integrity-5);ST.disciplineDebt=Math.min(200,(ST.disciplineDebt||0)+15);if(!ST.failByType)ST.failByType={body:0,mind:0,disc:0};ST.failByType[q.type]=(ST.failByType[q.type]||0)+1;if(q.type==='disc')ST.weeklyBoss.discFail=(ST.weeklyBoss.discFail||0)+1;}
    }
  });
  var failed=t.nn.filter(function(q){return ST.questStatus[q.id]==='fail';});var ok=failed.length===0;
  ST.sr7.push(ok?1:0);var energy=ok?(3+Math.floor(Math.random()*2)):(1+Math.floor(Math.random()*2));
  if(!ST.bilans)ST.bilans=[];var d=new Date();
  var _tbqs2=[];[].concat(t.nn,[t.water],t.secs||[]).filter(Boolean).forEach(function(q){_tbqs2.push({n:(q.name||'').substring(0,30),s:ST.questStatus[q.id]||'skip'});});
  ST.bilans.push({day:ST.day,date:d.getDate()+'/'+(d.getMonth()+1)+'/'+d.getFullYear(),energy:energy,disc:3,resisted:Math.random()>0.15,relapse:'',block:'',success:ok,hour:14,quests:_tbqs2});
  if(!ST.dayLog)ST.dayLog=[];
  ST.dayLog.push({day:ST.day,date:d.getDate()+'/'+(d.getMonth()+1)+'/'+d.getFullYear(),dow:ST.day%7,success:ok,perfect:false,partial:ok,energy:energy,body:t.nn.some(function(q){return q.type==='body'&&ST.questStatus[q.id]&&ST.questStatus[q.id]!=='fail';}),mind:t.nn.some(function(q){return q.type==='mind'&&ST.questStatus[q.id]&&ST.questStatus[q.id]!=='fail';}),disc:t.nn.some(function(q){return q.type==='disc'&&ST.questStatus[q.id]&&ST.questStatus[q.id]!=='fail';}),xp:ST.xp,streak:ST.streak});
  if(ST.dayLog.length>400)ST.dayLog=ST.dayLog.slice(-400);
  if(energy<=2)ST.fatigueScore=Math.max(1,ST.fatigueScore-1);else if(energy>=4)ST.fatigueScore=Math.min(4,ST.fatigueScore+1);
  if(ok){ST.streak++;ST.bestStreak=Math.max(ST.bestStreak,ST.streak);ST.failStreak=0;ST.integrity=Math.min(100,ST.integrity+3);ST.disciplineDebt=Math.max(0,(ST.disciplineDebt||0)-15);if(ST.streak>=2&&ST.fatigueScore<=1)ST.fatigueScore=2;if(ST.integrity>=60)ST.rankDowngrade=false;}
  else{ST.failStreak=(ST.failStreak||0)+1;if(ST.failStreak>=3)ST.streak=0;else ST.streak=Math.max(0,ST.streak-1);if(failed.length>=2){ST.totalSanctions=(ST.totalSanctions||0)+1;ST.sanctionsCompleted=(ST.sanctionsCompleted||0)+1;}}
  if(ST.day%7===0){var wb=ST.weeklyBoss||{};var _tw=ST.week||1;var _tnm=_tw>=2?4:0;var _tnd=_tw>=3;if((wb.body||0)>=3&&(_tw<2||(wb.mind||0)>=_tnm)&&(!_tnd||(wb.discFail||0)<=2)){ST.xp+=40;ST.points+=20;ST.bossWins=(ST.bossWins||0)+1;var _debt=ST.disciplineDebt||0;if(_debt>=20){ST.disciplineDebt-=20;}else if(_debt>0){ST.disciplineDebt=0;}}}
  // Boss check BEFORE advDay
  var wbC=ST.weeklyBoss||{body:0,mind:0,discFail:0};var _twC=ST.week||1;var _tnmC=_twC>=2?4:0;var _tndC=_twC>=3;
  if((wbC.body||0)>=3&&(_twC<2||(wbC.mind||0)>=_tnmC)&&(!_tndC||(wbC.discFail||0)<=2)&&!ST._bossShownThisWeek){
    ST._bossShownThisWeek=true;
    ST.xp+=40;ST.points+=20;ST.bossWins=(ST.bossWins||0)+1;
    var debt=ST.disciplineDebt||0;
    if(debt>=20)ST.disciplineDebt-=20;else if(debt>0)ST.disciplineDebt=0;
    if(!ST.bossQuoteIdx)ST.bossQuoteIdx=0;ST.bossQuoteIdx=(ST.bossQuoteIdx+1)%BOSS_QUOTES.length;
  }
  ST.dayDone=true;ST.reviewDone=true;ST.sanctionPending=false;save();
  _testDateCounter++;ST.lastDate='test-'+(_testDateCounter-1);
  advDay();ST.lastDate=todayStr();
  if(!ST.weekPlan||!ST.weekPlan.length){ST.weekPlan=genWeek();}
  ST.questStatus={};ST.dayDone=false;ST.reviewDone=false;ST.morningCheckDone=false;ST.todayMood=null;save();
}

function testReset(){
  if(!confirm('Remettre à zéro la progression ? (Le questionnaire et ton pourquoi sont conservés)'))return;
  // Preserve onboarding data
  var savedAnswers=ST.answers||{};
  var savedMulti=ST.multiAnswers||{};
  var savedWhy=ST.myWhy||'';
  // Clear storage
  try{indexedDB.deleteDatabase('solo_leveling_db');}catch(e){}
  try{localStorage.clear();}catch(e){}
  // Reset state but keep onboarding
  ST=Object.assign({},DEF);
  ST.onboarded=true;
  ST.answers=savedAnswers;
  ST.multiAnswers=savedMulti;
  ST.myWhy=savedWhy;
  ST.fatigueScore=3;
  ST.weekPlan=genWeek();
  ST.lastDate=todayStr();
  _testDateCounter=1;
  window._TEST_MODE=true;
  save();
  nav('s-main');
  renderMain();
  toast('Reset - questionnaire conservé.');
}

