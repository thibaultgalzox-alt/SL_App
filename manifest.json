// ─── V2 SVG CHART HELPERS ───
function _svgSparkline(data,color,w,h){
  if(!data.length)return'';
  if(data.length===1)return`<svg viewBox="0 0 ${w} ${h}" style="width:100%;height:${h}px"><circle cx="${w/2}" cy="${h/2}" r="2" fill="${color}"/></svg>`;
  const max=Math.max(...data,1),min=Math.min(...data,0),range=max-min||1;
  const pts=data.map((v,i)=>`${(i/(data.length-1))*w},${h-((v-min)/range)*(h-4)-2}`).join(' ');
  const area=pts+` ${w},${h} 0,${h}`;
  const gid='sg'+color.replace(/#/g,'')+(Math.random()*9999|0);
  return`<svg viewBox="0 0 ${w} ${h}" style="width:100%;height:${h}px" preserveAspectRatio="none"><defs><linearGradient id="${gid}" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="${color}" stop-opacity="0.3"/><stop offset="100%" stop-color="${color}" stop-opacity="0"/></linearGradient></defs><polygon points="${area}" fill="url(#${gid})"/><polyline points="${pts}" fill="none" stroke="${color}" stroke-width="1.5" stroke-linejoin="round"/></svg>`;
}

function _svgRadar(body,mind,disc,size){
  const cx=size/2,cy=size/2,r=size*.38;
  const a=[-Math.PI/2,-Math.PI/2+(2*Math.PI/3),-Math.PI/2+(4*Math.PI/3)];
  const v=[body/100,mind/100,disc/100];
  const gp=s=>a.map(an=>`${cx+r*s*Math.cos(an)},${cy+r*s*Math.sin(an)}`).join(' ');
  const dp=v.map((val,i)=>`${cx+r*val*Math.cos(a[i])},${cy+r*val*Math.sin(a[i])}`).join(' ');
  const labs=[{t:'Body',x:cx,y:cy-r-10,c:'#2e7d32'},{t:'Mind',x:cx+r+6,y:cy+r*.6,c:'#74b9ff'},{t:'Disc',x:cx-r-6,y:cy+r*.6,c:'#fd79a8'}];
  let svg=`<svg viewBox="0 0 ${size} ${size}" style="width:${size}px;height:${size}px">`;
  [.25,.5,.75,1].forEach(s=>{svg+=`<polygon points="${gp(s)}" fill="none" stroke="#d4c9b0" stroke-width="0.5"/>`;});
  a.forEach(an=>{svg+=`<line x1="${cx}" y1="${cy}" x2="${cx+r*Math.cos(an)}" y2="${cy+r*Math.sin(an)}" stroke="#d4c9b0" stroke-width="0.5"/>`;});
  svg+=`<polygon points="${dp}" fill="rgba(108,92,231,0.15)" stroke="#c0713a" stroke-width="1.5"/>`;
  v.forEach((val,i)=>{svg+=`<circle cx="${cx+r*val*Math.cos(a[i])}" cy="${cy+r*val*Math.sin(a[i])}" r="3" fill="${labs[i].c}"/>`;});
  labs.forEach((l,i)=>{svg+=`<text x="${l.x}" y="${l.y}" text-anchor="middle" fill="${l.c}" font-size="9" font-weight="600" font-family="sans-serif">${l.t} ${Math.round(v[i]*100)}%</text>`;});
  svg+='</svg>';return svg;
}

function _svgHeatmap(dayLog,totalDays){
  const cs=9,gap=2;
  // Show last 365 days max
  const showDays=Math.min(totalDays,365);
  const startDay=Math.max(1,totalDays-showDays+1);
  const weeks=Math.ceil(showDays/7);const w=weeks*(cs+gap)+14;const h=7*(cs+gap)+12;
  let svg='<svg viewBox="0 0 '+w+' '+h+'" style="width:'+w+'px;height:'+h+'px">';
  var dowLbl=['L','M','M','J','V','S','D'];
  for(var di=0;di<7;di++){svg+='<text x="0" y="'+(di*(cs+gap)+cs+4)+'" font-size="7" fill="#8a7e6a" font-family="sans-serif">'+dowLbl[di]+'</text>';}
  var logMap={};for(var li=0;li<dayLog.length;li++){logMap[dayLog[li].day]=dayLog[li];}
  for(var i=0;i<showDays;i++){
    var wk=Math.floor(i/7),dow=i%7,dayN=startDay+i;
    var entry=logMap[dayN];
    var color='#d4c9b0';
    if(dayN<=totalDays&&entry){
      // surpassé=dark green(all quests), réussi=green(NN ok), raté=red(>=1 NN fail), échec=bright red(all NN fail)
      if(entry.perfect)color='#00694b';
      else if(entry.success)color='#00b894';
      else if(entry.body===false&&entry.mind===false&&entry.disc===false)color='#b71c1c';
      else color='#c0392b';
    } else if(dayN<=totalDays){color='#c0392b';}
    svg+='<rect x="'+(14+wk*(cs+gap))+'" y="'+(dow*(cs+gap))+'" width="'+cs+'" height="'+cs+'" rx="2" fill="'+color+'" opacity="0.85"/>';
  }
  svg+='</svg>';return svg;
}

function _svgLally(autoData,totalDays){
  const w=280,h=110,max=100,thresh=85;
  // Compute automaticity array from dayLog
  const auto=[];
  for(let i=0;i<autoData.length;i++){
    const maxA=95,rate=0.04+(i<21?0.015:0);
    const rawAuto=maxA*(1-Math.exp(-rate*i));
    // Add noise from actual success
    const entry=autoData[i];
    const bonus=entry&&entry.success?2:-3;
    auto.push(Math.max(0,Math.min(max,Math.round(rawAuto+bonus))));
  }
  if(!auto.length)return'<div style="font-size:11px;color:#8a7e6a;text-align:center;padding:1rem">Pas encore de données.</div>';
  const pts=auto.map((v,i)=>`${(i/(Math.max(auto.length-1,1)))*w},${h-(v/max)*(h-10)-5}`).join(' ');
  const idealPts=auto.map((_,i)=>{const iv=95*(1-Math.exp(-0.04*i));return`${(i/(Math.max(auto.length-1,1)))*w},${h-(iv/max)*(h-10)-5}`;}).join(' ');
  const threshY=h-(thresh/max)*(h-10)-5;
  const p2x=(Math.min(21,auto.length)/(Math.max(auto.length-1,1)))*w;
  const p3x=(Math.min(66,auto.length)/(Math.max(auto.length-1,1)))*w;
  let svg=`<svg viewBox="0 0 ${w} ${h+20}" style="width:100%;height:${h+20}px">`;
  svg+=`<rect x="0" y="0" width="${p2x}" height="${h}" fill="#2e7d32" opacity="0.03" rx="3"/>`;
  svg+=`<rect x="${p2x}" y="0" width="${p3x-p2x}" height="${h}" fill="#c0713a" opacity="0.03"/>`;
  svg+=`<rect x="${p3x}" y="0" width="${w-p3x}" height="${h}" fill="#d4a054" opacity="0.03" rx="3"/>`;
  svg+=`<text x="${p2x/2}" y="${h+13}" text-anchor="middle" font-size="7" fill="#2e7d32" font-family="sans-serif">Phase 1</text>`;
  svg+=`<text x="${(p2x+p3x)/2}" y="${h+13}" text-anchor="middle" font-size="7" fill="#c0713a" font-family="sans-serif">Phase 2</text>`;
  svg+=`<text x="${(p3x+w)/2}" y="${h+13}" text-anchor="middle" font-size="7" fill="#d4a054" font-family="sans-serif">Phase 3</text>`;
  svg+=`<line x1="0" y1="${threshY}" x2="${w}" y2="${threshY}" stroke="#00b894" stroke-width="0.5" stroke-dasharray="4 2"/>`;
  svg+=`<text x="${w-2}" y="${threshY+10}" text-anchor="end" font-size="6" fill="#00b894" font-family="sans-serif">85%</text>`;
  svg+=`<polyline points="${idealPts}" fill="none" stroke="#e8dfd3" stroke-width="1" stroke-dasharray="3 2"/>`;
  svg+=`<defs><linearGradient id="lgfill" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#c0713a" stop-opacity="0.2"/><stop offset="100%" stop-color="#c0713a" stop-opacity="0"/></linearGradient></defs>`;
  svg+=`<polygon points="${pts} ${w},${h} 0,${h}" fill="url(#lgfill)"/>`;
  svg+=`<polyline points="${pts}" fill="none" stroke="#c0713a" stroke-width="2" stroke-linejoin="round"/>`;
  const lastV=auto[auto.length-1];const lastX=w;const lastY=h-(lastV/max)*(h-10)-5;
  svg+=`<circle cx="${lastX}" cy="${lastY}" r="4" fill="#d4a054"/>`;
  svg+='</svg>';
  return{svg,lastVal:lastV,auto};
}


function _svgSpider(questLog){
  if(!questLog||Object.keys(questLog).length<3)return'<div style="font-size:10px;color:var(--ink3);text-align:center;padding:1rem">Pas encore assez de données.</div>';
  var order=['body','mind','disc','se','sm','sh'];
  var labels={'body':'Body','mind':'Mind','disc':'Discipline','se':'Sec. Facile','sm':'Sec. Moyen','sh':'Sec. Dur'};
  // Estimated global average completion rates
  var globalAvg={'body':0.65,'mind':0.60,'disc':0.55,'se':0.50,'sm':0.40,'sh':0.25};
  var cats=[];
  for(var oi=0;oi<order.length;oi++){
    var k=order[oi];
    if(questLog[k]&&questLog[k].gen>0){
      cats.push({name:labels[k]||k,gen:questLog[k].gen,ok:questLog[k].ok,
        userRate:questLog[k].ok/questLog[k].gen,
        avgRate:globalAvg[k]||0.5});
    }
  }
  if(cats.length<3)return'<div style="font-size:10px;color:var(--ink3);text-align:center;padding:1rem">Pas encore assez de données.</div>';
  // Use absolute counts with a dynamic scale so the web GROWS over time
  var maxCount=1;for(var i=0;i<cats.length;i++){maxCount=Math.max(maxCount,cats[i].gen,cats[i].ok);}
  // Scale: the outer ring = maxCount * 1.15 (so polygons never touch the edge)
  var scale=maxCount*1.15;
  var n=cats.length,size=270,cx=size/2,cy=size/2+8,r=size*.30;
  var svg='<svg viewBox="0 0 '+size+' '+(size+16)+'" style="width:100%;max-width:290px;height:auto;margin:0 auto;display:block">';
  var angles=[];for(var i=0;i<n;i++)angles.push(-Math.PI/2+(2*Math.PI/n)*i);
  // Grid rings (4 levels)
  for(var s=0;s<4;s++){
    var sc2=(s+1)/4;var pts='';
    for(var i=0;i<n;i++)pts+=(cx+r*sc2*Math.cos(angles[i]))+','+(cy+r*sc2*Math.sin(angles[i]))+' ';
    svg+='<polygon points="'+pts+'" fill="none" stroke="var(--bg2)" stroke-width="0.5"/>';
  }
  // Axes
  for(var i=0;i<n;i++)svg+='<line x1="'+cx+'" y1="'+cy+'" x2="'+(cx+r*Math.cos(angles[i]))+'" y2="'+(cy+r*Math.sin(angles[i]))+'" stroke="var(--bg2)" stroke-width="0.5"/>';
  // Grey polygon = generated quests (shows total volume - grows over time)
  var genPts='';for(var i=0;i<n;i++){var v=Math.min(1,cats[i].gen/scale);genPts+=(cx+r*v*Math.cos(angles[i]))+','+(cy+r*v*Math.sin(angles[i]))+' ';}
  svg+='<polygon points="'+genPts+'" fill="rgba(154,139,120,.08)" stroke="var(--ink4)" stroke-width="1.5" stroke-dasharray="4 2"/>';
  // Green polygon = completed quests (also absolute - grows over time)
  var okPts='';for(var i=0;i<n;i++){var v=Math.min(1,cats[i].ok/scale);okPts+=(cx+r*v*Math.cos(angles[i]))+','+(cy+r*v*Math.sin(angles[i]))+' ';}
  svg+='<polygon points="'+okPts+'" fill="rgba(43,122,59,.12)" stroke="var(--green)" stroke-width="2"/>';
  // Labels + dots
  for(var i=0;i<n;i++){
    var v=Math.min(1,cats[i].ok/scale);
    svg+='<circle cx="'+(cx+r*v*Math.cos(angles[i]))+'" cy="'+(cy+r*v*Math.sin(angles[i]))+'" r="3" fill="var(--green)"/>';
    var lx=cx+(r+24)*Math.cos(angles[i]);var ly=cy+(r+24)*Math.sin(angles[i]);
    var anchor=Math.abs(Math.cos(angles[i]))<.3?'middle':Math.cos(angles[i])>0?'start':'end';
    svg+='<text x="'+lx+'" y="'+ly+'" text-anchor="'+anchor+'" font-size="8" font-weight="600" fill="var(--ink2)" font-family="sans-serif">'+cats[i].name+'</text>';
    svg+='<text x="'+lx+'" y="'+(ly+10)+'" text-anchor="'+anchor+'" font-size="7" fill="var(--green)" font-family="sans-serif">'+cats[i].ok+'/'+cats[i].gen+' ('+Math.round(cats[i].userRate*100)+'%)</text>';
  }
  svg+='</svg>';
  return svg;
}


function _flowZone(el,label,rate,color){
  const zone=rate>85?'ennui':rate<50?'anxiété':'flow';
  const zc=zone==='flow'?'#2e7d32':zone==='ennui'?'#c0713a':'#e74c3c';
  const zl=zone==='flow'?'Zone de Flow ✓':zone==='ennui'?'Trop facile → ↑ diff.':'Trop dur → ↓ diff.';
  el.innerHTML=`<div class="st-flow-lbl" style="color:${color}">${label}</div>
    <div class="st-flow-track"><div class="st-flow-marker" style="left:${Math.max(0,Math.min(100,rate)-15)}%;width:30%;background:linear-gradient(90deg,transparent,${zc},transparent)"></div></div>
    <div style="display:flex;justify-content:space-between;align-items:center;margin-top:2px">
      <span class="st-flow-zone" style="color:${zc}">${zl}</span>
      <span style="font-size:11px;font-weight:700;color:${zc}">${rate}%</span>
    </div>`;
}

// ─── V2 RENDER STATS ───
function renderStats(){
  const dayLog=ST.dayLog||[];
  const bilans=ST.bilans||[];
  const sr7=ST.sr7||[];
  const totalDays=sr7.length||0;
  const successDays=sr7.filter(x=>x===1).length;
  const last30=sr7.slice(-30);
  const rate30=last30.length?Math.round(last30.filter(x=>x===1).length/last30.length*100):0;

  // ─── OVERVIEW PANE ───
  document.getElementById('st2-day').textContent=ST.day;
  document.getElementById('st2-streak').textContent=ST.streak;
  document.getElementById('st2-best').textContent=ST.bestStreak;
  document.getElementById('st2-rate').textContent=rate30+'%';

  // Heatmap
  document.getElementById('st2-heatmap').innerHTML=_svgHeatmap(dayLog,ST.day);

  // Top/Flop quests - only NN (body/mind/disc) + water, hide >85%
  const sb=ST.successByType||{body:0,mind:0,disc:0};
  const fb=ST.failByType||{body:0,mind:0,disc:0};
  const bodyTotal=Math.max(1,(sb.body||0)+(fb.body||0));
  const mindTotal=Math.max(1,(sb.mind||0)+(fb.mind||0));
  const discTotal=Math.max(1,(sb.disc||0)+(fb.disc||0));
  const bodyPct=Math.round((sb.body||0)/bodyTotal*100);
  const mindPct=Math.round((sb.mind||0)/mindTotal*100);
  const discPct=Math.round((sb.disc||0)/discTotal*100);
  const qlog=ST.questLog||{};
  const coreKeys=['body','mind','disc','water'];
  const qEntries=coreKeys.map(k=>{const v=qlog[k];if(!v||v.gen<2)return null;return{key:k,name:v.name,gen:v.gen,ok:v.ok,rate:Math.round(v.ok/v.gen*100)};}).filter(Boolean);
  const tfEl=document.getElementById('st2-topflop');
  if(qEntries.length>=2){
    const sorted=[...qEntries].sort((a,b)=>b.rate-a.rate);
    const top2=sorted.slice(0,2);
    const flop=sorted.filter(q=>q.rate<=85).sort((a,b)=>a.rate-b.rate).slice(0,2);
    let html='<div style="font-size:9px;font-weight:700;color:#2e7d32;text-transform:uppercase;letter-spacing:.08em;margin-bottom:4px">&#11014; Les + effectuées</div>';
    top2.forEach(q=>{html+='<div style="font-size:10px;color:#3a2e22;margin-bottom:3px;padding:4px 6px;background:#e8f5e9;border-radius:6px;border-left:2px solid #00b894">'+q.name+' <span style="color:#2e7d32;font-weight:700">'+q.rate+'%</span></div>';});
    if(flop.length){
      html+='<div style="font-size:9px;font-weight:700;color:#c0392b;text-transform:uppercase;letter-spacing:.08em;margin:6px 0 4px">&#11015; À améliorer</div>';
      flop.forEach(q=>{html+='<div style="font-size:10px;color:#3a2e22;margin-bottom:3px;padding:4px 6px;background:#fce8e8;border-radius:6px;border-left:2px solid #c0392b">'+q.name+' <span style="color:#c0392b;font-weight:700">'+q.rate+'%</span></div>';});
    } else {
      html+='<div style="font-size:9px;color:#2e7d32;margin-top:6px;font-style:italic">Toutes les quêtes obligatoires sont au-dessus de 85% ✓</div>';
    }
    tfEl.innerHTML=html;
  } else {
    tfEl.innerHTML='<div style="font-size:10px;color:#8a7e6a;padding:8px 0">Quelques jours de plus…</div>';
  }

  // Sparkline 30j
  const spark30=[];
  for(let i=0;i<last30.length;i++){
    const sl=last30.slice(Math.max(0,i-6),i+1);
    spark30.push(sl.reduce((a,b)=>a+b,0)/sl.length*100);
  }
  document.getElementById('st2-sparkline').innerHTML=spark30.length>1?_svgSparkline(spark30,'#c0713a',200,45):'<div style="font-size:10px;color:#8a7e6a;padding:10px 0">En attente de données…</div>';
  document.getElementById('st2-rate-big').textContent=rate30+'%';
  document.getElementById('st2-rate-big').style.color=rate30>=70?'#2e7d32':'#c0713a';
  const spStart=Math.max(1,ST.day-29);
  document.getElementById('st2-sp-start').textContent='J'+spStart;
  document.getElementById('st2-sp-end').textContent='J'+ST.day;

  // Flow zones
  const dl30=dayLog.slice(-30);
  const bodyR30=dl30.length?Math.round(dl30.filter(d=>d.body).length/dl30.length*100):50;
  const mindR30=dl30.length?Math.round(dl30.filter(d=>d.mind).length/dl30.length*100):50;
  const discR30=dl30.length?Math.round(dl30.filter(d=>d.disc).length/dl30.length*100):50;
  _flowZone(document.getElementById('st2-flow-body'),'Body',bodyR30,'#2e7d32');
  _flowZone(document.getElementById('st2-flow-mind'),'Mind',mindR30,'#74b9ff');
  _flowZone(document.getElementById('st2-flow-disc'),'Discipline',discR30,'#fd79a8');

  // XP sparkline
  const xpCurve=dayLog.map(d=>d.xp);
  document.getElementById('st2-xp-sparkline').innerHTML=xpCurve.length>1?_svgSparkline(xpCurve,'#d4a054',260,40):'<div style="font-size:10px;color:#8a7e6a;padding:8px 0">En attente de données…</div>';
  document.getElementById('st2-xp-total').textContent=ST.xp+' XP';
  document.getElementById('st2-xp-end').textContent='Jour '+ST.day;

  // Profile & Sanctions
  const ts=ST.totalSanctions||0;const sc2=ST.sanctionsCompleted||0;
  const goalTxt=["Perte de poids","Renforcement musculaire","Prise de masse","Maintien"][ST.answers.goal||0]||'Non défini';
  const hard=ST.multiAnswers.hardest||[];
  document.getElementById('st2-profile').innerHTML=`
    <div style="font-size:11px;color:#7a6e5a;margin-bottom:4px">Objectif : <strong style="color:#2c2416">${goalTxt}</strong></div>
    <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:6px">${hard.length?hard.map(h=>'<span class="badge" style="font-size:9px">'+h+'</span>').join(''):'<span style="font-size:10px;color:#8a7e6a">Non renseigné</span>'}</div>
    <div style="display:flex;gap:12px;font-size:11px;color:#7a6e5a">
      <span>Sanctions : <strong style="color:#c0392b">${ts}</strong></span>
      <span>Complétées : <strong style="color:#2e7d32">${sc2}</strong></span>
      <span>Rattrapage : <strong style="color:#c0713a">${ts>0?Math.round(sc2/ts*100):0}%</strong></span>
    </div>`;

  // ─── HABITS PANE ───
  const lallyResult=_svgLally(dayLog,ST.day);
  const autoScore=lallyResult.auto?lallyResult.auto[lallyResult.auto.length-1]||0:0;
  document.getElementById('st2-auto-score').textContent=autoScore+'%';
  document.getElementById('st2-auto-score').style.color=autoScore>=85?'#2e7d32':'#d4a054';
  document.getElementById('st2-auto-bar').style.width=autoScore+'%';
  document.getElementById('st2-auto-bar').style.background=autoScore>=85?'linear-gradient(90deg,#00b894,#2e7d32)':'linear-gradient(90deg,#c0713a,#d4a054)';
  const phase=ST.day<=21?1:ST.day<=66?2:3;
  document.getElementById('st2-auto-text').textContent=autoScore>=85
    ?'Tes habitudes approchent l\'automaticité. Le cerveau commence à exécuter ces comportements sans effort conscient.'
    :phase===1?'Phase 1 - Les gains d\'automaticité sont les plus forts maintenant. Chaque jour compte.'
    :phase===2?'Phase 2 - Les gains ralentissent naturellement, c\'est normal. Continue la régularité.'
    :'Phase 3 - Mode maîtrise. Tu construis sur des fondations solides.';

  // Lally curve
  document.getElementById('st2-lally-curve').innerHTML=lallyResult.svg||'<div style="font-size:10px;color:#8a7e6a;text-align:center;padding:1rem">Fais ton premier bilan pour voir ta courbe.</div>';

  // Phases
  const phases=[
    {label:'Phase 1 - Awakening',range:'J1–J21',days:21,color:'#2e7d32',done:ST.day>21},
    {label:'Phase 2 - Ascension',range:'J22–J66',days:45,color:'#d4a054',done:ST.day>66},
    {label:'Phase 3 - Mastery',range:'J67+',days:90,color:'#c0713a',done:false},
  ];
  document.getElementById('st2-phases').innerHTML=phases.map((p,i)=>{
    const progress=i===0?Math.min(100,(Math.min(ST.day,21)/21)*100):i===1?Math.min(100,(Math.max(0,Math.min(ST.day,66)-21)/45)*100):Math.min(100,(Math.max(0,ST.day-66)/90)*100);
    return`<div class="st-phase-row" style="border-left:3px solid ${p.color}">
      <div style="display:flex;justify-content:space-between;font-size:11px">
        <span style="font-weight:600;color:${p.done?p.color:'#3a2e22'}">${p.done?'✓ ':''}${p.label}</span>
        <span style="color:#8a7e6a;font-size:10px">${p.range}</span>
      </div>
      <div class="st-phase-track"><div class="st-phase-fill" style="width:${progress}%;background:${p.color}"></div></div>
    </div>`;
  }).join('');

  // Spider chart
  document.getElementById('st2-spider').innerHTML=_svgSpider(ST.questLog);
  // Axis counts
  document.getElementById('st2-body-n').textContent=ST.totalBody;
  document.getElementById('st2-mind-n').textContent=ST.totalMind;
  document.getElementById('st2-disc-n').textContent=ST.totalDisc;

  // ─── INSIGHTS PANE ───
  document.getElementById('st2-week-n').textContent=ST.week||1;

  // Generate insights
  const insights=[];
  const tl={body:'en sport',mind:'en études',disc:'en discipline'};
  const tln={body:'Sport',mind:'Études',disc:'Discipline'};
  // 1. Strongest axis
  const msI=Object.entries(sb).filter(([,v])=>v>0).sort((a,b)=>b[1]-a[1])[0];
  if(msI)insights.push({text:`Ton axe fort est <strong style="color:#2e7d32">${tln[msI[0]]}</strong> - ${bodyPct>80||mindPct>80||discPct>80?'la difficulté augmente progressivement.':'continue à construire dessus.'}`,color:'#2e7d32'});
  // 2. Weakest axis
  const mfI=Object.entries(fb).filter(([,v])=>v>0).sort((a,b)=>b[1]-a[1])[0];
  if(mfI)insights.push({text:`Tu échoues surtout <strong style="color:#c0392b">${tl[mfI[0]]}</strong>. Le système ajuste la difficulté pour te maintenir en zone de flow.`,color:'#c0392b'});
  // 3. Validation hours
  const vHours=ST.validationHours||[];
  if(vHours.length>=5){
    const avg=Math.round(vHours.reduce((a,b)=>a+b,0)/vHours.length);
    insights.push({text:`Tes validations sont concentrées vers <strong style="color:#74b9ff">${avg}h</strong>. Les rappels s'adapteront en conséquence.`,color:'#74b9ff'});
  }
  // 4. Automaticity
  insights.push({text:`Score d'automaticité : <strong style="color:#c0713a">${autoScore}%</strong>. ${autoScore>=70?'Tu approches du seuil d\'habitude formée (85%).':'Les gains sont les plus forts en ce moment - chaque jour régulier accélère la courbe.'}`,color:'#c0713a'});
  // 5. Fatigue correlation
  const lowEBilans=bilans.filter(b=>b.energy&&b.energy<=2);
  if(lowEBilans.length>=3){
    const failOnLow=lowEBilans.filter(b=>!b.success).length;
    if(failOnLow/lowEBilans.length>0.5)insights.push({text:'Les jours de faible énergie dégradent ton taux de réussite. Pense à adapter le rythme.',color:'#d4a054'});
  }
  // 6. Relapses
  const relapses=bilans.filter(b=>b.resisted===false&&b.hour!==undefined);
  if(relapses.length>=2){
    const evening=relapses.filter(b=>b.hour>=20).length;
    if(evening/relapses.length>0.6)insights.push({text:'Tes rechutes sont concentrées le soir. Prépare ta routine nocturne.',color:'#fd79a8'});
  }

  const insList=document.getElementById('st2-insights-list');
  if(insights.length){
    insList.innerHTML=insights.slice(0,5).map(ins=>`<div class="st-insight" style="border-left:2px solid ${ins.color}">${ins.text}</div>`).join('');
  } else {
    insList.innerHTML='<div style="font-size:11px;color:#8a7e6a;padding:8px 0">Continue - les insights apparaîtront au fil des jours.</div>';
  }

  // Mood correlation chart
  const moodData=[{emoji:'😴',label:'1-2★',filter:b=>b.energy&&b.energy<=2},{emoji:'😐',label:'3★',filter:b=>b.energy&&b.energy===3},{emoji:'⚡',label:'4-5★',filter:b=>b.energy&&b.energy>=4}];
  const moodEl=document.getElementById('st2-mood-chart');
  if(bilans.filter(b=>b.energy).length>=3){
    moodEl.innerHTML=moodData.map(m=>{
      const matching=bilans.filter(b=>!b.isSanction&&m.filter(b));
      const mRate=matching.length?Math.round(matching.filter(b=>b.success).length/matching.length*100):0;
      const barColor=mRate>80?'#2e7d32':mRate>60?'#c0713a':'#e74c3c';
      return`<div style="flex:1;text-align:center">
        <div style="font-size:20px;margin-bottom:3px">${m.emoji}</div>
        <div class="st-mood-bar-wrap"><div class="st-mood-bar" style="height:${mRate}%;background:${barColor}"></div></div>
        <div style="font-size:11px;font-weight:700;color:#3a2e22;margin-top:3px">${mRate}%</div>
        <div style="font-size:8px;color:#8a7e6a">${m.label}</div>
      </div>`;
    }).join('');
  } else {
    moodEl.innerHTML='<div style="font-size:10px;color:#8a7e6a;padding:12px 0;text-align:center;width:100%">Fais quelques bilans pour voir la corrélation énergie × réussite.</div>';
  }

  // Best / worst day
  const dowNames=['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];
  const dowStats=Array(7).fill(null).map(()=>({ok:0,total:0}));
  dayLog.forEach(d=>{if(d.dow!==undefined){dowStats[d.dow].total++;if(d.success)dowStats[d.dow].ok++;}});
  const dowRates=dowStats.map((d,i)=>({dow:i,rate:d.total?Math.round(d.ok/d.total*100):null,total:d.total})).filter(d=>d.total>=2);
  if(dowRates.length>=2){
    dowRates.sort((a,b)=>b.rate-a.rate);
    const best=dowRates[0],worst=dowRates[dowRates.length-1];
    document.getElementById('st2-best-day').textContent=dowNames[best.dow];
    document.getElementById('st2-best-day-rate').textContent=best.rate+'% de réussite';
    document.getElementById('st2-worst-day').textContent=dowNames[worst.dow];
    document.getElementById('st2-worst-day-rate').textContent=worst.rate+'% de réussite';
  } else {
    document.getElementById('st2-best-day').textContent='—';
    document.getElementById('st2-best-day-rate').textContent='En attente…';
    document.getElementById('st2-worst-day').textContent='—';
    document.getElementById('st2-worst-day-rate').textContent='En attente…';
  }

  // Time Capsule
  document.getElementById('st2-capsule').innerHTML=`
    <div style="font-size:9px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#d4a054;margin-bottom:8px">&#128368; Jour 1 → Jour ${ST.day}</div>
    <div class="st-capsule">
      <div class="st-capsule-val" style="color:#8a7e6a">0%</div><div class="st-capsule-arrow">→</div><div class="st-capsule-val" style="color:#2e7d32">${autoScore}%</div>
      <div style="font-size:8px;color:#8a7e6a;text-align:center">Auto. J1</div><div></div><div style="font-size:8px;color:#2e7d32;text-align:center">Auto. J${ST.day}</div>
      <div class="st-capsule-val" style="color:#8a7e6a">0</div><div class="st-capsule-arrow">→</div><div class="st-capsule-val" style="color:#c0713a">${ST.xp}</div>
      <div style="font-size:8px;color:#8a7e6a;text-align:center">XP</div><div></div><div style="font-size:8px;color:#d4a054;text-align:center">XP</div>
      <div class="st-capsule-val" style="color:#8a7e6a">0</div><div class="st-capsule-arrow">→</div><div class="st-capsule-val" style="color:#d4a054">${ST.bestStreak}</div>
      <div style="font-size:8px;color:#8a7e6a;text-align:center">Streak</div><div></div><div style="font-size:8px;color:#d4a054;text-align:center">Record</div>
    </div>
    <div style="font-size:11px;color:#d4a054;text-align:center;margin-top:8px;font-style:italic">"${autoScore>=70?'Ces habitudes font désormais partie de toi.':ST.day>21?'La transformation est en cours. Continue.':'Chaque jour construit les fondations.'}"</div>`;

  // Bilan history
  function stH2(n){return[...Array(5)].map((_,i)=>`<span class="star-small${i<n?'':' off'}">&#9733;</span>`).join('');}
  const bilansSorted=bilans.filter(b=>!b.isSanction).slice().reverse();
  document.getElementById('st2-bilan-history').innerHTML=bilansSorted.slice(0,30).map(function(b,bi){
    var qd='';
    if(b.quests&&b.quests.length){
      qd='<div id="bqd'+bi+'" style="display:none;margin-top:5px;padding-top:5px;border-top:1px solid #d4c9b0">';
      b.quests.forEach(function(q){
        var si,sc3;
        if(q.s==='perfect'||q.s==='clear'||q.s==='dayoff'){si='✓';sc3='#8a8a8a';}
        else if(q.s==='fail'){si='✗';sc3='#c0392b';}
        else{si='–';sc3='#b0a898';}
        qd+='<div style="font-size:9px;color:'+sc3+';padding:1px 0">'+si+' '+q.n+'</div>';
      });
      qd+='</div>';
    }
    var pb=b.quests&&b.quests.length?'<button onclick="var e=document.getElementById(\'bqd'+bi+'\');e.style.display=e.style.display===\'none\'?\'block\':\'none\';" style="background:none;border:1px solid #d4c9b0;color:#c0713a;width:20px;height:20px;border-radius:4px;font-size:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;line-height:1">+</button>':'';
    return'<div class="st-bilan-mini"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:2px"><span style="font-size:10px;font-weight:600;color:#8a7e6a">J'+b.day+' \u2014 '+b.date+'</span><div style="display:flex;align-items:center;gap:6px"><span style="font-size:10px;font-weight:600;color:'+(b.perfect?'#00694b':b.success?'#2e7d32':'#c0392b')+'">'+(b.perfect?'\u2728 Surpass\u00e9':b.success?'\u2713 R\u00e9ussi':'\u2717 Rat\u00e9')+'</span>'+pb+'</div></div><div style="display:flex;align-items:center;gap:8px;font-size:10px;color:#7a6e5a"><span>\u26A1 '+stH2(b.energy)+'</span><span>\u2694 '+stH2(b.disc)+'</span>'+(b.resisted===true?'<span style="color:#2e7d32">\uD83D\uDEE1\uFE0F Oui!</span>':b.resisted===false?'<span style="color:#c0392b">\uD83D\uDC80 Non.</span>':'')+'</div>'+(b.block?'<div style="font-size:10px;color:#8a7e6a;margin-top:3px;font-style:italic">\u2192 '+b.block+'</div>':'')+qd+'</div>';
  }).join('')||'<div style="font-size:11px;color:#8a7e6a;padding:8px 0">Aucun bilan encore.</div>';
}



