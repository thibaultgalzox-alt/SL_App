  document.getElementById('ob-body').innerHTML=
    '<div class="ob-title">Mon pourquoi</div>'
    +'<div class="ob-sub" style="line-height:1.7;margin-bottom:1.2rem">Avant de signer, prends un moment.<br/>Pourquoi tu fais ça ? Pas pour le système - pour toi.<br/><strong>Cette phrase te sera montrée dans les moments difficiles.</strong></div>'
    +'<textarea id="my-why-input" placeholder="Ex : Je veux devenir quelqu\'un dont je suis fier..." style="width:100%;min-height:100px;border-radius:12px;border:2px solid #d4c9b0;padding:14px;font-size:14px;font-family:inherit;resize:vertical;background:#fff;color:#2a2118;line-height:1.6">'+(ST.myWhy||'')+'</textarea>'
    +'<div style="font-size:11px;color:#8a7e6a;margin-top:6px;font-style:italic">Cette réponse n\'est pas notée. Elle est là pour toi.</div>'
    +'<div style="margin-top:1rem"><button class="btn primary" onclick="saveMyWhy()" style="width:100%">Continuer vers la signature</button></div>';
  document.getElementById('ob-fill').style.width='95%';
