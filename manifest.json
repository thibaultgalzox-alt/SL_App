var _checkedTitles={};
function checkNewTitles(){
  for(var i=0;i<ID_T.length;i++){
    var t=ID_T[i];
    if(t.ok(ST)&&!_checkedTitles[t.id]){
      _checkedTitles[t.id]=true;
      document.getElementById('title-earned-name').textContent='"'+t.name+'"';
      document.getElementById('title-earned-cond').textContent=t.cond;
      SND.rare();flash('gold',800);vib([100,50,100]);
