function buildOB(){
  const total=OB_QS.length,q=OB_QS[ST.obQ];document.getElementById('ob-fill').style.width=Math.round(ST.obQ/total*100)+'%';document.getElementById('ob-lbl').textContent='Question '+(ST.obQ+1)+' / '+total;
  const body=document.getElementById('ob-body');
  if(q.type==='group'){
    // Multi-question page (addictions)
    var allAnswered=q.questions.every(function(sq){return ST.answers[sq.id]!==undefined;});
    var html='<div class="ob-title">'+q.text+'</div><div class="ob-sub">'+(q.sub||'')+'</div>';
    q.questions.forEach(function(sq){
      html+='<div style="margin-bottom:12px"><div style="font-size:12px;font-weight:700;color:var(--ink);margin-bottom:6px">'+sq.label+'</div><div style="display:flex;gap:5px;flex-wrap:wrap">';
      sq.opts.forEach(function(o,i){
        var sel=ST.answers[sq.id]===i;
        html+='<button class="ob-opt'+(sel?' sel':'')+'" style="flex:1;min-width:70px;padding:8px 6px;font-size:10px;text-align:center" onclick="obGroupSel(\''+sq.id+'\','+i+')">'+o+'</button>';
      });
      html+='</div></div>';
    });
    html+='<div class="ob-nav">'+(ST.obQ>0?'<button class="btn" onclick="obBack()">Retour</button>':'')+'<button class="btn primary" id="obn" onclick="obNext()" '+(allAnswered?'':' disabled')+'>Continuer</button></div>';
    body.innerHTML=html;
  }
  else if(q.type==='multi'){const sel=ST.multiAnswers[q.id]||[];body.innerHTML=`<div class="ob-title">${q.text}</div><div class="ob-sub">${q.sub||''}</div><div class="ob-opts" id="ob-opts"></div><div class="ob-nav">${ST.obQ>0?'<button class="btn" onclick="obBack()">Retour</button>':''}<button class="btn primary" onclick="obNextM()">Continuer</button></div>`;const opts=document.getElementById('ob-opts');q.opts.forEach(o=>{const s=sel.includes(o);const b=document.createElement('button');b.className='ob-chk'+(s?' sel':'');b.innerHTML=`<div class="cb">${s?'&#10003;':''}</div><span>${o}</span>`;b.onclick=()=>{const c=ST.multiAnswers[q.id]||[];ST.multiAnswers[q.id]=c.includes(o)?c.filter(x=>x!==o):[...c,o];buildOB();};opts.appendChild(b);});}
  else{body.innerHTML=`<div class="ob-title">${q.text}</div><div class="ob-sub">${q.sub||''}</div><div class="ob-opts" id="ob-opts"></div><div class="ob-nav">${ST.obQ>0?'<button class="btn" onclick="obBack()">Retour</button>':''}<button class="btn primary" id="obn" onclick="obNext()" ${ST.answers[q.id]===undefined?'disabled':''}>Continuer</button></div>`;const opts=document.getElementById('ob-opts');q.opts.forEach((o,i)=>{const b=document.createElement('button');b.className='ob-opt'+(ST.answers[q.id]===i?' sel':'');b.textContent=o;b.onclick=()=>{ST.answers[q.id]=i;document.querySelectorAll('.ob-opt').forEach(x=>x.classList.remove('sel'));b.classList.add('sel');const nb=document.getElementById('obn');if(nb)nb.disabled=false;};opts.appendChild(b);});}
}
function obGroupSel(id,val){ST.answers[id]=val;buildOB();}
function obNext(){
  var q=OB_QS[ST.obQ];
  if(q.type==='group'){
    var allOk=q.questions.every(function(sq){return ST.answers[sq.id]!==undefined;});
    if(!allOk)return;
  } else if(ST.answers[q.id]===undefined)return;
  ST.obQ++;ST.obQ>=OB_QS.length?showMyWhy():buildOB();
}
function obNextM(){ST.obQ++;ST.obQ>=OB_QS.length?showMyWhy():buildOB();}
function obBack(){ST.obQ=Math.max(0,ST.obQ-1);buildOB();}

function showWelcome(){
